<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Trenios.Mobile.ViewModels"
             xmlns:api="clr-namespace:Trenios.Mobile.Models.Api"
             xmlns:services="clr-namespace:Trenios.Mobile.Services"
             xmlns:h="clr-namespace:Trenios.Mobile.Helpers"
             x:Class="Trenios.Mobile.Pages.POSPagePhone"
             x:DataType="vm:POSViewModel"
             Shell.NavBarIsVisible="False"
             x:Name="ThisPage"
             BackgroundColor="{StaticResource Gray100}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- Menu Item Card Template -->
            <DataTemplate x:Key="MenuItemTemplate" x:DataType="api:BranchMenuItemDto">
                <Border StrokeShape="RoundRectangle 12"
                        StrokeThickness="0"
                        BackgroundColor="White"
                        Padding="0"
                        Margin="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.SelectMenuItemCommand}"
                                              CommandParameter="{Binding .}"/>
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="120,Auto">
                        <!-- Product Image -->
                        <Grid Grid.Row="0" BackgroundColor="{StaticResource Gray100}">
                            <Image Source="{Binding PrimaryImageUrl}"
                                   Aspect="AspectFill"
                                   IsVisible="{Binding HasImage}"/>
                            <Label Text="{Binding MenuItemName, Converter={StaticResource FirstLetterConverter}}"
                                   FontSize="40"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource Gray300}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding HasImage, Converter={StaticResource InvertedBoolConverter}}"/>
                        </Grid>
                        <!-- Product Info -->
                        <VerticalStackLayout Grid.Row="1" Padding="10,8" Spacing="2">
                            <Label Text="{Binding MenuItemName}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray900}"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2"/>
                            <Label Text="{Binding CategoryName}"
                                   FontSize="11"
                                   TextColor="{StaticResource Gray400}"
                                   LineBreakMode="TailTruncation"/>
                            <Label Text="{Binding Price, StringFormat='€{0:F2}'}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   TextColor="{StaticResource Primary}"
                                   Margin="0,2,0,0"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </DataTemplate>

            <!-- Cart Item Template -->
            <DataTemplate x:Key="CartItemTemplate" x:DataType="services:CartItem">
                <Border Style="{StaticResource OrderItemCard}" Margin="0,0,0,8">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="{Binding MenuItemName}"
                               FontFamily="OpenSansSemibold"
                               FontSize="14"
                               LineBreakMode="TailTruncation"/>
                        <Label Grid.Row="0" Grid.Column="1"
                               Text="{Binding TotalPrice, StringFormat='€{0:F2}'}"
                               Style="{StaticResource Price}"
                               FontSize="14"/>
                        <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                               Text="{Binding AdditionsSummary}"
                               Style="{StaticResource Caption}"
                               IsVisible="{Binding AdditionsSummary, Converter={StaticResource IsNotNullConverter}}"
                               Margin="0,4,0,0"/>
                        <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                               Spacing="12" Margin="0,8,0,0">
                            <Button Text="-"
                                    Style="{StaticResource QuantityButton}"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.DecreaseQuantityCommand}"
                                    CommandParameter="{Binding .}"/>
                            <Label Text="{Binding Quantity}"
                                   VerticalOptions="Center"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="16"
                                   WidthRequest="30"
                                   HorizontalTextAlignment="Center"/>
                            <Button Text="+"
                                    Style="{StaticResource QuantityButton}"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.IncreaseQuantityCommand}"
                                    CommandParameter="{Binding .}"/>
                            <Button Text="{h:Translate Remove}"
                                    Style="{StaticResource GhostButton}"
                                    TextColor="{StaticResource Danger}"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.RemoveItemCommand}"
                                    CommandParameter="{Binding .}"
                                    HorizontalOptions="EndAndExpand"/>
                        </HorizontalStackLayout>
                    </Grid>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- TOP SECTION: Header + Info + Search + Categories            -->
        <!-- (hidden when cart view is open)                             -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <VerticalStackLayout Grid.Row="0" x:Name="PhoneHeader" Spacing="0"
                             BackgroundColor="White">

            <!-- Header bar: Logo · Language · Logout -->
            <Border StrokeThickness="0"
                    BackgroundColor="White"
                    HeightRequest="72"
                    Padding="16,0">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <!-- Logo -->
                    <Image Source="trenios_logo_red.png"
                           HeightRequest="100"
                           WidthRequest="100"
                           Aspect="AspectFit"
                           HorizontalOptions="Start"
                           VerticalOptions="Center"/>

                    <!-- Language button -->
                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="1.5"
                            Stroke="{StaticResource Gray200}"
                            BackgroundColor="Transparent"
                            Padding="14,8"
                            VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLanguageTapped"/>
                        </Border.GestureRecognizers>
                        <Label x:Name="CurrentLanguageLabel"
                               Text="EN"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               TextColor="{StaticResource Gray700}"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"/>
                    </Border>

                    <!-- Logout button -->
                    <Border Grid.Column="2"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource Primary}"
                            HeightRequest="40"
                            WidthRequest="40"
                            VerticalOptions="Center">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="&#x2794;"
                               FontSize="18"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Divider -->
            <BoxView HeightRequest="1" BackgroundColor="{StaticResource Gray200}"/>

            <!-- Restaurant · Branch info row -->
            <Grid Padding="16,10" ColumnDefinitions="Auto,*" ColumnSpacing="10"
                  BackgroundColor="White">
                <!-- Restaurant icon/logo -->
                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0"
                        HeightRequest="36"
                        WidthRequest="36"
                        BackgroundColor="{StaticResource Gray100}"
                        VerticalOptions="Center">
                    <Image Source="{Binding RestaurantLogoUrl}"
                           Aspect="AspectFill"
                           IsVisible="{Binding HasRestaurantLogo}"/>
                </Border>
                <!-- Restaurant · Branch names -->
                <Label Grid.Column="1"
                       VerticalOptions="Center"
                       FontSize="14">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{Binding RestaurantName}"
                                  FontFamily="OpenSansSemibold"
                                  TextColor="{StaticResource Gray900}"/>
                            <Span Text=" · "
                                  TextColor="{StaticResource Gray400}"/>
                            <Span Text="{Binding BranchName}"
                                  TextColor="{StaticResource Gray600}"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Grid>

            <!-- Search bar -->
            <Border Margin="12,0,12,10"
                    Padding="12,0"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="1"
                    Stroke="{StaticResource Gray200}"
                    BackgroundColor="White"
                    HeightRequest="46">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                    <Label Text="🔍"
                           FontSize="14"
                           TextColor="{StaticResource Gray400}"
                           VerticalOptions="Center"/>
                    <Entry Grid.Column="1"
                           Text="{Binding SearchText, Mode=TwoWay}"
                           Placeholder="{h:Translate SearchMenuItems}"
                           BackgroundColor="Transparent"
                           HeightRequest="46"
                           IsTextPredictionEnabled="False"/>
                </Grid>
            </Border>

            <!-- Category pills: "All" + categories -->
            <ScrollView Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never"
                        Padding="12,0,12,12"
                        HeightRequest="52">
                <HorizontalStackLayout Spacing="8">

                    <!-- "All" pill -->
                    <Border StrokeShape="RoundRectangle 20"
                            StrokeThickness="1"
                            Padding="16,0"
                            HeightRequest="36"
                            VerticalOptions="Center">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding IsAllSelected}"
                                         Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                                <Setter Property="Stroke" Value="{StaticResource Primary}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Border"
                                         Binding="{Binding IsAllSelected}"
                                         Value="False">
                                <Setter Property="BackgroundColor" Value="White"/>
                                <Setter Property="Stroke" Value="{StaticResource Gray200}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectAllCategoriesCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="{h:Translate All}"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               VerticalOptions="Center">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsAllSelected}"
                                             Value="True">
                                    <Setter Property="TextColor" Value="White"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsAllSelected}"
                                             Value="False">
                                    <Setter Property="TextColor" Value="{StaticResource Gray600}"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>

                    <!-- Category pills from ViewModel -->
                    <HorizontalStackLayout Spacing="8"
                                           BindableLayout.ItemsSource="{Binding Categories}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:SelectableCategory">
                                <Border StrokeShape="RoundRectangle 20"
                                        StrokeThickness="1"
                                        Padding="16,0"
                                        HeightRequest="36"
                                        VerticalOptions="Center">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding IsSelected}"
                                                     Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                                            <Setter Property="Stroke" Value="{StaticResource Primary}"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding IsSelected}"
                                                     Value="False">
                                            <Setter Property="BackgroundColor" Value="White"/>
                                            <Setter Property="Stroke" Value="{StaticResource Gray200}"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.SelectCategoryCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="{Binding Name}"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="13"
                                           VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding IsSelected}"
                                                         Value="True">
                                                <Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding IsSelected}"
                                                         Value="False">
                                                <Setter Property="TextColor" Value="{StaticResource Gray600}"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>

                </HorizontalStackLayout>
            </ScrollView>

        </VerticalStackLayout>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- CONTENT AREA: Products View OR Cart View                    -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" x:Name="PhoneContentGrid">

            <!-- Products View -->
            <Grid x:Name="PhoneProductsView" BackgroundColor="{StaticResource Gray100}">
                <CollectionView ItemsSource="{Binding FilteredMenuItems}"
                                ItemTemplate="{StaticResource MenuItemTemplate}"
                                BackgroundColor="Transparent"
                                Margin="8,8">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical"
                                         Span="2"
                                         HorizontalItemSpacing="8"
                                         VerticalItemSpacing="8"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center"
                                             HorizontalOptions="Center"
                                             Spacing="8"
                                             Margin="0,60,0,0">
                            <Label Text="{h:Translate NoItemsInCategory}"
                                   Style="{StaticResource Subtitle}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>

                <!-- Loading indicator -->
                <ActivityIndicator IsRunning="{Binding IsLoadingProducts}"
                                   IsVisible="{Binding IsLoadingProducts}"
                                   Color="{StaticResource Primary}"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"/>
            </Grid>

            <!-- Cart View (shown when user taps bottom bar) -->
            <Grid x:Name="PhoneCartView"
                  IsVisible="False"
                  RowDefinitions="Auto,*,Auto,Auto"
                  BackgroundColor="White">
                <!-- Cart header -->
                <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="Auto,*,Auto">
                    <Button Grid.Column="0"
                            Text="{h:Translate Back}"
                            Style="{StaticResource GhostButton}"
                            Clicked="OnBackToProducts"/>
                    <Label Grid.Column="1"
                           Text="{h:Translate CurrentOrder}"
                           Style="{StaticResource Title}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    <Label Grid.Column="2"
                           Text="{Binding TotalItems, StringFormat='{0} items'}"
                           Style="{StaticResource Caption}"
                           VerticalOptions="Center"/>
                </Grid>
                <BoxView Grid.Row="0" Style="{StaticResource Divider}" VerticalOptions="End"/>

                <!-- Cart items -->
                <CollectionView Grid.Row="1"
                                ItemsSource="{Binding CartItems}"
                                ItemTemplate="{StaticResource CartItemTemplate}"
                                Margin="12,8">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                            <Label Text="{h:Translate CartIsEmpty}"
                                   Style="{StaticResource Subtitle}"
                                   HorizontalOptions="Center"/>
                            <Label Text="{h:Translate AddProductsToStart}"
                                   Style="{StaticResource Caption}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>

                <!-- Total row -->
                <Grid Grid.Row="2"
                      Padding="16,12"
                      ColumnDefinitions="*,Auto"
                      BackgroundColor="{StaticResource Gray50}">
                    <Label Text="{h:Translate Total}" Style="{StaticResource Title}" VerticalOptions="Center"/>
                    <Label Grid.Column="1"
                           Text="{Binding Subtotal, StringFormat='€{0:F2}'}"
                           Style="{StaticResource TotalPrice}"/>
                </Grid>

                <!-- Create Order button -->
                <Grid Grid.Row="3" Padding="12">
                    <Button Text="{h:Translate CreateOrder}"
                            Style="{StaticResource SuccessButton}"
                            Command="{Binding PayCommand}"
                            IsVisible="{Binding HasItems}"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- BOTTOM ACTION BAR (cart summary, shown when HasItems)       -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2"
              x:Name="PhoneBottomBar"
              Padding="12,10"
              IsVisible="{Binding HasItems}"
              BackgroundColor="White">
            <Border StrokeShape="RoundRectangle 14"
                    BackgroundColor="{StaticResource Success}"
                    Padding="16,14"
                    HorizontalOptions="Fill">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCartTapped"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                    <Border WidthRequest="28"
                            HeightRequest="28"
                            StrokeShape="RoundRectangle 14"
                            BackgroundColor="White"
                            StrokeThickness="0">
                        <Label Text="{Binding TotalItems}"
                               TextColor="{StaticResource Success}"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <Label TextColor="White"
                           FontFamily="OpenSansSemibold"
                           FontSize="16"
                           VerticalOptions="Center">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{h:Translate ShowOrders}"/>
                                <Span Text=" - "/>
                                <Span Text="{Binding Subtotal, StringFormat='€{0:F2}'}"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- CUSTOMIZATION OVERLAY                                        -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid IsVisible="{Binding ShowCustomization}"
              BackgroundColor="#80000000"
              Grid.RowSpan="3">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CancelCustomizationCommand}"/>
            </Grid.GestureRecognizers>

            <Border VerticalOptions="Center"
                    HorizontalOptions="Fill"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="0"
                    BackgroundColor="White"
                    MaximumHeightRequest="600"
                    Margin="12"
                    Padding="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer/>
                </Border.GestureRecognizers>

                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <!-- Header -->
                    <Grid Grid.Row="0" Padding="16,14" ColumnDefinitions="*,Auto"
                          BackgroundColor="{StaticResource Primary}">
                        <Label Text="{Binding SelectedMenuItem.MenuItemName}"
                               TextColor="White"
                               FontFamily="OpenSansSemibold"
                               FontSize="18"
                               LineBreakMode="TailTruncation"/>
                        <Label Grid.Column="1"
                               Text="{Binding SelectedMenuItem.Price, StringFormat='€{0:F2}'}"
                               TextColor="White"
                               FontFamily="OpenSansSemibold"
                               FontSize="16"/>
                    </Grid>

                    <!-- Quantity -->
                    <Grid Grid.Row="1" Padding="16,12" ColumnDefinitions="Auto,*,Auto"
                          BackgroundColor="{StaticResource Gray50}">
                        <Label Text="{h:Translate Quantity}"
                               FontFamily="OpenSansSemibold"
                               FontSize="16"
                               VerticalOptions="Center"/>
                        <HorizontalStackLayout Grid.Column="2" Spacing="14">
                            <Button Text="-"
                                    Style="{StaticResource QuantityButton}"
                                    Command="{Binding DecreaseCustomizationQuantityCommand}"
                                    WidthRequest="38" HeightRequest="38" FontSize="18"/>
                            <Label Text="{Binding CustomizationQuantity}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="18"
                                   VerticalOptions="Center"
                                   WidthRequest="40"
                                   HorizontalTextAlignment="Center"/>
                            <Button Text="+"
                                    Style="{StaticResource QuantityButton}"
                                    Command="{Binding IncreaseCustomizationQuantityCommand}"
                                    WidthRequest="38" HeightRequest="38" FontSize="18"/>
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- Additions -->
                    <Grid Grid.Row="2">
                        <ActivityIndicator IsRunning="{Binding IsLoadingAdditions}"
                                           IsVisible="{Binding IsLoadingAdditions}"
                                           Color="{StaticResource Primary}"
                                           VerticalOptions="Center"/>

                        <CollectionView ItemsSource="{Binding SelectableAdditionGroups}"
                                        IsVisible="{Binding IsLoadingAdditions, Converter={StaticResource InvertedBoolConverter}}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:SelectableAdditionGroup">
                                    <VerticalStackLayout Spacing="8" Padding="16,6">
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="{Binding Name}" FontFamily="OpenSansSemibold" FontSize="16"/>
                                            <Label Text="{Binding SelectionHint}" Style="{StaticResource Caption}" FontSize="13" VerticalOptions="Center"/>
                                            <Label Text="*" TextColor="{StaticResource Danger}" FontSize="16"
                                                   IsVisible="{Binding IsRequired}" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                        <!-- Single Select -->
                                        <VerticalStackLayout Spacing="4"
                                                             IsVisible="{Binding IsSingleSelect}"
                                                             BindableLayout.ItemsSource="{Binding Additions}">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="vm:SelectableAddition">
                                                    <Border Padding="10,8"
                                                            StrokeShape="RoundRectangle 6"
                                                            StrokeThickness="1"
                                                            Stroke="{Binding StrokeColor}"
                                                            BackgroundColor="{Binding BackgroundColor}">
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleAdditionCommand}"
                                                                CommandParameter="{Binding .}"/>
                                                        </Border.GestureRecognizers>
                                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                                            <Ellipse Grid.Column="0" WidthRequest="20" HeightRequest="20"
                                                                     Fill="{Binding CheckboxBackgroundColor}"
                                                                     Stroke="{Binding StrokeColor}"
                                                                     StrokeThickness="2" VerticalOptions="Center"/>
                                                            <Label Grid.Column="0" Text="✓" FontSize="11"
                                                                   TextColor="White" HorizontalOptions="Center"
                                                                   VerticalOptions="Center"
                                                                   IsVisible="{Binding IsSelected}" InputTransparent="True"/>
                                                            <Label Grid.Column="1" Text="{Binding Name}" FontSize="14" VerticalOptions="Center"/>
                                                            <Label Grid.Column="2"
                                                                   Text="{Binding UnitPrice, StringFormat='+€{0:F2}'}"
                                                                   FontSize="13"
                                                                   TextColor="{StaticResource Primary}"
                                                                   VerticalOptions="Center"
                                                                   IsVisible="{Binding HasPrice}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </VerticalStackLayout>

                                        <!-- Multi Select -->
                                        <VerticalStackLayout Spacing="4"
                                                             IsVisible="{Binding IsMultiSelect}"
                                                             BindableLayout.ItemsSource="{Binding Additions}">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="vm:SelectableAddition">
                                                    <Border Padding="10,8"
                                                            StrokeShape="RoundRectangle 6"
                                                            StrokeThickness="1"
                                                            Stroke="{Binding StrokeColor}"
                                                            BackgroundColor="{Binding BackgroundColor}"
                                                            Opacity="{Binding ItemOpacity}">
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleAdditionCommand}"
                                                                CommandParameter="{Binding .}"/>
                                                        </Border.GestureRecognizers>
                                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                                            <RoundRectangle Grid.Column="0" WidthRequest="20" HeightRequest="20"
                                                                            CornerRadius="4"
                                                                            Fill="{Binding CheckboxBackgroundColor}"
                                                                            Stroke="{Binding StrokeColor}"
                                                                            StrokeThickness="2" VerticalOptions="Center"/>
                                                            <Label Grid.Column="0" Text="✓" FontSize="11"
                                                                   TextColor="White" HorizontalOptions="Center"
                                                                   VerticalOptions="Center"
                                                                   IsVisible="{Binding IsSelected}" InputTransparent="True"/>
                                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                                <HorizontalStackLayout Spacing="4">
                                                                    <Label Text="{Binding Quantity, StringFormat='{0}x '}"
                                                                           FontSize="14" FontFamily="OpenSansSemibold"
                                                                           TextColor="{StaticResource Primary}"
                                                                           IsVisible="{Binding IsSelected}"/>
                                                                    <Label Text="{Binding Name}" FontSize="14"/>
                                                                </HorizontalStackLayout>
                                                                <Label Text="{Binding UnitPrice, StringFormat='€{0:F2} each'}"
                                                                       FontSize="12" TextColor="{StaticResource Gray500}"
                                                                       IsVisible="{Binding HasPrice}"/>
                                                            </VerticalStackLayout>
                                                            <HorizontalStackLayout Grid.Column="2" Spacing="6"
                                                                                   IsVisible="{Binding IsSelected}"
                                                                                   VerticalOptions="Center">
                                                                <Border WidthRequest="30" HeightRequest="30"
                                                                        StrokeShape="RoundRectangle 15"
                                                                        StrokeThickness="0"
                                                                        BackgroundColor="{StaticResource Gray200}">
                                                                    <Border.GestureRecognizers>
                                                                        <TapGestureRecognizer
                                                                            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.DecreaseAdditionQuantityCommand}"
                                                                            CommandParameter="{Binding .}"/>
                                                                    </Border.GestureRecognizers>
                                                                    <Label Text="-" FontSize="16" FontFamily="OpenSansSemibold"
                                                                           TextColor="{StaticResource Gray700}"
                                                                           HorizontalOptions="Center" VerticalOptions="Center"
                                                                           InputTransparent="True"/>
                                                                </Border>
                                                                <Label Text="{Binding Quantity}" FontSize="14"
                                                                       FontFamily="OpenSansSemibold" WidthRequest="24"
                                                                       HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                                                <Border WidthRequest="30" HeightRequest="30"
                                                                        StrokeShape="RoundRectangle 15"
                                                                        StrokeThickness="0"
                                                                        BackgroundColor="{StaticResource Primary}">
                                                                    <Border.GestureRecognizers>
                                                                        <TapGestureRecognizer
                                                                            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.IncreaseAdditionQuantityCommand}"
                                                                            CommandParameter="{Binding .}"/>
                                                                    </Border.GestureRecognizers>
                                                                    <Label Text="+" FontSize="16" FontFamily="OpenSansSemibold"
                                                                           TextColor="White"
                                                                           HorizontalOptions="Center" VerticalOptions="Center"
                                                                           InputTransparent="True"/>
                                                                </Border>
                                                            </HorizontalStackLayout>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Grid>

                    <!-- Footer -->
                    <Grid Grid.Row="3" RowDefinitions="Auto,Auto,Auto"
                          Padding="12,10" RowSpacing="8"
                          BackgroundColor="{StaticResource Gray50}">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <Label Text="{Binding CustomizationTotalPrice, StringFormat='Total: €{0:F2}'}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="16"
                                   TextColor="{StaticResource Primary}"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <Label Grid.Row="1"
                               Text="{Binding ValidationMessage}"
                               TextColor="{StaticResource Danger}"
                               FontSize="13"
                               HorizontalOptions="Center"
                               IsVisible="{Binding HasValidationError}"/>
                        <Grid Grid.Row="2" ColumnDefinitions="*,2*" ColumnSpacing="10">
                            <Button Grid.Column="0"
                                    Text="{h:Translate Cancel}"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding CancelCustomizationCommand}"/>
                            <Button Grid.Column="1"
                                    Text="{h:Translate AddToOrder}"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ConfirmCustomizationCommand}"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- LOADING OVERLAY                                              -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="#80000000" Grid.RowSpan="3">
            <Frame BackgroundColor="White" CornerRadius="16" Padding="30,20"
                   HasShadow="True" HorizontalOptions="Center" VerticalOptions="Center">
                <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="True" Color="{StaticResource Primary}"
                                       HeightRequest="40" WidthRequest="40"/>
                    <Label Text="{h:Translate CreatingOrder}" FontSize="16"
                           FontFamily="OpenSansSemibold" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- ORDER TYPE SELECTION OVERLAY                                 -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid IsVisible="{Binding ShowOrderTypeSelection}" BackgroundColor="#80000000" Grid.RowSpan="3">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CancelOrderTypeCommand}"/>
            </Grid.GestureRecognizers>
            <Border VerticalOptions="Center" HorizontalOptions="Fill"
                    StrokeShape="RoundRectangle 16" StrokeThickness="0"
                    BackgroundColor="White" Margin="16" Padding="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer/>
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="0">
                    <Grid Padding="20,16" BackgroundColor="{StaticResource Primary}">
                        <Label Text="{h:Translate SelectOrderType}" TextColor="White"
                               FontFamily="OpenSansSemibold" FontSize="18" HorizontalOptions="Center"/>
                    </Grid>
                    <VerticalStackLayout Spacing="10" Padding="20,16">
                        <Button Text="{h:Translate DineIn}" Style="{StaticResource PrimaryButton}"
                                IsVisible="{Binding IsDineInEnabled}"
                                Command="{Binding SelectOrderTypeCommand}" CommandParameter="1"
                                HeightRequest="46" FontSize="16"/>
                        <Button Text="{h:Translate TakeAway}" Style="{StaticResource SecondaryButton}"
                                IsVisible="{Binding IsTakeAwayEnabled}"
                                Command="{Binding SelectOrderTypeCommand}" CommandParameter="2"
                                HeightRequest="46" FontSize="16"/>
                        <Button Text="{h:Translate Delivery}" Style="{StaticResource SecondaryButton}"
                                IsVisible="{Binding IsDeliveryEnabled}"
                                Command="{Binding SelectOrderTypeCommand}" CommandParameter="3"
                                HeightRequest="46" FontSize="16"/>
                        <Button Text="{h:Translate Cancel}" Style="{StaticResource GhostButton}"
                                Command="{Binding CancelOrderTypeCommand}"
                                HeightRequest="40" Margin="0,6,0,0"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- TABLE SELECTION OVERLAY                                      -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid IsVisible="{Binding ShowTableSelection}" BackgroundColor="#80000000" Grid.RowSpan="3">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CancelTableSelectionCommand}"/>
            </Grid.GestureRecognizers>
            <Border VerticalOptions="Center" HorizontalOptions="Fill"
                    StrokeShape="RoundRectangle 16" StrokeThickness="0"
                    BackgroundColor="White" MaximumHeightRequest="500"
                    Margin="12" Padding="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer/>
                </Border.GestureRecognizers>
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Header -->
                    <Grid Grid.Row="0" Padding="20,14" BackgroundColor="{StaticResource Primary}">
                        <VerticalStackLayout HorizontalOptions="Center">
                            <Label Text="{h:Translate SelectTable}" TextColor="White"
                                   FontFamily="OpenSansSemibold" FontSize="18" HorizontalOptions="Center"/>
                            <Label TextColor="#FFCCCC" FontSize="12" HorizontalOptions="Center"
                                   IsVisible="{Binding IsTableRequired}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="(" FontSize="12"/>
                                        <Span Text="{h:Translate TableRequired}" FontSize="12"/>
                                        <Span Text=")" FontSize="12"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                    </Grid>

                    <ActivityIndicator Grid.Row="1"
                                       IsVisible="{Binding IsLoadingTables}"
                                       IsRunning="{Binding IsLoadingTables}"
                                       Color="{StaticResource Primary}"
                                       VerticalOptions="Center"/>

                    <ScrollView Grid.Row="1"
                                IsVisible="{Binding IsLoadingTables, Converter={StaticResource InvertedBoolConverter}}"
                                Margin="12,10">
                        <FlexLayout Wrap="Wrap" JustifyContent="Start" AlignContent="Start"
                                    BindableLayout.ItemsSource="{Binding Tables}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="api:TableDto">
                                    <Border Padding="10"
                                            StrokeShape="RoundRectangle 8"
                                            StrokeThickness="2"
                                            Stroke="{StaticResource Gray200}"
                                            BackgroundColor="White"
                                            WidthRequest="100" HeightRequest="70" Margin="4">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnTableTapped"/>
                                        </Border.GestureRecognizers>
                                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                                            <Label Text="{Binding Number}" FontSize="18"
                                                   FontFamily="OpenSansSemibold" HorizontalOptions="Center"/>
                                            <Label Text="{Binding CapacityDisplay}" FontSize="11"
                                                   TextColor="{StaticResource Gray500}" HorizontalOptions="Center"
                                                   IsVisible="{Binding Capacity, Converter={StaticResource IsNotNullConverter}}"/>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>
                    </ScrollView>

                    <!-- Footer -->
                    <Grid Grid.Row="2" Padding="16,12"
                          RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="10" RowSpacing="10"
                          BackgroundColor="{StaticResource Gray50}">
                        <HorizontalStackLayout Grid.Row="0" Grid.ColumnSpan="3"
                                               HorizontalOptions="Center" Spacing="6"
                                               IsVisible="{Binding SelectedTable, Converter={StaticResource IsNotNullConverter}}">
                            <Label Text="{h:Translate Table}" FontSize="14" TextColor="{StaticResource Gray600}"/>
                            <Label Text="{Binding SelectedTable.Number}" FontSize="16"
                                   FontFamily="OpenSansSemibold" TextColor="{StaticResource Primary}"/>
                        </HorizontalStackLayout>
                        <Button Grid.Row="1" Grid.Column="0"
                                Text="{h:Translate Skip}"
                                Style="{StaticResource GhostButton}"
                                IsVisible="{Binding IsTableRequired, Converter={StaticResource InvertedBoolConverter}}"
                                Command="{Binding SkipTableSelectionCommand}"
                                HorizontalOptions="Start" FontSize="14"/>
                        <Button Grid.Row="1" Grid.Column="1"
                                Text="{h:Translate Cancel}"
                                Style="{StaticResource GhostButton}"
                                Command="{Binding CancelTableSelectionCommand}"
                                FontSize="14"/>
                        <Button Grid.Row="1" Grid.Column="2"
                                Text="{h:Translate Confirm}"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ConfirmTableSelectionCommand}"
                                FontSize="14"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

    </Grid>

</ContentPage>
