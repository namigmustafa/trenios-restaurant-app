<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Trenios.Mobile.ViewModels"
             xmlns:models="clr-namespace:Trenios.Mobile.Models.Api"
             xmlns:h="clr-namespace:Trenios.Mobile.Helpers"
             x:Class="Trenios.Mobile.Pages.TablesPage"
             x:DataType="vm:TablesViewModel"
             x:Name="ThisPage"
             Title="{h:Translate Tables}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="7*,3*">

        <!-- ==================== PAGE HEADER ==================== -->
        <VerticalStackLayout Grid.Row="0" Grid.ColumnSpan="2" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
            <Grid Padding="16,12" HeightRequest="64" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <Image Source="trenios_logo_red.png"
                       HeightRequest="36"
                       HorizontalOptions="Start"
                       VerticalOptions="Center"
                       Aspect="AspectFit"/>
                <Border Grid.Column="1"
                        x:Name="LanguageBorder"
                        Padding="12,6"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="1.5"
                        Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                        VerticalOptions="Center">
                    <Label x:Name="CurrentLanguageLabel"
                           Text="EN"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLanguageTapped"/>
                    </Border.GestureRecognizers>
                </Border>
                <Border Grid.Column="2"
                        Padding="12,8"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0"
                        BackgroundColor="{StaticResource Primary}"
                        VerticalOptions="Center">
                    <Label Text="&#x2794;"
                           FontSize="16"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>
            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>

            <!-- Restaurant · Branch row -->
            <Grid Padding="16,10" HeightRequest="52" ColumnDefinitions="Auto,*" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                <Border WidthRequest="34" HeightRequest="34"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0"
                        BackgroundColor="{StaticResource Primary}"
                        VerticalOptions="Center"
                        IsVisible="{Binding HasRestaurantLogo, Converter={StaticResource InvertedBoolConverter}}">
                    <Label Text="{Binding RestaurantName, Converter={StaticResource FirstLetterConverter}}"
                           TextColor="White"
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
                <Image Source="{Binding RestaurantLogoUrl}"
                       WidthRequest="34" HeightRequest="34"
                       Aspect="AspectFill"
                       VerticalOptions="Center"
                       IsVisible="{Binding HasRestaurantLogo}">
                    <Image.Clip>
                        <RoundRectangleGeometry Rect="0,0,34,34" CornerRadius="8"/>
                    </Image.Clip>
                </Image>
                <Label Grid.Column="1" VerticalOptions="Center" Margin="10,0,0,0">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{Binding RestaurantName}"
                                  FontFamily="OpenSansSemibold"
                                  FontSize="14"
                                  TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                            <Span Text=" · " FontSize="14" TextColor="{StaticResource Gray400}"/>
                            <Span Text="{Binding BranchName}"
                                  FontSize="14"
                                  TextColor="{StaticResource Gray500}"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Grid>
            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>
        </VerticalStackLayout>

        <!-- ==================== CONTENT AREA ==================== -->
        <Grid Grid.Row="1" Grid.Column="0"
              Grid.ColumnSpan="2"
              RowDefinitions="Auto,*"
              BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">

            <!-- Filter / Stats strip -->
            <VerticalStackLayout Grid.Row="0" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}" Spacing="0">

                <!-- Stat summary cards -->
                <Grid Padding="16,12" ColumnDefinitions="*,*" ColumnSpacing="12">
                    <!-- Available -->
                    <Border Grid.Column="0"
                            Padding="16,12"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1.5"
                            Stroke="#27AE60"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{h:Translate Available}"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray500}"/>
                            <Label Text="{Binding AvailableCount}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="28"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                        </VerticalStackLayout>
                    </Border>
                    <!-- Occupied -->
                    <Border Grid.Column="1"
                            Padding="16,12"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1.5"
                            Stroke="{StaticResource Primary}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{h:Translate Occupied}"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray500}"/>
                            <Label Text="{Binding OccupiedCount}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="28"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Filter pills -->
                <HorizontalStackLayout Padding="16,0,16,12" Spacing="8">
                    <!-- All -->
                    <Border Padding="16,8" StrokeShape="RoundRectangle 20" StrokeThickness="1.5"
                            Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" BackgroundColor="Transparent">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding FilterAll}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                                <Setter Property="Stroke" Value="{StaticResource Primary}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Label Text="{h:Translate All}" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding FilterAll}" Value="True">
                                    <Setter Property="TextColor" Value="White"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SetStatusFilterCommand}" CommandParameter="All"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <!-- Available -->
                    <Border Padding="16,8" StrokeShape="RoundRectangle 20" StrokeThickness="1.5"
                            Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" BackgroundColor="Transparent">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding FilterAvailable}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                                <Setter Property="Stroke" Value="{StaticResource Primary}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Label Text="{h:Translate Available}" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding FilterAvailable}" Value="True">
                                    <Setter Property="TextColor" Value="White"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SetStatusFilterCommand}" CommandParameter="Available"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <!-- Occupied -->
                    <Border Padding="16,8" StrokeShape="RoundRectangle 20" StrokeThickness="1.5"
                            Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" BackgroundColor="Transparent">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding FilterOccupied}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                                <Setter Property="Stroke" Value="{StaticResource Primary}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Label Text="{h:Translate Occupied}" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding FilterOccupied}" Value="True">
                                    <Setter Property="TextColor" Value="White"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SetStatusFilterCommand}" CommandParameter="Occupied"/>
                        </Border.GestureRecognizers>
                    </Border>
                </HorizontalStackLayout>

                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>
            </VerticalStackLayout>

            <!-- Tables grid -->
            <RefreshView Grid.Row="1"
                         IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding RefreshCommand}"
                         BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                <CollectionView x:Name="TablesCollectionView"
                                ItemsSource="{Binding FilteredTables}"
                                SelectionMode="None"
                                BackgroundColor="Transparent">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical"
                                         Span="{OnIdiom Phone=2, Default=4}"
                                         HorizontalItemSpacing="12"
                                         VerticalItemSpacing="12"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.Header>
                        <BoxView HeightRequest="12" Color="Transparent" BackgroundColor="Transparent"/>
                    </CollectionView.Header>
                    <CollectionView.Footer>
                        <BoxView HeightRequest="20" Color="Transparent" BackgroundColor="Transparent"/>
                    </CollectionView.Footer>
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="40">
                            <Label Text="{h:Translate NoTablesFound}"
                                   FontSize="16"
                                   TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:TableWithReservationDto">
                            <Border Padding="14"
                                    Margin="12,0"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="2"
                                    Stroke="{Binding StatusColor}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TablesViewModel}}, Path=SelectTableCommand}"
                                                          CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                                    <!-- Table name + dot -->
                                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding TableDisplay}"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="17"
                                               TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                               VerticalOptions="Center"/>
                                        <Ellipse Grid.Column="1"
                                                 WidthRequest="12" HeightRequest="12"
                                                 Fill="{Binding StatusColor}"
                                                 VerticalOptions="Center"/>
                                    </Grid>

                                    <!-- Capacity -->
                                    <HorizontalStackLayout Grid.Row="1" Spacing="4"
                                                           IsVisible="{Binding Capacity, Converter={StaticResource IsNotNullConverter}}">
                                        <Label Text="👥" FontSize="13" VerticalOptions="Center"/>
                                        <Label Text="{Binding CapacityDisplay}"
                                               FontSize="13"
                                               TextColor="{StaticResource Gray500}"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>

                                    <!-- Status badge -->
                                    <Border Grid.Row="2"
                                            Padding="10,5"
                                            StrokeShape="RoundRectangle 20"
                                            StrokeThickness="0"
                                            BackgroundColor="{Binding StatusBadgeBackground}"
                                            HorizontalOptions="Start">
                                        <Label Text="{Binding StatusText}"
                                               FontSize="11"
                                               FontFamily="OpenSansSemibold"
                                               TextColor="{Binding StatusBadgeTextColor}"
                                               TextTransform="Uppercase"/>
                                    </Border>

                                    <!-- Occupied info -->
                                    <VerticalStackLayout Grid.Row="3" Spacing="6" IsVisible="{Binding IsReserved}">
                                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}" Margin="0,2"/>
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <Label Text="⏱" FontSize="12" VerticalOptions="Center"/>
                                            <Label Grid.Column="1" Text="{h:Translate Duration}"
                                                   FontSize="12" TextColor="{StaticResource Gray500}"
                                                   VerticalOptions="Center" Margin="4,0,0,0"/>
                                            <Label Grid.Column="2" Text="{Binding DurationDisplay}"
                                                   FontSize="12" FontFamily="OpenSansSemibold"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" VerticalOptions="Center"/>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{h:Translate Total}"
                                                   FontSize="12" TextColor="{StaticResource Gray500}"
                                                   VerticalOptions="Center"/>
                                            <Label Grid.Column="1"
                                                   Text="{Binding TotalAmountDisplay}"
                                                   FontSize="12" FontFamily="OpenSansSemibold"
                                                   TextColor="{StaticResource Primary}" VerticalOptions="Center"/>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>
        </Grid>

        <!-- ==================== TABLE DETAILS PANEL ==================== -->
        <Grid IsVisible="{Binding HasSelectedTable}"
              Grid.Row="{OnIdiom Phone=0, Default=1}"
              Grid.RowSpan="{OnIdiom Phone=2, Default=1}"
              Grid.Column="0"
              Grid.ColumnSpan="2">
            <!-- Dim backdrop (tablet only) — tap to dismiss -->
            <BoxView BackgroundColor="#80000000"
                     IsVisible="{OnIdiom Phone=False, Default=True}">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseDetailsCommand}"/>
                </BoxView.GestureRecognizers>
            </BoxView>
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                    StrokeThickness="0"
                    HorizontalOptions="{OnIdiom Phone=Fill, Default=End}"
                    WidthRequest="{OnIdiom Phone=-1, Default=420}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="-4,0" Radius="16" Opacity="0.2"/>
                </Border.Shadow>
            <Grid RowDefinitions="Auto,Auto,*,Auto">

                <!-- Phone-only header -->
                <VerticalStackLayout Grid.Row="0" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                                     IsVisible="{OnIdiom Phone=True, Default=False}">
                    <Grid Padding="16,12" HeightRequest="64" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Image Source="trenios_logo_red.png"
                               HeightRequest="36" HorizontalOptions="Start"
                               VerticalOptions="Center" Aspect="AspectFit"/>
                        <Border Grid.Column="1"
                                x:Name="DetailsLanguageBorder"
                                Padding="12,6" StrokeShape="RoundRectangle 8"
                                StrokeThickness="1.5" Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}" VerticalOptions="Center">
                            <Label x:Name="DetailsCurrentLanguageLabel"
                                   Text="EN" FontFamily="OpenSansSemibold" FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLanguageTapped"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Column="2"
                                Padding="12,8" StrokeShape="RoundRectangle 8"
                                StrokeThickness="0" BackgroundColor="{StaticResource Primary}"
                                VerticalOptions="Center">
                            <Label Text="&#x2794;" FontSize="16" TextColor="White"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>
                </VerticalStackLayout>

                <!-- Back / Close row -->
                <Grid Grid.Row="1" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}" Padding="8,6" ColumnDefinitions="Auto,*,Auto">
                    <Border Padding="10,8" StrokeShape="RoundRectangle 8" StrokeThickness="0"
                            BackgroundColor="Transparent"
                            IsVisible="{OnIdiom Phone=True, Default=False}">
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="←" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" VerticalOptions="Center"/>
                            <Label Text="{h:Translate Back}" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CloseDetailsCommand}"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <Border Grid.Column="2"
                            Padding="10,6" StrokeShape="RoundRectangle 8" StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" BackgroundColor="Transparent"
                            IsVisible="{OnIdiom Phone=False, Default=True}">
                        <Label Text="✕" FontSize="14" TextColor="{StaticResource Gray600}"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CloseDetailsCommand}"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <!-- Detail content -->
                <ScrollView Grid.Row="2" Padding="14">
                    <VerticalStackLayout Spacing="12">

                        <!-- Table info card -->
                        <Border Padding="16,14" StrokeShape="RoundRectangle 14"
                                StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                            <VerticalStackLayout Spacing="10">
                                <!-- Name + dot -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{Binding SelectedTable.TableDisplay}"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="26"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                           VerticalOptions="Center"/>
                                    <Ellipse Grid.Column="1"
                                             WidthRequest="14" HeightRequest="14"
                                             Fill="{Binding SelectedTable.StatusColor}"
                                             VerticalOptions="Center"/>
                                </Grid>
                                <!-- Capacity -->
                                <HorizontalStackLayout Spacing="6"
                                                       IsVisible="{Binding SelectedTable.Capacity, Converter={StaticResource IsNotNullConverter}}">
                                    <Label Text="👥" FontSize="14" VerticalOptions="Center"/>
                                    <Label FontSize="14" TextColor="{StaticResource Gray500}" VerticalOptions="Center">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{h:Translate Seats}"/>
                                                <Span Text=": "/>
                                                <Span Text="{Binding SelectedTable.Capacity}"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </HorizontalStackLayout>

                                <!-- Reservation info (occupied only) -->
                                <VerticalStackLayout Spacing="10" IsVisible="{Binding SelectedTable.IsReserved}">
                                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>
                                    <!-- Started + Duration -->
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                                            <Label Text="{h:Translate StartedAt}"
                                                   FontSize="12" TextColor="{StaticResource Gray500}"/>
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="⏱" FontSize="13" TextColor="{StaticResource Primary}" VerticalOptions="Center"/>
                                                <Label Text="{Binding SelectedTable.CurrentReservation.StartedAtFullDisplay}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="14"
                                                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                                       VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                                            <Label Text="{h:Translate Duration}"
                                                   FontSize="12" TextColor="{StaticResource Gray500}"/>
                                            <Label Text="{Binding SelectedTable.CurrentReservation.DurationDisplay}"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="16"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>
                                    <!-- Total Amount -->
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{h:Translate TotalAmount}"
                                               FontSize="12" TextColor="{StaticResource Gray500}"/>
                                        <Label Text="{Binding SelectedTable.CurrentReservation.TotalAmountDisplay}"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="22"
                                               TextColor="{StaticResource Primary}"/>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>

                                <!-- No reservation -->
                                <Label Text="{h:Translate NoReservation}"
                                       FontSize="14"
                                       TextColor="{StaticResource Gray500}"
                                       IsVisible="{Binding SelectedTable.IsReserved, Converter={StaticResource InvertedBoolConverter}}"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- All Orders section -->
                        <Label Text="{h:Translate OrdersInTable}"
                               FontFamily="OpenSansSemibold"
                               FontSize="17"
                               TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                               IsVisible="{Binding SelectedTable.IsReserved}"
                               Margin="4,0"/>

                        <!-- Orders list -->
                        <VerticalStackLayout Spacing="10"
                                             IsVisible="{Binding SelectedTable.IsReserved}"
                                             BindableLayout.ItemsSource="{Binding SelectedTable.CurrentReservation.Orders}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:TableOrderSummaryDto">
                                    <Border Padding="14"
                                            StrokeShape="RoundRectangle 12"
                                            StrokeThickness="1"
                                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                                        <VerticalStackLayout Spacing="0">
                                            <!-- Order header row -->
                                            <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,4">
                                                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                                    <Label Text="{Binding OrderNumber}"
                                                           FontFamily="OpenSansSemibold"
                                                           FontSize="15"
                                                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                                                    <Border Padding="8,3"
                                                            StrokeShape="RoundRectangle 10"
                                                            StrokeThickness="0"
                                                            BackgroundColor="{Binding StatusColor}">
                                                        <Label Text="{Binding StatusDisplay}"
                                                               FontSize="11"
                                                               FontFamily="OpenSansSemibold"
                                                               TextColor="White"/>
                                                    </Border>
                                                </HorizontalStackLayout>
                                                <Label Grid.Column="1"
                                                       Text="{Binding TotalAmountDisplay}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="15"
                                                       TextColor="{StaticResource Primary}"
                                                       VerticalOptions="Center"
                                                       Margin="0,0,8,0"/>
                                                <Border Grid.Column="2"
                                                        Padding="8,4"
                                                        StrokeShape="RoundRectangle 8"
                                                        StrokeThickness="1"
                                                        Stroke="{StaticResource Primary}"
                                                        BackgroundColor="Transparent"
                                                        VerticalOptions="Center"
                                                        IsVisible="{Binding IsNotCancelled}">
                                                    <Label Text="{h:Translate Cancel}"
                                                           FontSize="11"
                                                           FontFamily="OpenSansSemibold"
                                                           TextColor="{StaticResource Primary}"/>
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.CancelOrderCommand}"
                                                            CommandParameter="{Binding .}"/>
                                                    </Border.GestureRecognizers>
                                                </Border>
                                            </Grid>
                                            <!-- Placed time -->
                                            <Label Text="{Binding PlacedAtFullDisplay}"
                                                   FontSize="12"
                                                   TextColor="{StaticResource Gray500}"
                                                   Margin="0,0,0,8"/>
                                            <!-- Items -->
                                            <VerticalStackLayout IsVisible="{Binding HasItems}" Spacing="0">
                                                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}" Margin="0,0,0,8"/>
                                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Items}" Spacing="6">
                                                    <BindableLayout.ItemTemplate>
                                                        <DataTemplate x:DataType="models:OrderItemResponse">
                                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                                                <Label Grid.Column="0"
                                                                       Text="{Binding QuantityDisplay}"
                                                                       FontSize="13"
                                                                       FontFamily="OpenSansSemibold"
                                                                       TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                                                       VerticalOptions="Start"/>
                                                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                                    <Label Text="{Binding MenuItemName}"
                                                                           FontSize="13"
                                                                           FontFamily="OpenSansSemibold"
                                                                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                                                           LineBreakMode="TailTruncation"/>
                                                                    <Label Text="{Binding AdditionsSummary}"
                                                                           FontSize="12"
                                                                           FontAttributes="Italic"
                                                                           TextColor="{StaticResource Gray400}"
                                                                           IsVisible="{Binding HasAdditions}"
                                                                           LineBreakMode="TailTruncation"/>
                                                                </VerticalStackLayout>
                                                                <Label Grid.Column="2"
                                                                       Text="{Binding TotalPriceDisplay}"
                                                                       FontSize="13"
                                                                       TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                                                       VerticalOptions="Start"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </BindableLayout.ItemTemplate>
                                                </VerticalStackLayout>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>

                <!-- Action buttons -->
                <Grid Grid.Row="3"
                      Padding="14,12"
                      ColumnDefinitions="*,*,*"
                      ColumnSpacing="10"
                      BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                      IsVisible="{Binding CanCheckout}">
                    <BoxView Grid.ColumnSpan="3" HeightRequest="1"
                             Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                             VerticalOptions="Start" Margin="0,-12,0,0"/>
                    <!-- Release -->
                    <Border Grid.Column="0" Padding="0,14"
                            StrokeShape="RoundRectangle 12" StrokeThickness="1.5"
                            Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                        <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                            <Label Text="↩" FontSize="16" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"/>
                            <Label Text="{h:Translate Release}" FontSize="12" FontFamily="OpenSansSemibold"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ReleaseCommand}"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <!-- Move -->
                    <Border Grid.Column="1" Padding="0,14"
                            StrokeShape="RoundRectangle 12" StrokeThickness="1.5"
                            Stroke="#3B82F6" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                        <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                            <Label Text="→" FontSize="16" HorizontalOptions="Center" TextColor="#3B82F6"/>
                            <Label Text="{h:Translate Move}" FontSize="12" FontFamily="OpenSansSemibold"
                                   TextColor="#3B82F6" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShowMoveDialogCommand}"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <!-- Checkout -->
                    <Border Grid.Column="2" Padding="0,14"
                            StrokeShape="RoundRectangle 12" StrokeThickness="0"
                            BackgroundColor="{StaticResource Primary}">
                        <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                            <Label Text="💳" FontSize="16" HorizontalOptions="Center"/>
                            <Label Text="{h:Translate Checkout}" FontSize="12" FontFamily="OpenSansSemibold"
                                   TextColor="White" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CheckoutCommand}"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>
            </Grid>
            </Border>
        </Grid>

        <!-- ==================== MOVE TABLE DIALOG ==================== -->
        <Grid Grid.RowSpan="2" Grid.ColumnSpan="2"
              IsVisible="{Binding ShowMoveTableDialog}"
              BackgroundColor="#80000000">
            <Border VerticalOptions="Center"
                    HorizontalOptions="Fill"
                    Margin="16"
                    Padding="0"
                    StrokeShape="RoundRectangle 14"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                    HeightRequest="520">
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Dialog header -->
                    <Grid Grid.Row="0"
                          Padding="16,14"
                          BackgroundColor="{StaticResource Primary}"
                          ColumnDefinitions="*,Auto">
                        <Label Text="{h:Translate SelectTargetTable}"
                               FontFamily="OpenSansSemibold"
                               FontSize="16"
                               TextColor="White"
                               VerticalOptions="Center"/>
                        <Button Grid.Column="1"
                                Text="✕"
                                WidthRequest="34"
                                HeightRequest="34"
                                CornerRadius="17"
                                BackgroundColor="#33FFFFFF"
                                TextColor="White"
                                FontSize="13"
                                Padding="0"
                                Command="{Binding CloseMoveDialogCommand}"/>
                    </Grid>
                    <!-- Available tables -->
                    <CollectionView Grid.Row="1"
                                    x:Name="MoveTargetCollectionView"
                                    ItemsSource="{Binding AvailableTables}"
                                    SelectionMode="Single"
                                    SelectionChanged="OnMoveTargetSelectionChanged"
                                    Margin="8">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20">
                                <Label Text="{h:Translate NoTablesFound}"
                                       FontSize="14"
                                       TextColor="{StaticResource Gray500}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:TableWithReservationDto">
                                <Border Padding="14,12"
                                        Margin="4"
                                        StrokeShape="RoundRectangle 10"
                                        StrokeThickness="2"
                                        Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroupList>
                                            <VisualStateGroup x:Name="CommonStates">
                                                <VisualState x:Name="Normal"/>
                                                <VisualState x:Name="Selected">
                                                    <VisualState.Setters>
                                                        <Setter Property="Stroke" Value="{StaticResource Primary}"/>
                                                        <Setter Property="BackgroundColor" Value="#FFF0F0"/>
                                                    </VisualState.Setters>
                                                </VisualState>
                                            </VisualStateGroup>
                                        </VisualStateGroupList>
                                    </VisualStateManager.VisualStateGroups>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="{Binding TableDisplay}"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="15"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                                            <Label Text="{Binding CapacityDisplay}"
                                                   FontSize="12"
                                                   TextColor="{StaticResource Gray500}"
                                                   IsVisible="{Binding Capacity, Converter={StaticResource IsNotNullConverter}}"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <!-- Confirm -->
                    <VerticalStackLayout Grid.Row="2" Padding="16,12" Spacing="10" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                        <HorizontalStackLayout Spacing="8"
                                               HorizontalOptions="Center"
                                               IsVisible="{Binding TargetTable, Converter={StaticResource IsNotNullConverter}}">
                            <Label Text="{Binding SelectedTable.TableDisplay}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                   VerticalOptions="Center"/>
                            <Label Text="→" FontSize="16" TextColor="{StaticResource Gray500}" VerticalOptions="Center"/>
                            <Label Text="{Binding TargetTable.TableDisplay}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   TextColor="{StaticResource Primary}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Button Text="{h:Translate Confirm}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                FontFamily="OpenSansSemibold"
                                HeightRequest="50"
                                CornerRadius="10"
                                Command="{Binding ConfirmMoveCommand}"
                                IsEnabled="{Binding TargetTable, Converter={StaticResource IsNotNullConverter}}"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </Grid>

        <!-- ==================== LOADING OVERLAY ==================== -->
        <Grid Grid.RowSpan="2" Grid.ColumnSpan="2"
              IsVisible="{Binding IsLoading}"
              BackgroundColor="#80000000">
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               Color="White"
                               WidthRequest="50"
                               HeightRequest="50"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
        </Grid>
    </Grid>
</ContentPage>
