<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Trenios.Mobile.ViewModels"
             xmlns:models="clr-namespace:Trenios.Mobile.Models.Api"
             xmlns:h="clr-namespace:Trenios.Mobile.Helpers"
             x:Class="Trenios.Mobile.Pages.TablesPage"
             x:DataType="vm:TablesViewModel"
             x:Name="ThisPage"
             Title="{h:Translate Tables}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="7*,3*">
        <!-- Header -->
        <Grid Grid.Row="0" Grid.ColumnSpan="2"
              Padding="16,12"
              BackgroundColor="{StaticResource Primary}"
              ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0"
                    Text="{h:Translate Back}"
                    Style="{StaticResource GhostButton}"
                    TextColor="White"
                    Command="{Binding BackCommand}"/>
            <Label Grid.Column="1"
                   Text="{h:Translate Tables}"
                   FontFamily="OpenSansSemibold"
                   FontSize="20"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
            <Button Grid.Column="2"
                    Text="{h:Translate Refresh}"
                    Style="{StaticResource GhostButton}"
                    TextColor="White"
                    Command="{Binding RefreshCommand}"/>
        </Grid>

        <!-- Tables Grid -->
        <RefreshView Grid.Row="1" Grid.Column="0"
                     Grid.ColumnSpan="{Binding HasSelectedTable, Converter={StaticResource BoolToColumnSpanConverter}}"
                     IsRefreshing="{Binding IsRefreshing}"
                     Command="{Binding RefreshCommand}"
                     Margin="0,0,0,12">
            <CollectionView x:Name="TablesCollectionView"
                            ItemsSource="{Binding Tables}"
                            SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="{OnIdiom Phone=2, Default=4}"
                                     HorizontalItemSpacing="12"
                                     VerticalItemSpacing="12"/>
                </CollectionView.ItemsLayout>
                <CollectionView.Header>
                    <BoxView HeightRequest="12" Color="Transparent"/>
                </CollectionView.Header>
                <CollectionView.Footer>
                    <BoxView HeightRequest="20" Color="Transparent"/>
                </CollectionView.Footer>
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="40">
                        <Label Text="{h:Translate NoTablesFound}"
                               FontSize="16"
                               TextColor="{StaticResource Gray500}"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TableWithReservationDto">
                        <Border Padding="16"
                                Margin="12,0"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="2"
                                Stroke="{Binding StatusColor}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TablesViewModel}}, Path=SelectTableCommand}"
                                                      CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="8">
                                <!-- Table Number -->
                                <Label Grid.Row="0"
                                       Text="{Binding TableDisplay}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="18"
                                       HorizontalOptions="Center"/>

                                <!-- Status Badge -->
                                <Border Grid.Row="1"
                                        Padding="12,6"
                                        StrokeShape="RoundRectangle 6"
                                        StrokeThickness="0"
                                        BackgroundColor="{Binding StatusColor}"
                                        HorizontalOptions="Center">
                                    <Label Text="{Binding StatusText}"
                                           FontSize="12"
                                           FontFamily="OpenSansSemibold"
                                           TextColor="White"/>
                                </Border>

                                <!-- Capacity -->
                                <Label Grid.Row="2"
                                       Text="{Binding CapacityDisplay}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray500}"
                                       HorizontalOptions="Center"
                                       IsVisible="{Binding Capacity, Converter={StaticResource IsNotNullConverter}}"/>

                                <!-- Reservation Info (if reserved) -->
                                <VerticalStackLayout Grid.Row="3"
                                                     Spacing="4"
                                                     IsVisible="{Binding IsReserved}">
                                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}" Margin="0,4"/>
                                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                                        <Label Text="{Binding OrdersCount}"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="13"
                                               TextColor="{StaticResource Primary}"/>
                                        <Label Text="{h:Translate OrdersInTable}"
                                               FontSize="13"
                                               TextColor="{StaticResource Gray600}"/>
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding CurrentReservation.TotalAmountDisplay}"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="14"
                                           TextColor="{StaticResource Primary}"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Table Details Panel - Full screen on Phone, Side panel on Tablet -->
        <Border IsVisible="{Binding HasSelectedTable}"
                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                StrokeThickness="1"
                Stroke="{StaticResource Gray300}"
                Grid.Row="{OnIdiom Phone=0, Default=1}"
                Grid.Column="{OnIdiom Phone=0, Default=1}"
                Grid.RowSpan="{OnIdiom Phone=2, Default=1}"
                Grid.ColumnSpan="{OnIdiom Phone=2, Default=1}">
            <Grid RowDefinitions="Auto,*,Auto">
                <!-- Details Header -->
                <Grid Grid.Row="0"
                      Padding="16,12"
                      BackgroundColor="{OnIdiom Phone={StaticResource Primary}, Default={StaticResource Gray100}}"
                      ColumnDefinitions="Auto,*,Auto">
                    <!-- Back button for Phone -->
                    <Button Grid.Column="0"
                            Text="&lt;"
                            FontSize="16"
                            Padding="10,8"
                            BackgroundColor="Transparent"
                            TextColor="{OnIdiom Phone=White, Default={StaticResource Gray700}}"
                            Command="{Binding CloseDetailsCommand}"
                            IsVisible="{OnIdiom Phone=True, Default=False}"/>
                    <VerticalStackLayout Grid.Column="1"
                                         HorizontalOptions="{OnIdiom Phone=Center, Default=Start}">
                        <Label Text="{Binding SelectedTable.TableDisplay}"
                               FontFamily="OpenSansSemibold"
                               FontSize="18"
                               TextColor="{OnIdiom Phone=White, Default={StaticResource Gray900}}"/>
                        <HorizontalStackLayout Spacing="8"
                                               HorizontalOptions="{OnIdiom Phone=Center, Default=Start}">
                            <Border Padding="8,4"
                                    StrokeShape="RoundRectangle 4"
                                    StrokeThickness="0"
                                    BackgroundColor="{Binding SelectedTable.StatusColor}">
                                <Label Text="{Binding SelectedTable.StatusText}"
                                       FontSize="11"
                                       TextColor="White"/>
                            </Border>
                            <Label Text="{Binding SelectedTable.CapacityDisplay}"
                                   FontSize="12"
                                   TextColor="{OnIdiom Phone={StaticResource Gray200}, Default={StaticResource Gray500}}"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding SelectedTable.Capacity, Converter={StaticResource IsNotNullConverter}}"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                    <!-- Close button for Tablet -->
                    <Button Grid.Column="2"
                            Text="X"
                            WidthRequest="40"
                            HeightRequest="40"
                            CornerRadius="20"
                            BackgroundColor="{StaticResource Gray200}"
                            TextColor="{StaticResource Gray700}"
                            Command="{Binding CloseDetailsCommand}"
                            IsVisible="{OnIdiom Phone=False, Default=True}"/>
                </Grid>

                <!-- Reservation Details -->
                <ScrollView Grid.Row="1" Padding="16">
                    <VerticalStackLayout Spacing="16">
                        <!-- No Reservation Message -->
                        <VerticalStackLayout IsVisible="{Binding SelectedTable.IsReserved, Converter={StaticResource InvertedBoolConverter}}"
                                             VerticalOptions="Center"
                                             HorizontalOptions="Center"
                                             Padding="40">
                            <Label Text="{h:Translate NoReservation}"
                                   FontSize="16"
                                   TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <!-- Reservation Info -->
                        <VerticalStackLayout Spacing="16"
                                             IsVisible="{Binding SelectedTable.IsReserved}">
                            <!-- Session Info -->
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" RowSpacing="8" ColumnSpacing="16">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label Text="{h:Translate StartedAt}"
                                           FontSize="12"
                                           TextColor="{StaticResource Gray500}"/>
                                    <Label Text="{Binding SelectedTable.CurrentReservation.StartedAtDisplay}"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="16"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1">
                                    <Label Text="{h:Translate Duration}"
                                           FontSize="12"
                                           TextColor="{StaticResource Gray500}"/>
                                    <Label Text="{Binding SelectedTable.CurrentReservation.DurationDisplay}"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="16"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2">
                                    <Label Text="{h:Translate TotalAmount}"
                                           FontSize="12"
                                           TextColor="{StaticResource Gray500}"/>
                                    <Label Text="{Binding SelectedTable.CurrentReservation.TotalAmountDisplay}"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="20"
                                           TextColor="{StaticResource Primary}"/>
                                </VerticalStackLayout>
                            </Grid>

                            <BoxView HeightRequest="1" Color="{StaticResource Gray200}"/>

                            <!-- Orders Header -->
                            <Label Text="{h:Translate OrdersInTable}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="15"/>

                            <!-- Orders List -->
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding SelectedTable.CurrentReservation.Orders}"
                                                 Spacing="8">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:TableOrderSummaryDto">
                                        <Border Padding="12"
                                                StrokeShape="RoundRectangle 8"
                                                StrokeThickness="1"
                                                Stroke="{StaticResource Gray200}"
                                                BackgroundColor="{StaticResource Gray50}">
                                            <VerticalStackLayout Spacing="8">
                                                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="6">
                                                    <!-- Order Number and Status -->
                                                    <HorizontalStackLayout Grid.Column="0" Spacing="8">
                                                        <Label Text="{Binding OrderNumber}"
                                                               FontFamily="OpenSansSemibold"
                                                               FontSize="14"/>
                                                        <Border Padding="6,2"
                                                                StrokeShape="RoundRectangle 4"
                                                                StrokeThickness="0"
                                                                BackgroundColor="{Binding StatusColor}">
                                                            <Label Text="{Binding StatusDisplay}"
                                                                   FontSize="10"
                                                                   TextColor="White"/>
                                                        </Border>
                                                    </HorizontalStackLayout>

                                                    <!-- Total -->
                                                    <Label Grid.Column="1"
                                                           Text="{Binding TotalAmountDisplay}"
                                                           FontFamily="OpenSansSemibold"
                                                           FontSize="14"
                                                           TextColor="{StaticResource Primary}"/>

                                                    <!-- Items and Time -->
                                                    <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="8">
                                                        <Label Text="{Binding ItemCountDisplay}"
                                                               FontSize="12"
                                                               TextColor="{StaticResource Gray500}"/>
                                                        <Label Text="·"
                                                               FontSize="12"
                                                               TextColor="{StaticResource Gray400}"/>
                                                        <Label Text="{Binding PlacedAtDisplay}"
                                                               FontSize="12"
                                                               TextColor="{StaticResource Gray500}"/>
                                                    </HorizontalStackLayout>
                                                </Grid>

                                                <!-- Order Items -->
                                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Items}"
                                                                     Spacing="4"
                                                                     IsVisible="{Binding HasItems}">
                                                    <BoxView HeightRequest="1" Color="{StaticResource Gray200}"/>
                                                    <BindableLayout.ItemTemplate>
                                                        <DataTemplate x:DataType="models:OrderItemResponse">
                                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Padding="0,2">
                                                                <Label Grid.Column="0"
                                                                       Text="{Binding QuantityDisplay}"
                                                                       FontSize="12"
                                                                       FontFamily="OpenSansSemibold"
                                                                       TextColor="{StaticResource Gray600}"
                                                                       VerticalOptions="Start"/>
                                                                <VerticalStackLayout Grid.Column="1">
                                                                    <Label Text="{Binding MenuItemName}"
                                                                           FontSize="12"
                                                                           TextColor="{StaticResource Gray700}"
                                                                           LineBreakMode="TailTruncation"/>
                                                                    <Label Text="{Binding AdditionsSummary}"
                                                                           FontSize="11"
                                                                           TextColor="{StaticResource Gray400}"
                                                                           IsVisible="{Binding HasAdditions}"
                                                                           LineBreakMode="TailTruncation"/>
                                                                </VerticalStackLayout>
                                                                <Label Grid.Column="2"
                                                                       Text="{Binding TotalPrice, StringFormat='€{0:F2}'}"
                                                                       FontSize="12"
                                                                       TextColor="{StaticResource Gray600}"
                                                                       VerticalOptions="Start"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </BindableLayout.ItemTemplate>
                                                </VerticalStackLayout>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- Actions -->
                <Grid Grid.Row="2"
                      Padding="16"
                      ColumnDefinitions="*,*,*"
                      ColumnSpacing="8"
                      BackgroundColor="{StaticResource Gray100}"
                      IsVisible="{Binding CanCheckout}">
                    <Button Grid.Column="0"
                            Text="{h:Translate Release}"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding ReleaseCommand}"/>
                    <Button Grid.Column="1"
                            Text="{h:Translate Move}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ShowMoveDialogCommand}"/>
                    <Button Grid.Column="2"
                            Text="{h:Translate Checkout}"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding CheckoutCommand}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Move Table Dialog -->
        <Grid Grid.RowSpan="2" Grid.ColumnSpan="2"
              IsVisible="{Binding ShowMoveTableDialog}"
              BackgroundColor="#80000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseMoveDialogCommand}"/>
            </Grid.GestureRecognizers>
            <Border VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Margin="20"
                    Padding="0"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                    MaximumWidthRequest="400"
                    MaximumHeightRequest="500">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer/>
                </Border.GestureRecognizers>
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Dialog Header -->
                    <Grid Grid.Row="0"
                          Padding="16,12"
                          BackgroundColor="{StaticResource Primary}"
                          ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="{h:Translate SelectTargetTable}"
                               FontFamily="OpenSansSemibold"
                               FontSize="16"
                               TextColor="White"
                               VerticalOptions="Center"/>
                        <Button Grid.Column="1"
                                Text="X"
                                WidthRequest="32"
                                HeightRequest="32"
                                CornerRadius="16"
                                BackgroundColor="White"
                                TextColor="{StaticResource Primary}"
                                FontSize="12"
                                Padding="0"
                                Command="{Binding CloseMoveDialogCommand}"/>
                    </Grid>

                    <!-- Available Tables List -->
                    <CollectionView Grid.Row="1"
                                    ItemsSource="{Binding AvailableTables}"
                                    SelectionMode="None"
                                    Margin="8">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="20">
                                <Label Text="{h:Translate NoTablesFound}"
                                       FontSize="14"
                                       TextColor="{StaticResource Gray500}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:TableWithReservationDto">
                                <Border Padding="12"
                                        Margin="4"
                                        StrokeShape="RoundRectangle 8"
                                        StrokeThickness="3"
                                        Stroke="{Binding StatusColor}"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray700}}">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelectedTarget}" Value="True">
                                            <Setter Property="Stroke" Value="{StaticResource Primary}"/>
                                            <Setter Property="BackgroundColor" Value="#E8F0FE"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:TablesViewModel}}, Path=SelectTargetTableCommand}"
                                                              CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="12">
                                        <Label Text="{Binding TableDisplay}"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="16"
                                               VerticalOptions="Center"/>
                                        <Label Text="{Binding CapacityDisplay}"
                                               FontSize="12"
                                               TextColor="{StaticResource Gray500}"
                                               VerticalOptions="Center"
                                               IsVisible="{Binding Capacity, Converter={StaticResource IsNotNullConverter}}"/>
                                        <Label Text="✓"
                                               FontSize="18"
                                               TextColor="{StaticResource Primary}"
                                               FontFamily="OpenSansSemibold"
                                               VerticalOptions="Center"
                                               IsVisible="{Binding IsSelectedTarget}"/>
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Selected Target & Confirm -->
                    <VerticalStackLayout Grid.Row="2"
                                         Padding="16"
                                         Spacing="12"
                                         BackgroundColor="{StaticResource Gray100}">
                        <HorizontalStackLayout Spacing="8"
                                               HorizontalOptions="Center"
                                               IsVisible="{Binding TargetTable, Converter={StaticResource IsNotNullConverter}}">
                            <Label FontSize="14"
                                   TextColor="{StaticResource Gray600}"
                                   VerticalOptions="Center">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{h:Translate MoveTable}"/>
                                        <Span Text=":"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Label Text="{Binding SelectedTable.TableDisplay}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   VerticalOptions="Center"/>
                            <Label Text="→"
                                   FontSize="16"
                                   TextColor="{StaticResource Gray500}"
                                   VerticalOptions="Center"/>
                            <Label Text="{Binding TargetTable.TableDisplay}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   TextColor="{StaticResource Primary}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Button Text="{h:Translate Confirm}"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ConfirmMoveCommand}"
                                IsEnabled="{Binding TargetTable, Converter={StaticResource IsNotNullConverter}}"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </Grid>

        <!-- Loading Overlay -->
        <Grid Grid.RowSpan="2" Grid.ColumnSpan="2"
              IsVisible="{Binding IsLoading}"
              BackgroundColor="#80000000">
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               Color="{StaticResource Primary}"
                               WidthRequest="50"
                               HeightRequest="50"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
        </Grid>
    </Grid>
</ContentPage>
