<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Trenios.Mobile.ViewModels"
             xmlns:models="clr-namespace:Trenios.Mobile.Models.Api"
             xmlns:h="clr-namespace:Trenios.Mobile.Helpers"
             x:Class="Trenios.Mobile.Pages.OrdersPage"
             x:DataType="vm:OrdersViewModel"
             x:Name="ThisPage"
             Title="{h:Translate Orders}"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>

        <!-- Template A: Created / Preparing — swipe enabled -->
        <DataTemplate x:Key="SwipeableOrderTemplate" x:DataType="models:OrderResponse">
            <SwipeView Margin="12,4">
                <SwipeView.LeftItems>
                    <SwipeItems Mode="Reveal">
                        <SwipeItem Text="{h:Translate Cancel}"
                                   BackgroundColor="#e74c3c"
                                   Command="{Binding Source={RelativeSource AncestorType={x:Type vm:OrdersViewModel}}, Path=CancelOrderSwipeCommand}"
                                   CommandParameter="{Binding .}"/>
                    </SwipeItems>
                </SwipeView.LeftItems>
                <SwipeView.RightItems>
                    <SwipeItems Mode="Reveal">
                        <SwipeItem Text="{h:Translate Complete}"
                                   BackgroundColor="#27ae60"
                                   Command="{Binding Source={RelativeSource AncestorType={x:Type vm:OrdersViewModel}}, Path=CompleteOrderSwipeCommand}"
                                   CommandParameter="{Binding .}"/>
                    </SwipeItems>
                </SwipeView.RightItems>
                <Border Padding="14,12"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:OrdersViewModel}}, Path=SelectOrderCommand}"
                                              CommandParameter="{Binding .}"/>
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4">
                        <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6" VerticalOptions="Center">
                            <Label Text="{Binding OrderTypeIcon}" FontSize="15" VerticalOptions="Center"/>
                            <Label Text="{Binding OrderTypeDisplay}" FontSize="13"
                                   TextColor="{StaticResource Gray600}" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Border Grid.Row="0" Grid.Column="1"
                                Padding="10,4" StrokeShape="RoundRectangle 12"
                                StrokeThickness="0" BackgroundColor="{Binding StatusColor}"
                                VerticalOptions="Center">
                            <Label Text="{Binding StatusDisplay}"
                                   FontSize="11" FontFamily="OpenSansSemibold" TextColor="White"/>
                        </Border>
                        <Label Grid.Row="1" Grid.ColumnSpan="2"
                               Text="{Binding OrderNumber}"
                               FontFamily="OpenSansSemibold" FontSize="18"
                               TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" Margin="0,2,0,0"/>
                        <Label Grid.Row="2" Grid.ColumnSpan="2"
                               Text="{Binding TableDisplay}"
                               FontSize="13" FontFamily="OpenSansSemibold"
                               TextColor="{StaticResource Primary}"
                               IsVisible="{Binding HasTable}"/>
                        <Label Grid.Row="3" Grid.ColumnSpan="2"
                               Text="{Binding PlacedAtDisplay}"
                               FontSize="12" TextColor="{StaticResource Gray500}"/>
                        <Label Grid.Row="4" Grid.Column="0"
                               Text="{Binding TotalAmountDisplay, StringFormat='Total - {0}'}"
                               FontFamily="OpenSansSemibold" FontSize="14"
                               TextColor="{StaticResource Primary}" Margin="0,4,0,0"/>
                        <Label Grid.Row="4" Grid.Column="1"
                               Text="{h:Translate SwipeToAction}"
                               FontSize="11" FontAttributes="Italic"
                               TextColor="{StaticResource Gray400}"
                               VerticalOptions="End"/>
                    </Grid>
                </Border>
            </SwipeView>
        </DataTemplate>

        <!-- Template B: Completed / Cancelled / Confirmed — no swipe -->
        <DataTemplate x:Key="ReadOnlyOrderTemplate" x:DataType="models:OrderResponse">
            <Border Margin="12,4"
                    Padding="14,12"
                    StrokeShape="RoundRectangle 12"
                    StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:OrdersViewModel}}, Path=SelectOrderCommand}"
                                          CommandParameter="{Binding .}"/>
                </Border.GestureRecognizers>
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4">
                    <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6" VerticalOptions="Center">
                        <Label Text="{Binding OrderTypeIcon}" FontSize="15" VerticalOptions="Center"/>
                        <Label Text="{Binding OrderTypeDisplay}" FontSize="13"
                               TextColor="{StaticResource Gray600}" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Border Grid.Row="0" Grid.Column="1"
                            Padding="10,4" StrokeShape="RoundRectangle 12"
                            StrokeThickness="0" BackgroundColor="{Binding StatusColor}"
                            VerticalOptions="Center">
                        <Label Text="{Binding StatusDisplay}"
                               FontSize="11" FontFamily="OpenSansSemibold" TextColor="White"/>
                    </Border>
                    <Label Grid.Row="1" Grid.ColumnSpan="2"
                           Text="{Binding OrderNumber}"
                           FontFamily="OpenSansSemibold" FontSize="18"
                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" Margin="0,2,0,0"/>
                    <Label Grid.Row="2" Grid.ColumnSpan="2"
                           Text="{Binding TableDisplay}"
                           FontSize="13" FontFamily="OpenSansSemibold"
                           TextColor="{StaticResource Primary}"
                           IsVisible="{Binding HasTable}"/>
                    <Label Grid.Row="3" Grid.ColumnSpan="2"
                           Text="{Binding PlacedAtDisplay}"
                           FontSize="12" TextColor="{StaticResource Gray500}"/>
                    <Label Grid.Row="4" Grid.Column="0"
                           Text="{Binding TotalAmountDisplay, StringFormat='Total - {0}'}"
                           FontFamily="OpenSansSemibold" FontSize="14"
                           TextColor="{StaticResource Primary}" Margin="0,4,0,0"/>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Selector -->
        <h:OrderDataTemplateSelector x:Key="OrderTemplateSelector"
                                     SwipeableTemplate="{StaticResource SwipeableOrderTemplate}"
                                     ReadOnlyTemplate="{StaticResource ReadOnlyOrderTemplate}"/>

    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="7*,3*">

        <!-- ==================== PAGE HEADER ==================== -->
        <VerticalStackLayout Grid.Row="0" Grid.ColumnSpan="2" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
            <Grid Padding="16,12" HeightRequest="64" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <Image Source="trenios_logo_red.png"
                       HeightRequest="36"
                       HorizontalOptions="Start"
                       VerticalOptions="Center"
                       Aspect="AspectFit"/>
                <Border Grid.Column="1"
                        x:Name="LanguageBorder"
                        Padding="12,6"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="1.5"
                        Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                        VerticalOptions="Center">
                    <Label x:Name="CurrentLanguageLabel"
                           Text="EN"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLanguageTapped"/>
                    </Border.GestureRecognizers>
                </Border>
                <Border Grid.Column="2"
                        Padding="12,8"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0"
                        BackgroundColor="{StaticResource Primary}"
                        VerticalOptions="Center">
                    <Label Text="&#x2794;"
                           FontSize="16"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>
            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>
        </VerticalStackLayout>

        <!-- ==================== CONTENT AREA ==================== -->
        <Grid Grid.Row="1" Grid.Column="0"
              Grid.ColumnSpan="2"
              RowDefinitions="Auto,*"
              BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">

            <!-- Filter / Info strip -->
            <VerticalStackLayout Grid.Row="0" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}" Spacing="0">

                <!-- Restaurant · Branch info row -->
                <Grid Padding="16,10" HeightRequest="52" ColumnDefinitions="Auto,*" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                    <Border WidthRequest="34" HeightRequest="34"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource Primary}"
                            VerticalOptions="Center"
                            IsVisible="{Binding HasRestaurantLogo, Converter={StaticResource InvertedBoolConverter}}">
                        <Label Text="{Binding RestaurantName, Converter={StaticResource FirstLetterConverter}}"
                               TextColor="White"
                               FontFamily="OpenSansSemibold"
                               FontSize="15"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                    <Image Source="{Binding RestaurantLogoUrl}"
                           WidthRequest="34" HeightRequest="34"
                           Aspect="AspectFill"
                           VerticalOptions="Center"
                           IsVisible="{Binding HasRestaurantLogo}">
                        <Image.Clip>
                            <RoundRectangleGeometry CornerRadius="8" Rect="0,0,34,34"/>
                        </Image.Clip>
                    </Image>
                    <Label Grid.Column="1" VerticalOptions="Center" Margin="10,0,0,0">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding RestaurantName}"
                                      FontFamily="OpenSansSemibold"
                                      FontSize="14"
                                      TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                                <Span Text=" · " FontSize="14" TextColor="{StaticResource Gray400}"/>
                                <Span Text="{Binding BranchName}"
                                      FontSize="14"
                                      TextColor="{StaticResource Gray500}"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Grid>

                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>

                <!-- Status filter pills -->
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                            Padding="16,10">
                    <HorizontalStackLayout Spacing="8">

                        <!-- All -->
                        <Border Padding="16,8" StrokeShape="RoundRectangle 20" StrokeThickness="1.5"
                                Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" BackgroundColor="Transparent">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding FilterAll}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                                    <Setter Property="Stroke" Value="{StaticResource Primary}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="{h:Translate All}" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding FilterAll}" Value="True">
                                        <Setter Property="TextColor" Value="White"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetStatusFilterCommand}" CommandParameter="All"/>
                            </Border.GestureRecognizers>
                        </Border>

                        <!-- Created -->
                        <Border Padding="16,8" StrokeShape="RoundRectangle 20" StrokeThickness="1.5"
                                Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" BackgroundColor="Transparent">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding FilterCreated}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                                    <Setter Property="Stroke" Value="{StaticResource Primary}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="{h:Translate Created}" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding FilterCreated}" Value="True">
                                        <Setter Property="TextColor" Value="White"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetStatusFilterCommand}" CommandParameter="Created"/>
                            </Border.GestureRecognizers>
                        </Border>

                        <!-- Preparing -->
                        <Border Padding="16,8" StrokeShape="RoundRectangle 20" StrokeThickness="1.5"
                                Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" BackgroundColor="Transparent">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding FilterPreparing}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                                    <Setter Property="Stroke" Value="{StaticResource Primary}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="{h:Translate Preparing}" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding FilterPreparing}" Value="True">
                                        <Setter Property="TextColor" Value="White"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetStatusFilterCommand}" CommandParameter="Preparing"/>
                            </Border.GestureRecognizers>
                        </Border>

                        <!-- Completed -->
                        <Border Padding="16,8" StrokeShape="RoundRectangle 20" StrokeThickness="1.5"
                                Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" BackgroundColor="Transparent">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding FilterCompleted}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                                    <Setter Property="Stroke" Value="{StaticResource Primary}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="{h:Translate Completed}" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding FilterCompleted}" Value="True">
                                        <Setter Property="TextColor" Value="White"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetStatusFilterCommand}" CommandParameter="Completed"/>
                            </Border.GestureRecognizers>
                        </Border>

                        <!-- Cancelled -->
                        <Border Padding="16,8" StrokeShape="RoundRectangle 20" StrokeThickness="1.5"
                                Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" BackgroundColor="Transparent">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding FilterCancelled}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                                    <Setter Property="Stroke" Value="{StaticResource Primary}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="{h:Translate Cancelled}" FontSize="13" FontFamily="OpenSansSemibold" TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding FilterCancelled}" Value="True">
                                        <Setter Property="TextColor" Value="White"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetStatusFilterCommand}" CommandParameter="Cancelled"/>
                            </Border.GestureRecognizers>
                        </Border>

                    </HorizontalStackLayout>
                </ScrollView>

                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>

                <!-- Show Today checkbox card -->
                <Border Margin="16,12" Padding="14,12"
                        StrokeShape="RoundRectangle 12" StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                    <HorizontalStackLayout Spacing="10">
                        <CheckBox IsChecked="{Binding ShowTodayOnly}"
                                  VerticalOptions="Center"
                                  Color="{StaticResource Primary}"/>
                        <Label Text="{h:Translate ShowToday}"
                               VerticalOptions="Center"
                               FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Date range row (shown when not today only) -->
                <Grid Padding="16,0,16,12"
                      ColumnDefinitions="Auto,Auto,Auto,Auto"
                      ColumnSpacing="8"
                      IsVisible="{Binding ShowTodayOnly, Converter={StaticResource InvertedBoolConverter}}">
                    <Label Text="{h:Translate From}" VerticalOptions="Center" FontSize="13" TextColor="{StaticResource Gray600}"/>
                    <DatePicker Grid.Column="1" Date="{Binding StartDate}" Format="dd/MM/yyyy" FontSize="13" VerticalOptions="Center"/>
                    <Label Grid.Column="2" Text="{h:Translate To}" VerticalOptions="Center" FontSize="13" TextColor="{StaticResource Gray600}"/>
                    <DatePicker Grid.Column="3" Date="{Binding EndDate}" Format="dd/MM/yyyy" FontSize="13" VerticalOptions="Center"/>
                </Grid>


            </VerticalStackLayout>

            <!-- Orders list — grouped by date -->
            <RefreshView Grid.Row="1"
                         IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding RefreshCommand}"
                         BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
                <CollectionView x:Name="OrdersCollectionView"
                                ItemsSource="{Binding GroupedOrders}"
                                IsGrouped="True"
                                SelectionMode="None"
                                BackgroundColor="Transparent">
                    <CollectionView.GroupHeaderTemplate>
                        <DataTemplate x:DataType="vm:OrderGroup">
                            <Grid Padding="16,12,16,4" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <Label Text="📅" FontSize="14" VerticalOptions="Center"/>
                                <Label Grid.Column="1"
                                       Text="{Binding DateLabel}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray800}, Dark={StaticResource Gray200}}"
                                       VerticalOptions="Center"/>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.GroupHeaderTemplate>
                    <CollectionView.Footer>
                        <BoxView HeightRequest="20" Color="Transparent" BackgroundColor="Transparent"/>
                    </CollectionView.Footer>
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="40" Spacing="8">
                            <Label Text="📋" FontSize="40" HorizontalOptions="Center"/>
                            <Label Text="{h:Translate NoOrdersFound}"
                                   FontSize="15"
                                   TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <h:OrderDataTemplateSelector
                            SwipeableTemplate="{StaticResource SwipeableOrderTemplate}"
                            ReadOnlyTemplate="{StaticResource ReadOnlyOrderTemplate}"/>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>
        </Grid>

        <!-- ==================== ORDER DETAILS PANEL ==================== -->
        <Grid IsVisible="{Binding HasSelectedOrder}"
              Grid.Row="{OnIdiom Phone=0, Default=1}"
              Grid.RowSpan="{OnIdiom Phone=2, Default=1}"
              Grid.Column="0"
              Grid.ColumnSpan="2">
            <!-- Dim backdrop (tablet only) — tap to dismiss -->
            <BoxView BackgroundColor="#80000000"
                     IsVisible="{OnIdiom Phone=False, Default=True}">
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseDetailsCommand}"/>
                </BoxView.GestureRecognizers>
            </BoxView>
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}"
                    StrokeThickness="0"
                    HorizontalOptions="{OnIdiom Phone=Fill, Default=End}"
                    WidthRequest="{OnIdiom Phone=-1, Default=420}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="-4,0" Radius="16" Opacity="0.2"/>
                </Border.Shadow>
            <Grid RowDefinitions="Auto,Auto,*,Auto">

                <!-- Details own header (phone only) -->
                <VerticalStackLayout Grid.Row="0" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                                     IsVisible="{OnIdiom Phone=True, Default=False}">
                    <Grid Padding="16,12" HeightRequest="64" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                        <Image Source="trenios_logo_red.png"
                               HeightRequest="36" HorizontalOptions="Start"
                               VerticalOptions="Center" Aspect="AspectFit"/>
                        <Border Grid.Column="1"
                                x:Name="DetailsLanguageBorder"
                                Padding="12,6" StrokeShape="RoundRectangle 8"
                                StrokeThickness="1.5" Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}" VerticalOptions="Center">
                            <Label x:Name="DetailsCurrentLanguageLabel"
                                   Text="EN" FontFamily="OpenSansSemibold" FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLanguageTapped"/>
                            </Border.GestureRecognizers>
                        </Border>
                        <Border Grid.Column="2"
                                Padding="12,8" StrokeShape="RoundRectangle 8"
                                StrokeThickness="0" BackgroundColor="{StaticResource Primary}"
                                VerticalOptions="Center">
                            <Label Text="&#x2794;" FontSize="16" TextColor="White"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>
                </VerticalStackLayout>

                <!-- Back / Close row -->
                <Grid Grid.Row="1" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}" Padding="8,6" ColumnDefinitions="Auto,*,Auto">
                    <Border Padding="10,8" StrokeShape="RoundRectangle 8" StrokeThickness="0"
                            BackgroundColor="Transparent" IsVisible="{OnIdiom Phone=True, Default=False}">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="←" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" VerticalOptions="Center"/>
                            <Label Text="{h:Translate Back}" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CloseDetailsCommand}"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <Border Grid.Column="2"
                            Padding="10,6" StrokeShape="RoundRectangle 8" StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" BackgroundColor="Transparent"
                            IsVisible="{OnIdiom Phone=False, Default=True}">
                        <Label Text="✕" FontSize="14" TextColor="{StaticResource Gray600}"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CloseDetailsCommand}"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>

                <!-- Scrollable detail content -->
                <ScrollView Grid.Row="2" Padding="12">
                    <VerticalStackLayout Spacing="10">

                        <!-- Order summary card -->
                        <Border Padding="16,14" StrokeShape="RoundRectangle 14"
                                StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="6">
                                <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                                    <Label Text="{Binding SelectedOrder.OrderTypeIcon}" FontSize="15" VerticalOptions="Center"/>
                                    <Label Text="{Binding SelectedOrder.OrderTypeDisplay}"
                                           FontSize="13" TextColor="{StaticResource Gray600}" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                                <Border Grid.Row="0" Grid.Column="1"
                                        Padding="12,5" StrokeShape="RoundRectangle 12"
                                        StrokeThickness="0" BackgroundColor="{Binding SelectedOrder.StatusColor}"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding SelectedOrder.StatusDisplay}"
                                           FontSize="12" FontFamily="OpenSansSemibold" TextColor="White"/>
                                </Border>
                                <Label Grid.Row="1" Grid.ColumnSpan="2"
                                       Text="{Binding SelectedOrder.OrderNumber}"
                                       FontFamily="OpenSansSemibold" FontSize="22"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                                <Label Grid.Row="2" Grid.ColumnSpan="2"
                                       Text="{Binding SelectedOrder.TableDisplay}"
                                       FontSize="14" FontFamily="OpenSansSemibold"
                                       TextColor="{StaticResource Primary}"
                                       IsVisible="{Binding SelectedOrder.HasTable}"/>
                                <Label Grid.Row="3" Grid.ColumnSpan="2"
                                       Text="{Binding SelectedOrder.PlacedAtFullDisplay}"
                                       FontSize="13" TextColor="{StaticResource Gray500}"/>
                            </Grid>
                        </Border>

                        <!-- Order items card -->
                        <Border Padding="16,14" StrokeShape="RoundRectangle 14"
                                StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                            <VerticalStackLayout Spacing="0">
                                <Label Text="{h:Translate OrderDetails}"
                                       FontFamily="OpenSansSemibold" FontSize="16"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                       Margin="0,0,0,12"/>
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding SelectedOrder.Items}" Spacing="0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:OrderItemResponse">
                                            <VerticalStackLayout Spacing="0">
                                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Padding="0,10,0,10">
                                                    <Label Grid.Column="0"
                                                           Text="{Binding QuantityDisplay}"
                                                           FontSize="14" TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                                           VerticalOptions="Start" Margin="0,2,0,0"/>
                                                    <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                                        <Label Text="{Binding MenuItemName}"
                                                               FontSize="14" TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                                                        <!-- Discount badge -->
                                                        <Border Padding="6,2" StrokeShape="RoundRectangle 4"
                                                                StrokeThickness="0" BackgroundColor="#DCFCE7"
                                                                IsVisible="{Binding HasDiscount}"
                                                                HorizontalOptions="Start">
                                                            <Label Text="{Binding DiscountLabel}"
                                                                   FontSize="11" FontFamily="OpenSansSemibold"
                                                                   TextColor="#16A34A"/>
                                                        </Border>
                                                        <Label Text="{Binding AdditionsSummary, StringFormat='Extras: {0}'}"
                                                               FontSize="12" FontAttributes="Italic"
                                                               TextColor="{StaticResource Gray500}"
                                                               IsVisible="{Binding HasAdditions}"/>
                                                    </VerticalStackLayout>
                                                    <!-- Price column: strikethrough original + discounted -->
                                                    <VerticalStackLayout Grid.Column="2" Spacing="1" VerticalOptions="Start" HorizontalOptions="End">
                                                        <Label Text="{Binding OriginalTotalPriceDisplay}"
                                                               FontSize="12" TextColor="{StaticResource Gray400}"
                                                               TextDecorations="Strikethrough"
                                                               IsVisible="{Binding HasDiscount}"
                                                               HorizontalOptions="End"/>
                                                        <Label Text="{Binding TotalPriceDisplay}"
                                                               FontSize="14"
                                                               HorizontalOptions="End">
                                                            <Label.Triggers>
                                                                <DataTrigger TargetType="Label" Binding="{Binding HasDiscount}" Value="True">
                                                                    <Setter Property="TextColor" Value="#16A34A"/>
                                                                    <Setter Property="FontFamily" Value="OpenSansSemibold"/>
                                                                </DataTrigger>
                                                                <DataTrigger TargetType="Label" Binding="{Binding HasDiscount}" Value="False">
                                                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                                                                </DataTrigger>
                                                            </Label.Triggers>
                                                        </Label>
                                                    </VerticalStackLayout>
                                                </Grid>
                                                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                                <!-- Add items button — shown below items when order is editable -->
                                <Border Margin="0,10,0,0" Padding="14,8"
                                        StrokeShape="RoundRectangle 20" StrokeThickness="0"
                                        BackgroundColor="{StaticResource Primary}"
                                        HorizontalOptions="Center"
                                        IsVisible="{Binding SelectedOrderCanChangeStatus}">
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="+" FontSize="16" TextColor="White"
                                               FontFamily="OpenSansSemibold" VerticalOptions="Center"/>
                                        <Label Text="{h:Translate AddNewMenu}"
                                               FontFamily="OpenSansSemibold" FontSize="13"
                                               TextColor="White" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding AddItemsToOrderCommand}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Activity sessions card -->
                        <Border Padding="16,14" StrokeShape="RoundRectangle 14"
                                StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                                IsVisible="{Binding ShowActivitiesCard}">
                            <VerticalStackLayout Spacing="0">
                                <Label Text="{h:Translate Activities}"
                                       FontFamily="OpenSansSemibold" FontSize="16"
                                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                       Margin="0,0,0,12"
                                       IsVisible="{Binding SelectedOrder.HasActivitySessions}"/>
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding SelectedOrder.ActivitySessions}" Spacing="0">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:ActivitySessionSummaryDto">
                                            <VerticalStackLayout Spacing="0">
                                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10" Padding="0,10,0,10">
                                                    <Label Grid.Column="0"
                                                           Text="🎯"
                                                           FontSize="14"
                                                           VerticalOptions="Center"/>
                                                    <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                                        <Label Text="{Binding ActivityName}"
                                                               FontSize="14"
                                                               TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                                                        <Label Text="{Binding DurationDisplay}"
                                                               FontSize="12"
                                                               FontFamily="OpenSansSemibold"
                                                               TextColor="{Binding StatusColor}"/>
                                                    </VerticalStackLayout>
                                                    <Label Grid.Column="2"
                                                           Text="{Binding TotalAmountDisplay}"
                                                           FontSize="14"
                                                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                                           VerticalOptions="Center"/>
                                                    <!-- Stop button — only for Active sessions -->
                                                    <Border Grid.Column="3"
                                                            Padding="10,6"
                                                            StrokeShape="RoundRectangle 8"
                                                            StrokeThickness="0"
                                                            BackgroundColor="{StaticResource Primary}"
                                                            VerticalOptions="Center"
                                                            IsVisible="{Binding IsActive}">
                                                        <Label Text="{h:Translate Stop}"
                                                               FontFamily="OpenSansSemibold"
                                                               FontSize="12"
                                                               TextColor="White"/>
                                                        <Border.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:OrdersViewModel}}, Path=StopSessionFromOrderCommand}"
                                                                CommandParameter="{Binding}"/>
                                                        </Border.GestureRecognizers>
                                                    </Border>
                                                </Grid>
                                                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                                <!-- Add Activity button — at the bottom of the activities card -->
                                <Border Margin="0,10,0,0" Padding="14,8"
                                        StrokeShape="RoundRectangle 20" StrokeThickness="0"
                                        BackgroundColor="{StaticResource Primary}"
                                        HorizontalOptions="Center"
                                        IsVisible="{Binding SelectedOrderCanChangeStatus}">
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="+" FontSize="16" TextColor="White"
                                               FontFamily="OpenSansSemibold" VerticalOptions="Center"/>
                                        <Label Text="{h:Translate AddActivity}"
                                               FontFamily="OpenSansSemibold" FontSize="13"
                                               TextColor="White" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding AddActivityToOrderCommand}"/>
                                    </Border.GestureRecognizers>
                                </Border>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Totals card -->
                        <Border Padding="16,14" StrokeShape="RoundRectangle 14"
                                StrokeThickness="1" Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                            <VerticalStackLayout Spacing="0">
                                <Grid ColumnDefinitions="*,Auto" Padding="0,0,0,10">
                                    <Label Text="{h:Translate Subtotal}" FontSize="14" TextColor="{StaticResource Gray500}"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding SelectedOrder.SubTotalDisplay}"
                                           FontSize="14" TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto" Padding="0,0,0,10"
                                      IsVisible="{Binding SelectedOrder.HasDiscount}">
                                    <Label Text="{h:Translate Discount}" FontSize="14" TextColor="{StaticResource Gray500}"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding SelectedOrder.DiscountAmountDisplay}"
                                           FontSize="14" TextColor="{StaticResource Success}"/>
                                </Grid>
                                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}" Margin="0,0,0,10"/>
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{h:Translate Total}"
                                           FontFamily="OpenSansSemibold" FontSize="16"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                                    <Label Grid.Column="1"
                                           Text="{Binding SelectedOrder.TotalAmountDisplay}"
                                           FontFamily="OpenSansSemibold" FontSize="16"
                                           TextColor="{StaticResource Primary}"/>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </ScrollView>

                <!-- Action buttons -->
                <Grid Grid.Row="3"
                      Padding="12,10" ColumnDefinitions="*,*" ColumnSpacing="10"
                      BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                      IsVisible="{Binding SelectedOrderCanChangeStatus}">
                    <BoxView Grid.ColumnSpan="2" HeightRequest="1"
                             Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                             VerticalOptions="Start" Margin="0,-10,0,0"/>
                    <Border Grid.Column="0" Padding="0,14"
                            StrokeShape="RoundRectangle 12" StrokeThickness="1.5"
                            Stroke="{StaticResource Primary}" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                        <Label Text="{h:Translate CancelOrder}"
                               FontFamily="OpenSansSemibold" FontSize="14"
                               TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding UpdateStatusCommand}" CommandParameter="Cancelled"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <Border Grid.Column="1" Padding="0,14"
                            StrokeShape="RoundRectangle 12" StrokeThickness="0"
                            BackgroundColor="{StaticResource Primary}">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding CanCompleteSelectedOrder}" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Label Text="{h:Translate Complete}"
                               FontFamily="OpenSansSemibold" FontSize="14"
                               TextColor="White" HorizontalOptions="Center"/>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding UpdateStatusCommand}" CommandParameter="Completed"/>
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>
            </Grid>
            </Border>
        </Grid>

        <!-- ==================== ACTIVITY SELECTION OVERLAY ==================== -->
        <Grid Grid.RowSpan="2" Grid.ColumnSpan="2"
              IsVisible="{Binding ShowActivitySelection}"
              BackgroundColor="#80000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseActivitySelectionCommand}"/>
            </Grid.GestureRecognizers>

            <Border VerticalOptions="Center" HorizontalOptions="Fill"
                    StrokeShape="RoundRectangle 16" StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                    MaximumHeightRequest="600"
                    Margin="16" Padding="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer/>
                </Border.GestureRecognizers>

                <Grid RowDefinitions="Auto,*">
                    <!-- Header -->
                    <Grid Grid.Row="0" Padding="16,14" ColumnDefinitions="*,Auto"
                          BackgroundColor="{StaticResource Primary}">
                        <Label Text="{h:Translate AddActivity}"
                               FontFamily="OpenSansSemibold" FontSize="17"
                               TextColor="White" VerticalOptions="Center"/>
                        <Border Grid.Column="1" Padding="10,6"
                                StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                BackgroundColor="#33FFFFFF">
                            <Label Text="✕" FontSize="14" TextColor="White"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CloseActivitySelectionCommand}"/>
                            </Border.GestureRecognizers>
                        </Border>
                    </Grid>

                    <!-- Content -->
                    <ScrollView Grid.Row="1">
                        <VerticalStackLayout Padding="0,8" Spacing="0">

                            <!-- Loading -->
                            <ActivityIndicator IsRunning="{Binding IsLoadingActivities}"
                                               IsVisible="{Binding IsLoadingActivities}"
                                               Color="{StaticResource Primary}"
                                               HorizontalOptions="Center"
                                               HeightRequest="80"/>

                            <!-- Groups -->
                            <VerticalStackLayout IsVisible="{Binding IsLoadingActivities, Converter={StaticResource InvertedBoolConverter}}"
                                                 BindableLayout.ItemsSource="{Binding ActivityBoardGroups}"
                                                 Spacing="0">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:ActivityBoardGroupDto">
                                        <VerticalStackLayout Spacing="0">
                                            <!-- Group type header -->
                                            <Label Text="{Binding ActivityTypeName}"
                                                   FontFamily="OpenSansSemibold" FontSize="13"
                                                   TextColor="{StaticResource Gray500}"
                                                   Padding="16,10,16,6"/>

                                            <!-- Activities in group -->
                                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Activities}"
                                                                 Spacing="0">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="models:ActivityBoardItemDto">
                                                        <VerticalStackLayout Spacing="0">
                                                            <Grid ColumnDefinitions="*,Auto" Padding="16,12" ColumnSpacing="12">
                                                                <VerticalStackLayout Spacing="3" VerticalOptions="Center">
                                                                    <Label Text="{Binding Name}"
                                                                           FontFamily="OpenSansSemibold" FontSize="15"
                                                                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                                                                    <Label Text="{Binding UnitPriceDisplay}"
                                                                           FontSize="13" TextColor="{StaticResource Gray500}"/>
                                                                </VerticalStackLayout>

                                                                <!-- Status badge + Start button -->
                                                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                                                    <Border Padding="8,4" HorizontalOptions="End"
                                                                            StrokeShape="RoundRectangle 6" StrokeThickness="0"
                                                                            BackgroundColor="{Binding StatusBackgroundColor}">
                                                                        <Label Text="{Binding StatusDisplay}"
                                                                               FontFamily="OpenSansSemibold" FontSize="11"
                                                                               TextColor="{Binding StatusColor}"/>
                                                                    </Border>
                                                                    <!-- Start button — only for free activities -->
                                                                    <Border Padding="12,7"
                                                                            StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                                                            BackgroundColor="{StaticResource Primary}"
                                                                            IsVisible="{Binding IsOccupied, Converter={StaticResource InvertedBoolConverter}}">
                                                                        <Label Text="{h:Translate Start}"
                                                                               FontFamily="OpenSansSemibold" FontSize="13"
                                                                               TextColor="White" HorizontalOptions="Center"/>
                                                                        <Border.GestureRecognizers>
                                                                            <TapGestureRecognizer
                                                                                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.SelectActivityCommand}"
                                                                                CommandParameter="{Binding .}"/>
                                                                        </Border.GestureRecognizers>
                                                                    </Border>
                                                                </VerticalStackLayout>
                                                            </Grid>
                                                            <BoxView HeightRequest="1"
                                                                     Color="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}"
                                                                     Margin="16,0"/>
                                                        </VerticalStackLayout>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </Border>
        </Grid>

        <!-- ==================== LOADING OVERLAY ==================== -->
        <!-- IsLoadingOverlay = IsLoading && !IsRefreshing — avoids double spinner during pull-to-refresh -->
        <Grid Grid.RowSpan="2" Grid.ColumnSpan="2"
              IsVisible="{Binding IsLoadingOverlay}"
              BackgroundColor="#80000000">
            <ActivityIndicator IsRunning="{Binding IsLoadingOverlay}"
                               Color="White"
                               WidthRequest="50" HeightRequest="50"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
        </Grid>

    </Grid>
</ContentPage>
