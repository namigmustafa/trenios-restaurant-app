<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Trenios.Mobile.ViewModels"
             xmlns:api="clr-namespace:Trenios.Mobile.Models.Api"
             xmlns:services="clr-namespace:Trenios.Mobile.Services"
             xmlns:h="clr-namespace:Trenios.Mobile.Helpers"
             x:Class="Trenios.Mobile.Pages.POSPage"
             x:DataType="vm:POSViewModel"
             Shell.NavBarIsVisible="False"
             x:Name="ThisPage">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- Menu Item Template - Image on left, Name and Price (1.5x size) -->
            <DataTemplate x:Key="MenuItemTemplate" x:DataType="api:BranchMenuItemDto">
                <Border StrokeShape="RoundRectangle 12"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                        Padding="0"
                        HeightRequest="150">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.SelectMenuItemCommand}"
                                              CommandParameter="{Binding .}"/>
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="150,*">
                        <!-- Image or Placeholder on Left -->
                        <Grid Grid.Column="0" BackgroundColor="{StaticResource Gray100}">
                            <Image Source="{Binding PrimaryImageUrl}"
                                   Aspect="AspectFill"
                                   IsVisible="{Binding HasImage}"/>
                            <Label Text="{Binding MenuItemName, Converter={StaticResource FirstLetterConverter}}"
                                   FontSize="42"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource Gray400}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding HasImage, Converter={StaticResource InvertedBoolConverter}}"/>
                        </Grid>
                        <!-- Name & Price on Right -->
                        <VerticalStackLayout Grid.Column="1"
                                             Padding="16,14"
                                             VerticalOptions="Center"
                                             Spacing="8">
                            <Label Text="{Binding MenuItemName}"
                                   FontSize="22"
                                   FontFamily="OpenSansSemibold"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2"/>
                            <Label Text="{Binding Price, StringFormat='€{0:F2}'}"
                                   FontSize="20"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource Primary}"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </DataTemplate>

            <!-- Cart Item Template -->
            <DataTemplate x:Key="CartItemTemplate" x:DataType="services:CartItem">
                <Border Style="{StaticResource OrderItemCard}"
                        Margin="0,0,0,8">
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto,Auto">
                        <!-- Product Name -->
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="{Binding MenuItemName}"
                               FontFamily="OpenSansSemibold"
                               FontSize="14"
                               LineBreakMode="TailTruncation"/>

                        <!-- Price -->
                        <Label Grid.Row="0" Grid.Column="1"
                               Text="{Binding TotalPrice, StringFormat='€{0:F2}'}"
                               Style="{StaticResource Price}"
                               FontSize="14"/>

                        <!-- Additions -->
                        <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                               Text="{Binding AdditionsSummary}"
                               Style="{StaticResource Caption}"
                               IsVisible="{Binding AdditionsSummary, Converter={StaticResource IsNotNullConverter}}"
                               Margin="0,4,0,0"/>

                        <!-- Quantity Controls -->
                        <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                               Spacing="12"
                                               Margin="0,8,0,0">
                            <Button Text="-"
                                    Style="{StaticResource QuantityButton}"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.DecreaseQuantityCommand}"
                                    CommandParameter="{Binding .}"/>
                            <Label Text="{Binding Quantity}"
                                   VerticalOptions="Center"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="16"
                                   WidthRequest="30"
                                   HorizontalTextAlignment="Center"/>
                            <Button Text="+"
                                    Style="{StaticResource QuantityButton}"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.IncreaseQuantityCommand}"
                                    CommandParameter="{Binding .}"/>
                            <Button Text="{h:Translate Remove}"
                                    Style="{StaticResource GhostButton}"
                                    TextColor="{StaticResource Danger}"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.RemoveItemCommand}"
                                    CommandParameter="{Binding .}"
                                    HorizontalOptions="EndAndExpand"/>
                        </HorizontalStackLayout>
                    </Grid>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid x:Name="MainGrid">
        <!-- Tablet Layout (Side by Side) -->
        <Grid x:Name="TabletLayout"
              ColumnDefinitions="*,360"
              IsVisible="False">
            <!-- Left: Products -->
            <Grid Grid.Column="0"
                  RowDefinitions="Auto,Auto,*">
                <!-- Header -->
                <Grid Grid.Row="0"
                      Style="{StaticResource HeaderGrid}"
                      ColumnDefinitions="Auto,*,Auto,Auto">
                    <!-- Branch Button -->
                    <Button Grid.Column="0"
                            Text="{Binding BranchName}"
                            Style="{StaticResource NavButton}"
                            Command="{Binding BackCommand}"
                            FontSize="14"
                            Padding="16,10"/>

                    <!-- Center: Orders and Kitchen -->
                    <HorizontalStackLayout Grid.Column="1"
                                           HorizontalOptions="Center"
                                           Spacing="12">
                        <Button Text="{h:Translate Orders}"
                                Style="{StaticResource NavButton}"
                                Command="{Binding ViewOrdersCommand}"/>
                        <Button Text="{h:Translate Kitchen}"
                                Style="{StaticResource NavButton}"
                                Command="{Binding ViewKitchenCommand}"/>
                    </HorizontalStackLayout>

                    <!-- User with Dropdown -->
                    <Border Grid.Column="2"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="1"
                            Stroke="{StaticResource Gray300}"
                            BackgroundColor="Transparent"
                            Padding="12,8"
                            Margin="0,0,10,0"
                            x:Name="UserDropdownTablet">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnUserTapped"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="{Binding UserName}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   VerticalOptions="Center"/>
                            <Label Text="▼"
                                   FontSize="10"
                                   VerticalOptions="Center"
                                   TextColor="{StaticResource Gray500}"/>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- User Dropdown Menu (hidden by default) -->
                    <Border Grid.Column="2"
                            x:Name="UserMenuTablet"
                            IsVisible="False"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="1"
                            Stroke="{StaticResource Gray300}"
                            BackgroundColor="{StaticResource White}"
                            Padding="4"
                            VerticalOptions="Start"
                            Margin="0,50,10,0"
                            ZIndex="100">
                        <VerticalStackLayout Spacing="2">
                            <Button Text="{h:Translate Language}"
                                    Style="{StaticResource GhostButton}"
                                    Clicked="OnLanguageTapped"
                                    HorizontalOptions="Fill"/>
                            <BoxView HeightRequest="1" BackgroundColor="{StaticResource Gray200}"/>
                            <Button Text="{h:Translate Logout}"
                                    Style="{StaticResource GhostButton}"
                                    TextColor="{StaticResource Danger}"
                                    Command="{Binding LogoutCommand}"
                                    HorizontalOptions="Fill"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Categories -->
                <ScrollView Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                            Padding="12,8">
                    <HorizontalStackLayout Spacing="8"
                                           BindableLayout.ItemsSource="{Binding Categories}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="api:CategoryDto">
                                <Button Text="{Binding Name}"
                                        Style="{StaticResource CategoryButton}"
                                        BackgroundColor="{Binding Color}"
                                        Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.SelectCategoryCommand}"
                                        CommandParameter="{Binding .}"/>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>

                <!-- Products Grid - More items with smaller cards -->
                <Grid Grid.Row="2">
                    <CollectionView ItemsSource="{Binding MenuItems}"
                                    ItemTemplate="{StaticResource MenuItemTemplate}"
                                    BackgroundColor="Transparent"
                                    Margin="4">
                        <CollectionView.ItemsLayout>
                            <GridItemsLayout Orientation="Vertical"
                                             Span="4"
                                             HorizontalItemSpacing="4"
                                             VerticalItemSpacing="4"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.EmptyView>
                            <VerticalStackLayout VerticalOptions="Center"
                                                 HorizontalOptions="Center">
                                <Label Text="{h:Translate NoItemsInCategory}"
                                       Style="{StaticResource Subtitle}"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                    </CollectionView>

                    <!-- Loading -->
                    <ActivityIndicator IsRunning="{Binding IsLoadingProducts}"
                                       IsVisible="{Binding IsLoadingProducts}"
                                       VerticalOptions="Center"
                                       HorizontalOptions="Center"/>

                    <!-- Error -->
                    <VerticalStackLayout IsVisible="{Binding ErrorMessage, Converter={StaticResource IsNotNullConverter}}"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="12">
                        <Label Text="{Binding ErrorMessage}"
                               TextColor="{StaticResource Danger}"
                               HorizontalOptions="Center"/>
                        <Button Text="{h:Translate Retry}"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding RefreshCommand}"/>
                    </VerticalStackLayout>
                </Grid>
            </Grid>

            <!-- Right: Order Summary -->
            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*,Auto,Auto"
                  BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                <!-- Order Header -->
                <Grid Grid.Row="0"
                      Padding="16,12"
                      ColumnDefinitions="*,Auto">
                    <Label Text="{h:Translate CurrentOrder}"
                           Style="{StaticResource Title}"/>
                    <Label Grid.Column="1"
                           Text="{Binding TotalItems, StringFormat='{0} items'}"
                           Style="{StaticResource Caption}"/>
                </Grid>

                <BoxView Grid.Row="0"
                         Style="{StaticResource Divider}"
                         VerticalOptions="End"/>

                <!-- Order Items -->
                <CollectionView Grid.Row="1"
                                ItemsSource="{Binding CartItems}"
                                ItemTemplate="{StaticResource CartItemTemplate}"
                                Margin="12,8">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center"
                                             HorizontalOptions="Center"
                                             Spacing="8">
                            <Label Text="{h:Translate NoItemsYet}"
                                   Style="{StaticResource Subtitle}"
                                   HorizontalOptions="Center"/>
                            <Label Text="{h:Translate TapProductToAdd}"
                                   Style="{StaticResource Caption}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>

                <!-- Totals -->
                <Grid Grid.Row="2"
                      Padding="16,12"
                      ColumnDefinitions="*,Auto"
                      BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource Gray700}}">
                    <Label Text="{h:Translate Total}"
                           Style="{StaticResource Title}"
                           VerticalOptions="Center"/>
                    <Label Grid.Column="1"
                           Text="{Binding Subtotal, StringFormat='€{0:F2}'}"
                           Style="{StaticResource TotalPrice}"/>
                </Grid>

                <!-- Quick Actions -->
                <Grid Grid.Row="3"
                      ColumnDefinitions="*,*,2*"
                      ColumnSpacing="8"
                      Padding="12">
                    <Button Grid.Column="0"
                            Text="{h:Translate Cancel}"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding CancelOrderCommand}"
                            FontSize="14"
                            Padding="8"/>
                    <Button Grid.Column="1"
                            Text="{h:Translate Repeat}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding RepeatLastOrderCommand}"
                            FontSize="14"
                            Padding="8"/>
                    <Button Grid.Column="2"
                            Text="{h:Translate CreateOrder}"
                            Style="{StaticResource SuccessButton}"
                            Command="{Binding PayCommand}"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- Phone Layout (Stacked with Bottom Tabs) -->
        <Grid x:Name="PhoneLayout"
              RowDefinitions="Auto,*,Auto"
              IsVisible="True">
            <!-- Header -->
            <Grid Grid.Row="0"
                  Style="{StaticResource HeaderGrid}"
                  ColumnDefinitions="Auto,*,Auto,Auto,Auto">
                <!-- Branch Button -->
                <Button Grid.Column="0"
                        Text="{Binding BranchName}"
                        Style="{StaticResource NavButton}"
                        Command="{Binding BackCommand}"
                        FontSize="14"
                        Padding="12,8"/>

                <!-- Center: Orders and Kitchen -->
                <HorizontalStackLayout Grid.Column="1"
                                       HorizontalOptions="Center"
                                       Spacing="10">
                    <Button Text="{h:Translate Orders}"
                            Style="{StaticResource NavButton}"
                            Command="{Binding ViewOrdersCommand}"/>
                    <Button Text="{h:Translate Kitchen}"
                            Style="{StaticResource NavButton}"
                            Command="{Binding ViewKitchenCommand}"/>
                </HorizontalStackLayout>

                <!-- Cart Badge -->
                <Border Grid.Column="2"
                        StrokeShape="RoundRectangle 8"
                        BackgroundColor="{StaticResource Primary}"
                        Padding="12,8"
                        IsVisible="{Binding HasItems}"
                        Margin="0,0,8,0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnCartTapped"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="4">
                        <Label Text="{Binding TotalItems}"
                               TextColor="White"
                               FontFamily="OpenSansSemibold"/>
                        <Label Text="{Binding Total, StringFormat=' €{0:F2}'}"
                               TextColor="White"
                               FontFamily="OpenSansSemibold"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- User with Dropdown -->
                <Border Grid.Column="3"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="1"
                        Stroke="{StaticResource Gray300}"
                        BackgroundColor="Transparent"
                        Padding="10,6"
                        x:Name="UserDropdownPhone">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnUserTapped"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="{Binding UserName}"
                               FontFamily="OpenSansSemibold"
                               FontSize="14"
                               VerticalOptions="Center"/>
                        <Label Text="▼"
                               FontSize="10"
                               VerticalOptions="Center"
                               TextColor="{StaticResource Gray500}"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- User Dropdown Menu (hidden by default) -->
                <Border Grid.Column="3"
                        x:Name="UserMenuPhone"
                        IsVisible="False"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="1"
                        Stroke="{StaticResource Gray300}"
                        BackgroundColor="{StaticResource White}"
                        Padding="4"
                        VerticalOptions="Start"
                        Margin="0,45,0,0"
                        ZIndex="100">
                    <VerticalStackLayout Spacing="2">
                        <Button Text="{h:Translate Language}"
                                Style="{StaticResource GhostButton}"
                                Clicked="OnLanguageTapped"
                                HorizontalOptions="Fill"/>
                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource Gray200}"/>
                        <Button Text="{h:Translate Logout}"
                                Style="{StaticResource GhostButton}"
                                TextColor="{StaticResource Danger}"
                                Command="{Binding LogoutCommand}"
                                HorizontalOptions="Fill"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Main Content Area -->
            <Grid Grid.Row="1"
                  x:Name="PhoneContentGrid">
                <!-- Products View -->
                <Grid x:Name="PhoneProductsView"
                      RowDefinitions="Auto,*">
                    <!-- Categories -->
                    <ScrollView Grid.Row="0"
                                Orientation="Horizontal"
                                HorizontalScrollBarVisibility="Never"
                                BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                                Padding="8,8">
                        <HorizontalStackLayout Spacing="8"
                                               BindableLayout.ItemsSource="{Binding Categories}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="api:CategoryDto">
                                    <Button Text="{Binding Name}"
                                            Style="{StaticResource CategoryButton}"
                                            BackgroundColor="{Binding Color}"
                                            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.SelectCategoryCommand}"
                                            CommandParameter="{Binding .}"/>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </HorizontalStackLayout>
                    </ScrollView>

                    <!-- Products Grid - 3 columns on phone -->
                    <Grid Grid.Row="1">
                        <CollectionView ItemsSource="{Binding MenuItems}"
                                        ItemTemplate="{StaticResource MenuItemTemplate}"
                                        BackgroundColor="Transparent"
                                        Margin="4">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical"
                                                 Span="3"
                                                 HorizontalItemSpacing="4"
                                                 VerticalItemSpacing="4"/>
                            </CollectionView.ItemsLayout>
                        </CollectionView>

                        <ActivityIndicator IsRunning="{Binding IsLoadingProducts}"
                                           IsVisible="{Binding IsLoadingProducts}"
                                           VerticalOptions="Center"/>
                    </Grid>
                </Grid>

                <!-- Cart View (Hidden by default on phone) -->
                <Grid x:Name="PhoneCartView"
                      IsVisible="False"
                      RowDefinitions="Auto,*,Auto,Auto"
                      BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                    <!-- Cart Header -->
                    <Grid Grid.Row="0"
                          Padding="16,12"
                          ColumnDefinitions="Auto,*,Auto">
                        <Button Grid.Column="0"
                                Text="{h:Translate Back}"
                                Style="{StaticResource GhostButton}"
                                Clicked="OnBackToProducts"/>
                        <Label Grid.Column="1"
                               Text="{h:Translate CurrentOrder}"
                               Style="{StaticResource Title}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="2"
                               Text="{Binding TotalItems, StringFormat='{0} items'}"
                               Style="{StaticResource Caption}"
                               VerticalOptions="Center"/>
                    </Grid>

                    <BoxView Grid.Row="0"
                             Style="{StaticResource Divider}"
                             VerticalOptions="End"/>

                    <!-- Cart Items -->
                    <CollectionView Grid.Row="1"
                                    ItemsSource="{Binding CartItems}"
                                    ItemTemplate="{StaticResource CartItemTemplate}"
                                    Margin="12,8">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout VerticalOptions="Center"
                                                 HorizontalOptions="Center"
                                                 Spacing="8">
                                <Label Text="{h:Translate CartIsEmpty}"
                                       Style="{StaticResource Subtitle}"
                                       HorizontalOptions="Center"/>
                                <Label Text="{h:Translate AddProductsToStart}"
                                       Style="{StaticResource Caption}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                    </CollectionView>

                    <!-- Totals -->
                    <Grid Grid.Row="2"
                          Padding="16,12"
                          ColumnDefinitions="*,Auto"
                          BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource Gray700}}">
                        <Label Text="{h:Translate Total}"
                               Style="{StaticResource Title}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1"
                               Text="{Binding Subtotal, StringFormat='€{0:F2}'}"
                               Style="{StaticResource TotalPrice}"/>
                    </Grid>

                    <!-- Quick Actions -->
                    <Grid Grid.Row="3"
                          ColumnDefinitions="*,2*"
                          ColumnSpacing="8"
                          Padding="12">
                        <Button Grid.Column="0"
                                Text="{h:Translate Cancel}"
                                Style="{StaticResource DangerButton}"
                                Command="{Binding CancelOrderCommand}"
                                FontSize="14"
                                Padding="8"/>
                        <Button Grid.Column="1"
                                Text="{h:Translate CreateOrder}"
                                Style="{StaticResource SuccessButton}"
                                Command="{Binding PayCommand}"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Bottom Action Bar (Phone only) -->
            <Grid Grid.Row="2"
                  x:Name="PhoneBottomBar"
                  Padding="12"
                  BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                <Button Text="{Binding Subtotal, StringFormat='Create Order  €{0:F2}'}"
                        Style="{StaticResource SuccessButton}"
                        Command="{Binding PayCommand}"
                        HorizontalOptions="Fill"/>
            </Grid>
        </Grid>

        <!-- Customization Overlay -->
        <Grid x:Name="CustomizationOverlay"
              IsVisible="{Binding ShowCustomization}"
              BackgroundColor="#80000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CancelCustomizationCommand}"/>
            </Grid.GestureRecognizers>

            <Border VerticalOptions="Start"
                    HorizontalOptions="Center"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                    WidthRequest="700"
                    Margin="16,30,16,16"
                    Padding="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer/>
                </Border.GestureRecognizers>

                <VerticalStackLayout Spacing="0">
                    <!-- Header with Item Name and Base Price -->
                    <Grid Padding="24,20"
                          ColumnDefinitions="*,Auto"
                          BackgroundColor="{StaticResource Primary}">
                        <Label Text="{Binding SelectedMenuItem.MenuItemName}"
                               TextColor="White"
                               FontFamily="OpenSansSemibold"
                               FontSize="24"
                               LineBreakMode="TailTruncation"/>
                        <Label Grid.Column="1"
                               Text="{Binding SelectedMenuItem.Price, StringFormat='€{0:F2}'}"
                               TextColor="White"
                               FontFamily="OpenSansSemibold"
                               FontSize="22"/>
                    </Grid>

                    <!-- Quantity Selector -->
                    <Grid Padding="24,18"
                          ColumnDefinitions="Auto,*,Auto"
                          BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource Gray700}}">
                        <Label Text="{h:Translate Quantity}"
                               FontFamily="OpenSansSemibold"
                               FontSize="20"
                               VerticalOptions="Center"/>
                        <HorizontalStackLayout Grid.Column="2"
                                               Spacing="20">
                            <Button Text="-"
                                    Style="{StaticResource QuantityButton}"
                                    Command="{Binding DecreaseCustomizationQuantityCommand}"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    FontSize="22"/>
                            <Label Text="{Binding CustomizationQuantity}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="24"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Center"
                                   WidthRequest="50"
                                   HorizontalTextAlignment="Center"/>
                            <Button Text="+"
                                    Style="{StaticResource QuantityButton}"
                                    Command="{Binding IncreaseCustomizationQuantityCommand}"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    FontSize="22"/>
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- Addition Groups - Use CollectionView for virtualized rendering -->
                    <CollectionView ItemsSource="{Binding SelectableAdditionGroups}"
                                    MaximumHeightRequest="500"
                                    VerticalScrollBarVisibility="Default">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="16"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:SelectableAdditionGroup">
                                <VerticalStackLayout Spacing="12" Padding="24,8">
                                    <!-- Group Header -->
                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="{Binding Name}"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="20"/>
                                        <Label Text="{Binding SelectionHint}"
                                               Style="{StaticResource Caption}"
                                               FontSize="16"
                                               VerticalOptions="Center"/>
                                        <Label Text="*"
                                               TextColor="{StaticResource Danger}"
                                               FontSize="18"
                                               IsVisible="{Binding IsRequired}"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>

                                    <!-- Single Select Additions (Radio style) - Virtualized -->
                                    <CollectionView ItemsSource="{Binding Additions}"
                                                    IsVisible="{Binding IsSingleSelect}"
                                                    SelectionMode="None"
                                                    VerticalScrollBarVisibility="Never"
                                                    HeightRequest="{Binding Additions.Count, Converter={StaticResource CountToHeightConverter}}">
                                        <CollectionView.ItemsLayout>
                                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="8"/>
                                        </CollectionView.ItemsLayout>
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="vm:SelectableAddition">
                                                <Border Padding="14,12"
                                                        StrokeShape="RoundRectangle 10"
                                                        StrokeThickness="1"
                                                        Stroke="{Binding IsSelected, Converter={StaticResource BoolToStrokeConverter}}"
                                                        BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToBackgroundConverter}}">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleAdditionCommand}"
                                                                              CommandParameter="{Binding .}"/>
                                                    </Border.GestureRecognizers>
                                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14" InputTransparent="True">
                                                        <!-- Radio Circle -->
                                                        <Border Grid.Column="0"
                                                                WidthRequest="26"
                                                                HeightRequest="26"
                                                                StrokeShape="RoundRectangle 13"
                                                                StrokeThickness="2"
                                                                Stroke="{Binding IsSelected, Converter={StaticResource BoolToStrokeConverter}}"
                                                                BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToCircleBackgroundConverter}}"
                                                                VerticalOptions="Center"
                                                                InputTransparent="True">
                                                            <Label Text="✓"
                                                                   FontSize="14"
                                                                   TextColor="White"
                                                                   HorizontalOptions="Center"
                                                                   VerticalOptions="Center"
                                                                   IsVisible="{Binding IsSelected}"
                                                                   InputTransparent="True"/>
                                                        </Border>
                                                        <!-- Name -->
                                                        <Label Grid.Column="1"
                                                               Text="{Binding Name}"
                                                               FontSize="18"
                                                               VerticalOptions="Center"
                                                               InputTransparent="True"/>
                                                        <!-- Price -->
                                                        <Label Grid.Column="2"
                                                               Text="{Binding UnitPrice, StringFormat='+€{0:F2}'}"
                                                               FontSize="16"
                                                               TextColor="{StaticResource Primary}"
                                                               VerticalOptions="Center"
                                                               IsVisible="{Binding HasPrice}"
                                                               InputTransparent="True"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>

                                    <!-- Multi Select Additions (Checkbox style with +/-) - Virtualized -->
                                    <CollectionView ItemsSource="{Binding Additions}"
                                                    IsVisible="{Binding IsMultiSelect}"
                                                    SelectionMode="None"
                                                    VerticalScrollBarVisibility="Never"
                                                    HeightRequest="{Binding Additions.Count, Converter={StaticResource CountToHeightMultiConverter}}">
                                        <CollectionView.ItemsLayout>
                                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="8"/>
                                        </CollectionView.ItemsLayout>
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="vm:SelectableAddition">
                                                <Border Padding="14,12"
                                                        StrokeShape="RoundRectangle 10"
                                                        StrokeThickness="1"
                                                        Stroke="{Binding IsSelected, Converter={StaticResource BoolToStrokeConverter}}"
                                                        BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToBackgroundConverter}}"
                                                        Opacity="{Binding ItemOpacity}">
                                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                                        <!-- Checkbox Square -->
                                                        <Border Grid.Column="0"
                                                                WidthRequest="26"
                                                                HeightRequest="26"
                                                                StrokeShape="RoundRectangle 5"
                                                                StrokeThickness="2"
                                                                Stroke="{Binding IsSelected, Converter={StaticResource BoolToStrokeConverter}}"
                                                                BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToCircleBackgroundConverter}}"
                                                                VerticalOptions="Center">
                                                            <Border.GestureRecognizers>
                                                                <TapGestureRecognizer Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleAdditionCommand}"
                                                                                      CommandParameter="{Binding .}"/>
                                                            </Border.GestureRecognizers>
                                                            <Label Text="✓"
                                                                   FontSize="14"
                                                                   TextColor="White"
                                                                   HorizontalOptions="Center"
                                                                   VerticalOptions="Center"
                                                                   IsVisible="{Binding IsSelected}"/>
                                                        </Border>

                                                        <!-- Name and Price (tappable to toggle) -->
                                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                            <VerticalStackLayout.GestureRecognizers>
                                                                <TapGestureRecognizer Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleAdditionCommand}"
                                                                                      CommandParameter="{Binding .}"/>
                                                            </VerticalStackLayout.GestureRecognizers>
                                                            <HorizontalStackLayout Spacing="4">
                                                                <Label Text="{Binding Quantity, StringFormat='{0}x '}"
                                                                       FontSize="16"
                                                                       FontFamily="OpenSansSemibold"
                                                                       TextColor="{StaticResource Primary}"
                                                                       IsVisible="{Binding IsSelected}"/>
                                                                <Label Text="{Binding Name}"
                                                                       FontSize="16"/>
                                                            </HorizontalStackLayout>
                                                            <Label Text="{Binding UnitPrice, StringFormat='€{0:F2} each'}"
                                                                   FontSize="13"
                                                                   TextColor="{StaticResource Gray500}"
                                                                   IsVisible="{Binding HasPrice}"/>
                                                        </VerticalStackLayout>

                                                        <!-- +/- Buttons (only visible when selected) -->
                                                        <HorizontalStackLayout Grid.Column="2"
                                                                               Spacing="8"
                                                                               IsVisible="{Binding IsSelected}"
                                                                               VerticalOptions="Center">
                                                            <!-- Decrease Button -->
                                                            <Border WidthRequest="34"
                                                                    HeightRequest="34"
                                                                    StrokeShape="RoundRectangle 17"
                                                                    StrokeThickness="0"
                                                                    BackgroundColor="{StaticResource Gray200}">
                                                                <Border.GestureRecognizers>
                                                                    <TapGestureRecognizer Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.DecreaseAdditionQuantityCommand}"
                                                                                          CommandParameter="{Binding .}"/>
                                                                </Border.GestureRecognizers>
                                                                <Label Text="-"
                                                                       FontSize="18"
                                                                       FontFamily="OpenSansSemibold"
                                                                       TextColor="{StaticResource Gray700}"
                                                                       HorizontalOptions="Center"
                                                                       VerticalOptions="Center"
                                                                       InputTransparent="True"/>
                                                            </Border>

                                                            <!-- Quantity Display -->
                                                            <Label Text="{Binding Quantity}"
                                                                   FontSize="16"
                                                                   FontFamily="OpenSansSemibold"
                                                                   WidthRequest="28"
                                                                   HorizontalTextAlignment="Center"
                                                                   VerticalOptions="Center"/>

                                                            <!-- Increase Button -->
                                                            <Border WidthRequest="34"
                                                                    HeightRequest="34"
                                                                    StrokeShape="RoundRectangle 17"
                                                                    StrokeThickness="0"
                                                                    BackgroundColor="{StaticResource Primary}">
                                                                <Border.GestureRecognizers>
                                                                    <TapGestureRecognizer Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.IncreaseAdditionQuantityCommand}"
                                                                                          CommandParameter="{Binding .}"/>
                                                                </Border.GestureRecognizers>
                                                                <Label Text="+"
                                                                       FontSize="18"
                                                                       FontFamily="OpenSansSemibold"
                                                                       TextColor="White"
                                                                       HorizontalOptions="Center"
                                                                       VerticalOptions="Center"
                                                                       InputTransparent="True"/>
                                                            </Border>

                                                            <!-- Total Price -->
                                                            <Label Text="{Binding TotalPrice, StringFormat='€{0:F2}'}"
                                                                   FontSize="15"
                                                                   FontFamily="OpenSansSemibold"
                                                                   TextColor="{StaticResource Primary}"
                                                                   WidthRequest="55"
                                                                   HorizontalTextAlignment="End"
                                                                   VerticalOptions="Center"
                                                                   IsVisible="{Binding HasPrice}"/>
                                                        </HorizontalStackLayout>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Footer with Total and Actions -->
                    <Grid RowDefinitions="Auto,Auto"
                          Padding="20,12"
                          RowSpacing="12"
                          BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource Gray700}}">
                        <!-- Price Breakdown -->
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <VerticalStackLayout>
                                <Label Text="{h:Translate ItemTotal}"
                                       Style="{StaticResource Caption}"/>
                                <Label Style="{StaticResource Caption}">
                                    <Label.Text>
                                        <MultiBinding StringFormat="€{0:F2} x {1}">
                                            <Binding Path="CustomizationItemPrice"/>
                                            <Binding Path="CustomizationQuantity"/>
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                            </VerticalStackLayout>
                            <Label Grid.Column="1"
                                   Text="{Binding CustomizationTotalPrice, StringFormat='€{0:F2}'}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="24"
                                   TextColor="{StaticResource Primary}"
                                   VerticalOptions="Center"/>
                        </Grid>

                        <!-- Action Buttons -->
                        <Grid Grid.Row="1"
                              ColumnDefinitions="*,2*"
                              ColumnSpacing="12">
                            <Button Grid.Column="0"
                                    Text="{h:Translate Cancel}"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding CancelCustomizationCommand}"/>
                            <Button Grid.Column="1"
                                    Text="{h:Translate AddToOrder}"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ConfirmCustomizationCommand}"/>
                        </Grid>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Loading Overlay for Order Creation -->
        <Grid IsVisible="{Binding IsBusy}"
              BackgroundColor="#80000000"
              ZIndex="200">
            <Frame BackgroundColor="{StaticResource White}"
                   CornerRadius="16"
                   Padding="40,30"
                   HasShadow="True"
                   HorizontalOptions="Center"
                   VerticalOptions="Center">
                <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="True"
                                       Color="{StaticResource Primary}"
                                       HeightRequest="50"
                                       WidthRequest="50"/>
                    <Label Text="{h:Translate CreatingOrder}"
                           FontSize="18"
                           FontFamily="OpenSansSemibold"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
        </Grid>

        <!-- Loading Overlay for Menu Item Selection -->
        <Grid IsVisible="{Binding IsLoadingAdditions}"
              BackgroundColor="#80000000"
              ZIndex="150">
            <Frame BackgroundColor="{StaticResource White}"
                   CornerRadius="16"
                   Padding="40,30"
                   HasShadow="True"
                   HorizontalOptions="Center"
                   VerticalOptions="Center">
                <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="True"
                                       Color="{StaticResource Primary}"
                                       HeightRequest="50"
                                       WidthRequest="50"/>
                    <Label Text="{h:Translate Loading}"
                           FontSize="18"
                           FontFamily="OpenSansSemibold"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Frame>
        </Grid>
    </Grid>

</ContentPage>
