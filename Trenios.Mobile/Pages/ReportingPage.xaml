<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Trenios.Mobile.ViewModels"
             xmlns:models="clr-namespace:Trenios.Mobile.Models.Api"
             xmlns:h="clr-namespace:Trenios.Mobile.Helpers"
             x:Class="Trenios.Mobile.Pages.ReportingPage"
             x:DataType="vm:ReportingViewModel"
             Title="{h:Translate Reports}"
             Shell.NavBarIsVisible="False">

    <ScrollView BackgroundColor="{StaticResource Gray100}">
        <VerticalStackLayout Spacing="0" Padding="0">

            <!-- ==================== PAGE HEADER ==================== -->
            <VerticalStackLayout BackgroundColor="White" Padding="0,0,0,0">
                <Grid Padding="16,12" HeightRequest="64" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <Image Source="trenios_logo_red.png"
                           HeightRequest="36"
                           HorizontalOptions="Start"
                           VerticalOptions="Center"
                           Aspect="AspectFit" />
                    <Border Grid.Column="1"
                            x:Name="CurrentLanguageLabel"
                            Padding="12,6"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="1.5"
                            Stroke="{StaticResource Gray300}"
                            BackgroundColor="White"
                            VerticalOptions="Center">
                        <Label x:Name="LanguageLabel"
                               Text="EN"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               TextColor="{StaticResource Gray700}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLanguageTapped" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border Grid.Column="2"
                            Padding="12,8"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource Primary}"
                            VerticalOptions="Center">
                        <Label Text="&#x2794;"
                               FontSize="16"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLogoutTapped" />
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>
                <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />
            </VerticalStackLayout>

            <!-- ==================== CONTEXT CARD ==================== -->
            <Border Margin="16,16,16,0"
                    Padding="16"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 14"
                    StrokeThickness="1"
                    Stroke="{StaticResource Gray200}">
                <VerticalStackLayout Spacing="10">

                    <!-- Role label and context name -->
                    <Label Text="{Binding ContextLabel}"
                           FontSize="11"
                           TextColor="{StaticResource Gray500}"
                           CharacterSpacing="1.5" />
                    <Label Text="{Binding ContextName}"
                           FontFamily="OpenSansSemibold"
                           FontSize="20"
                           TextColor="{StaticResource Primary}" />

                    <!-- Restaurant picker - SuperAdmin only -->
                    <Border IsVisible="{Binding ShowRestaurantFilter}"
                            Padding="12,10"
                            BackgroundColor="White"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="1"
                            Stroke="{StaticResource Gray300}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectRestaurantCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Label Text="&#x1F3E2;"
                                       FontSize="14"
                                       VerticalOptions="Center" />
                                <Label Text="{Binding SelectedRestaurantName}"
                                       FontSize="14"
                                       TextColor="{StaticResource Gray700}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Grid.Column="1"
                                   Text="&#x203A;"
                                   FontSize="18"
                                   TextColor="{StaticResource Gray400}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <!-- Branch picker - SuperAdmin and RestaurantOwner -->
                    <Border IsVisible="{Binding ShowBranchFilter}"
                            Padding="12,10"
                            BackgroundColor="White"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="1"
                            Stroke="{StaticResource Gray300}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectBranchCommand}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Label Text="&#x1F4CD;"
                                       FontSize="14"
                                       VerticalOptions="Center" />
                                <Label Text="{Binding SelectedBranchName}"
                                       FontSize="14"
                                       TextColor="{StaticResource Gray700}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <Label Grid.Column="1"
                                   Text="&#x203A;"
                                   FontSize="18"
                                   TextColor="{StaticResource Gray400}"
                                   VerticalOptions="Center" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>
            </Border>

            <!-- ==================== DATE / FILTER CARD ==================== -->
            <Border Margin="16,12,16,0"
                    Padding="16"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 14"
                    StrokeThickness="1"
                    Stroke="{StaticResource Gray200}">
                <VerticalStackLayout Spacing="12">

                    <!-- Toggle row -->
                    <Grid ColumnDefinitions="*,Auto">
                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                            <Label Text="&#x1F4C5;"
                                   FontSize="16"
                                   VerticalOptions="Center" />
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                <Label Text="{h:Translate ShowTodayOnly}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="15"
                                       TextColor="{StaticResource Gray900}" />
                                <Label Text="{Binding TodayDisplay}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray500}"
                                       IsVisible="{Binding ShowTodayOnly}" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                        <Switch Grid.Column="1"
                                IsToggled="{Binding ShowTodayOnly, Mode=TwoWay}"
                                OnColor="{StaticResource Primary}"
                                VerticalOptions="Center" />
                    </Grid>

                    <!-- Date pickers - only shown when ShowTodayOnly is off -->
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="12"
                          IsVisible="{Binding ShowDatePickers}">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{h:Translate StartDate}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray500}" />
                            <Border Padding="10,6"
                                    BackgroundColor="White"
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource Gray300}">
                                <DatePicker Date="{Binding StartDate, Mode=TwoWay}"
                                            FontSize="14"
                                            TextColor="{StaticResource Gray900}" />
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="4">
                            <Label Text="{h:Translate EndDate}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray500}" />
                            <Border Padding="10,6"
                                    BackgroundColor="White"
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource Gray300}">
                                <DatePicker Date="{Binding EndDate, Mode=TwoWay}"
                                            FontSize="14"
                                            TextColor="{StaticResource Gray900}" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Load Report button -->
                    <Button Text="{h:Translate LoadReport}"
                            Command="{Binding LoadReportCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="10"
                            Padding="0,14"
                            FontFamily="OpenSansSemibold"
                            FontSize="15" />

                </VerticalStackLayout>
            </Border>

            <!-- ==================== LOADING INDICATOR ==================== -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               Margin="0,20,0,0" />

            <!-- ==================== DATA SECTION ==================== -->
            <VerticalStackLayout Spacing="12"
                                 Padding="16,12,16,24"
                                 IsVisible="{Binding HasData}">

                <!-- Total Revenue card -->
                <Border Padding="16"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="1"
                        Stroke="{StaticResource Gray200}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ViewOrderBreakdownCommand}" />
                    </Border.GestureRecognizers>
                    <VerticalStackLayout Spacing="8">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{h:Translate TotalRevenue}"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray500}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding SalesSummary.PreviousPeriod.RevenueChangeDisplay}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="13"
                                   TextColor="{Binding SalesSummary.PreviousPeriod.RevenueChangeColor}"
                                   VerticalOptions="Center" />
                        </Grid>
                        <Label Text="{Binding SalesSummary.TotalRevenueDisplay}"
                               FontFamily="OpenSansSemibold"
                               FontSize="32"
                               TextColor="{StaticResource Gray900}" />
                        <Label Text="{h:Translate VsPreviousPeriod}"
                               FontSize="12"
                               TextColor="{StaticResource Gray400}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Total Orders + Avg Order value (2 columns) -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                    <Border Padding="14"
                            BackgroundColor="White"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="1"
                            Stroke="{StaticResource Gray200}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{h:Translate TotalOrders}"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray500}" />
                            <Label Text="{Binding SalesSummary.TotalOrders}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="28"
                                   TextColor="{StaticResource Gray900}" />
                            <Label Text="{Binding SalesSummary.PreviousPeriod.OrdersChangeDisplay}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="13"
                                   TextColor="{Binding SalesSummary.PreviousPeriod.OrdersChangeColor}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="14"
                            BackgroundColor="White"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="1"
                            Stroke="{StaticResource Gray200}">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{h:Translate AvgOrder}"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray500}" />
                            <Label Text="{Binding SalesSummary.AverageOrderValueDisplay}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="22"
                                   TextColor="{StaticResource Gray900}" />
                            <Label Text="{Binding SalesSummary.PreviousPeriod.AovChangeDisplay}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="13"
                                   TextColor="{Binding SalesSummary.PreviousPeriod.AovChangeColor}" />
                        </VerticalStackLayout>
                    </Border>

                </Grid>

                <!-- Completion Rate card -->
                <Border Padding="16"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="1"
                        Stroke="{StaticResource Gray200}">
                    <VerticalStackLayout Spacing="10">

                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{h:Translate CompletionRate}"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray500}"
                                   VerticalOptions="Center" />
                            <Label Grid.Column="1"
                                   Text="{Binding SalesSummary.CompletionRateDisplay}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="17"
                                   TextColor="{StaticResource Gray900}"
                                   VerticalOptions="Center" />
                        </Grid>

                        <ProgressBar Progress="{Binding SalesSummary.CompletionRateProgress}"
                                     ProgressColor="{StaticResource Primary}"
                                     HeightRequest="8" />

                        <!-- Completed / Cancelled / In-Progress stats (3 columns) -->
                        <Grid ColumnDefinitions="*,*,*">

                            <HorizontalStackLayout HorizontalOptions="Center"
                                                   Spacing="6"
                                                   VerticalOptions="Center">
                                <Ellipse Fill="#27AE60"
                                         WidthRequest="8"
                                         HeightRequest="8"
                                         VerticalOptions="Center" />
                                <Label FontSize="12"
                                       TextColor="{StaticResource Gray500}"
                                       VerticalOptions="Center">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding SalesSummary.CompletedOrders}" />
                                            <Span Text=" " />
                                            <Span Text="{h:Translate Completed}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Grid.Column="1"
                                                   HorizontalOptions="Center"
                                                   Spacing="6"
                                                   VerticalOptions="Center">
                                <Ellipse Fill="{StaticResource Gray400}"
                                         WidthRequest="8"
                                         HeightRequest="8"
                                         VerticalOptions="Center" />
                                <Label FontSize="12"
                                       TextColor="{StaticResource Gray500}"
                                       VerticalOptions="Center">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding SalesSummary.CancelledOrders}" />
                                            <Span Text=" " />
                                            <Span Text="{h:Translate Cancelled}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Grid.Column="2"
                                                   HorizontalOptions="Center"
                                                   Spacing="6"
                                                   VerticalOptions="Center">
                                <Ellipse Fill="{StaticResource Primary}"
                                         WidthRequest="8"
                                         HeightRequest="8"
                                         VerticalOptions="Center" />
                                <Label FontSize="12"
                                       TextColor="{StaticResource Gray500}"
                                       VerticalOptions="Center">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding SalesSummary.InProgressOrders}" />
                                            <Span Text=" " />
                                            <Span Text="{h:Translate InProgress}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </HorizontalStackLayout>

                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Performance Insight card -->
                <Border Padding="16"
                        BackgroundColor="#FFF5F5"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="1"
                        Stroke="#FFE0E0">
                    <HorizontalStackLayout Spacing="12" VerticalOptions="Start">
                        <Label Text="{Binding InsightIcon}"
                               FontSize="24"
                               VerticalOptions="Start" />
                        <VerticalStackLayout Spacing="4" HorizontalOptions="FillAndExpand">
                            <Label Text="{h:Translate PerformanceInsight}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="14"
                                   TextColor="{StaticResource Gray900}" />
                            <Label Text="{Binding PerformanceInsight}"
                                   FontSize="13"
                                   TextColor="{StaticResource Gray600}"
                                   LineBreakMode="WordWrap" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Border>

                <!-- ── TOP SELLING PRODUCTS ── -->
                <Border Padding="16"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="1"
                        Stroke="{StaticResource Gray200}"
                        IsVisible="{Binding HasTopProductsData}">
                    <VerticalStackLayout Spacing="0">

                        <Label Text="{h:Translate TopSellingProducts}"
                               FontSize="11"
                               TextColor="{StaticResource Gray500}"
                               CharacterSpacing="1.5"
                               Margin="0,0,0,12" />

                        <VerticalStackLayout Spacing="0"
                                             BindableLayout.ItemsSource="{Binding VisibleTopProducts}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:TopSellingItem">
                                    <VerticalStackLayout Spacing="6" Padding="0,8,0,8">

                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                                            <!-- Rank badge -->
                                            <Border Padding="6,4"
                                                    BackgroundColor="{StaticResource Primary}"
                                                    StrokeShape="RoundRectangle 6"
                                                    StrokeThickness="0"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding RankDisplay}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="12"
                                                       TextColor="White"
                                                       VerticalOptions="Center" />
                                            </Border>

                                            <!-- Name + category -->
                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="2"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding MenuItemName}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="14"
                                                       TextColor="{StaticResource Gray900}"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding CategoryName}"
                                                       FontSize="12"
                                                       TextColor="{StaticResource Gray500}" />
                                            </VerticalStackLayout>

                                            <!-- Revenue + qty + percent -->
                                            <VerticalStackLayout Grid.Column="2"
                                                                 Spacing="2"
                                                                 HorizontalOptions="End"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding RevenueDisplay}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="14"
                                                       TextColor="{StaticResource Gray900}"
                                                       HorizontalOptions="End" />
                                                <Label FontSize="12"
                                                       TextColor="{StaticResource Gray500}"
                                                       HorizontalOptions="End">
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="{Binding QuantityDisplay}" />
                                                            <Span Text=" · " />
                                                            <Span Text="{Binding PercentDisplay}" />
                                                        </FormattedString>
                                                    </Label.FormattedText>
                                                </Label>
                                            </VerticalStackLayout>

                                        </Grid>

                                        <!-- Percent progress bar -->
                                        <ProgressBar Progress="{Binding PercentProgress}"
                                                     ProgressColor="{StaticResource Primary}"
                                                     HeightRequest="4" />

                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- Show More button -->
                        <Button Text="{h:Translate ShowMore}"
                                Command="{Binding ShowMoreTopProductsCommand}"
                                IsVisible="{Binding CanShowMoreTopProducts}"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource Primary}"
                                FontFamily="OpenSansSemibold"
                                FontSize="14"
                                Padding="0,12,0,4"
                                BorderWidth="0" />

                    </VerticalStackLayout>
                </Border>

                <!-- ── SALES TRENDS ── -->
                <Border Padding="16"
                        BackgroundColor="White"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="1"
                        Stroke="{StaticResource Gray200}"
                        IsVisible="{Binding HasSalesTrendsData}">
                    <VerticalStackLayout Spacing="0">

                        <!-- Section header -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,12">
                            <Label Text="{h:Translate SalesTrends}"
                                   FontSize="11"
                                   TextColor="{StaticResource Gray500}"
                                   CharacterSpacing="1.5"
                                   VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="1"
                                                 HorizontalOptions="End">
                                <Label Text="{Binding TrendPercentDisplay}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13"
                                       TextColor="{Binding TrendPercentColor}"
                                       HorizontalOptions="End" />
                                <Label Text="{Binding TrendAverageDisplay}"
                                       FontSize="11"
                                       TextColor="{StaticResource Gray500}"
                                       HorizontalOptions="End" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Data point rows -->
                        <VerticalStackLayout Spacing="0"
                                             BindableLayout.ItemsSource="{Binding VisibleSalesTrends}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:SalesTrendDataPoint">
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="12"
                                          Padding="0,8,0,8">

                                        <!-- Date label -->
                                        <Border Padding="8,4"
                                                BackgroundColor="{StaticResource Gray100}"
                                                StrokeShape="RoundRectangle 6"
                                                StrokeThickness="0"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding Label}"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="12"
                                                   TextColor="{StaticResource Gray700}"
                                                   VerticalOptions="Center" />
                                        </Border>

                                        <!-- Orders + avg -->
                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="2"
                                                             VerticalOptions="Center">
                                            <Label Text="{Binding OrdersDisplay}"
                                                   FontSize="13"
                                                   TextColor="{StaticResource Gray500}" />
                                            <Label Text="{Binding AverageOrderValueDisplay}"
                                                   FontSize="11"
                                                   TextColor="{StaticResource Gray400}" />
                                        </VerticalStackLayout>

                                        <!-- Revenue -->
                                        <Label Grid.Column="2"
                                               Text="{Binding RevenueDisplay}"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="14"
                                               TextColor="{StaticResource Gray900}"
                                               VerticalOptions="Center" />

                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- Show More button -->
                        <Button Text="{h:Translate ShowMore}"
                                Command="{Binding ShowMoreSalesTrendsCommand}"
                                IsVisible="{Binding CanShowMoreSalesTrends}"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource Primary}"
                                FontFamily="OpenSansSemibold"
                                FontSize="14"
                                Padding="0,12,0,4"
                                BorderWidth="0" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

            <!-- ==================== NOT AUTHORIZED NOTICE ==================== -->
            <VerticalStackLayout IsVisible="{Binding IsAuthorized, Converter={StaticResource InvertedBoolConverter}}"
                                 HorizontalOptions="Center"
                                 Spacing="16"
                                 Padding="32,60,32,32">
                <Label Text="&#x26D4;"
                       FontSize="48"
                       HorizontalOptions="Center" />
                <Label Text="{h:Translate NotAuthorized}"
                       FontFamily="OpenSansSemibold"
                       FontSize="16"
                       TextColor="{StaticResource Gray700}"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap" />
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
