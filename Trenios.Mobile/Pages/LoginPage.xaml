<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Trenios.Mobile.ViewModels"
             xmlns:h="clr-namespace:Trenios.Mobile.Helpers"
             x:Class="Trenios.Mobile.Pages.LoginPage"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource White}">

    <Grid>
        <!-- Main content — VerticalOptions="Center" centers within the Grid -->
        <VerticalStackLayout VerticalOptions="Center"
                             HorizontalOptions="Fill"
                             MaximumWidthRequest="480"
                             Padding="32,0"
                             Spacing="0">

                    <!-- Logo -->
                    <Image Source="trenios_logo_red.png"
                           HeightRequest="56"
                           HorizontalOptions="Center"
                           Margin="0,0,0,52"/>

                    <!-- Username -->
                    <Label Text="{h:Translate Username}"
                           FontFamily="OpenSansSemibold"
                           FontSize="14"
                           TextColor="{StaticResource Gray800}"
                           Margin="0,0,0,8"/>
                    <Border StrokeShape="RoundRectangle 14"
                            StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            BackgroundColor="{StaticResource White}"
                            Padding="16,0"
                            Margin="0,0,0,20">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding HasError}" Value="True">
                                <Setter Property="Stroke" Value="#FECACA"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Entry Text="{Binding Username}"
                               Placeholder="{h:Translate EnterUsername}"
                               BackgroundColor="Transparent"
                               HeightRequest="52"/>
                    </Border>

                    <!-- Password -->
                    <Label Text="{h:Translate Password}"
                           FontFamily="OpenSansSemibold"
                           FontSize="14"
                           TextColor="{StaticResource Gray800}"
                           Margin="0,0,0,8"/>
                    <Border StrokeShape="RoundRectangle 14"
                            StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            BackgroundColor="{StaticResource White}"
                            Padding="16,0"
                            Margin="0,0,0,4">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding HasError}" Value="True">
                                <Setter Property="Stroke" Value="#FECACA"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Entry Text="{Binding Password}"
                               Placeholder="{h:Translate EnterPassword}"
                               BackgroundColor="Transparent"
                               IsPassword="True"
                               HeightRequest="52"/>
                    </Border>

                    <!-- Error banner -->
                    <Border IsVisible="{Binding HasError}"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1"
                            Stroke="#FECACA"
                            BackgroundColor="#FEF2F2"
                            Padding="14,12"
                            Margin="0,16,0,0">
                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                            <Label Text="&#x26A0;"
                                   TextColor="{StaticResource Primary}"
                                   FontSize="16"
                                   VerticalOptions="Center"/>
                            <Label Text="{Binding ErrorMessage}"
                                   TextColor="#B91C1C"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="13"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Fill"/>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Login button -->
                    <Button Text="{h:Translate Login}"
                            Command="{Binding LoginCommand}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}"
                            FontFamily="OpenSansSemibold"
                            FontSize="17"
                            CornerRadius="14"
                            HeightRequest="56"
                            Margin="0,16,0,0"/>

                    <!-- Activity indicator -->
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       HorizontalOptions="Center"
                                       Margin="0,12,0,0"/>

                    <!-- Language selector -->
                    <Border x:Name="LanguageDropdown"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1"
                            Stroke="{StaticResource Gray200}"
                            BackgroundColor="{StaticResource White}"
                            HeightRequest="44"
                            Margin="0,16,0,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLanguageTapped"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="6"
                                              HorizontalOptions="Center"
                                              VerticalOptions="Center">
                            <Label x:Name="CurrentLanguageLabel"
                                   Text="English"
                                   FontSize="14"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource Gray500}"
                                   VerticalOptions="Center"/>
                            <Label Text="▼"
                                   FontSize="9"
                                   TextColor="{StaticResource Gray400}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>

        </VerticalStackLayout>

        <!-- Language selection popup -->
        <Grid x:Name="LanguagePopup"
              IsVisible="False"
              BackgroundColor="#80000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseLanguagePopup"/>
            </Grid.GestureRecognizers>

            <Border VerticalOptions="Center"
                    HorizontalOptions="Center"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="0"
                    BackgroundColor="{StaticResource White}"
                    Padding="0"
                    WidthRequest="300">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer/>
                </Border.GestureRecognizers>

                <VerticalStackLayout Spacing="0">
                    <Label Text="{h:Translate Language}"
                           FontFamily="OpenSansSemibold"
                           FontSize="20"
                           Padding="20,16"
                           BackgroundColor="{StaticResource Primary}"
                           TextColor="White"/>

                    <VerticalStackLayout Padding="8">
                        <Button Text="English"
                                Style="{StaticResource GhostButton}"
                                HorizontalOptions="Fill"
                                Clicked="OnLanguageSelected"
                                AutomationId="en"/>
                        <Button Text="Azərbaycan"
                                Style="{StaticResource GhostButton}"
                                HorizontalOptions="Fill"
                                Clicked="OnLanguageSelected"
                                AutomationId="az"/>
                        <Button Text="Русский"
                                Style="{StaticResource GhostButton}"
                                HorizontalOptions="Fill"
                                Clicked="OnLanguageSelected"
                                AutomationId="ru"/>
                        <Button Text="Türkçe"
                                Style="{StaticResource GhostButton}"
                                HorizontalOptions="Fill"
                                Clicked="OnLanguageSelected"
                                AutomationId="tr"/>
                        <Button Text="Latviešu"
                                Style="{StaticResource GhostButton}"
                                HorizontalOptions="Fill"
                                Clicked="OnLanguageSelected"
                                AutomationId="lv"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>

</ContentPage>
