<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Trenios.Mobile.ViewModels"
             xmlns:api="clr-namespace:Trenios.Mobile.Models.Api"
             xmlns:services="clr-namespace:Trenios.Mobile.Services"
             xmlns:h="clr-namespace:Trenios.Mobile.Helpers"
             x:Class="Trenios.Mobile.Pages.AddToOrderPage"
             x:DataType="vm:AddToOrderViewModel"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <DataTemplate x:Key="MenuItemTemplate" x:DataType="api:BranchMenuItemDto">
                <Border StrokeShape="RoundRectangle 12"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                        Padding="0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.SelectMenuItemCommand}"
                                              CommandParameter="{Binding .}"/>
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="120,Auto">
                        <Grid Grid.Row="0" BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}">
                            <Image Source="{Binding PrimaryImageUrl}" Aspect="AspectFill" IsVisible="{Binding HasImage}"/>
                            <Label Text="{Binding MenuItemName, Converter={StaticResource FirstLetterConverter}}"
                                   FontSize="40" FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource Gray300}"
                                   HorizontalOptions="Center" VerticalOptions="Center"
                                   IsVisible="{Binding HasImage, Converter={StaticResource InvertedBoolConverter}}"/>
                        </Grid>
                        <VerticalStackLayout Grid.Row="1" Padding="10,8" Spacing="2">
                            <Label Text="{Binding MenuItemName}"
                                   FontFamily="OpenSansSemibold" FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                   LineBreakMode="TailTruncation" MaxLines="2"/>
                            <Label Text="{Binding PriceDisplay}"
                                   FontFamily="OpenSansSemibold" FontSize="14"
                                   TextColor="{StaticResource Primary}" Margin="0,2,0,0"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </DataTemplate>

            <DataTemplate x:Key="CartItemTemplate" x:DataType="services:CartItem">
                <Border Style="{StaticResource OrderItemCard}" Margin="0,0,0,8">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <Label Grid.Row="0" Grid.Column="0"
                               Text="{Binding MenuItemName}"
                               FontFamily="OpenSansSemibold" FontSize="14"
                               LineBreakMode="TailTruncation"/>
                        <Label Grid.Row="0" Grid.Column="1"
                               Text="{Binding TotalPriceDisplay}"
                               Style="{StaticResource Price}" FontSize="14"
                               HorizontalTextAlignment="End"/>
                        <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                               Spacing="12" Margin="0,8,0,0">
                            <Button Text="-" Style="{StaticResource QuantityButton}"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.DecreaseQuantityCommand}"
                                    CommandParameter="{Binding .}"/>
                            <Label Text="{Binding Quantity}" VerticalOptions="Center"
                                   FontFamily="OpenSansSemibold" FontSize="16"
                                   WidthRequest="30" HorizontalTextAlignment="Center"/>
                            <Button Text="+" Style="{StaticResource QuantityButton}"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.IncreaseQuantityCommand}"
                                    CommandParameter="{Binding .}"/>
                            <Button Text="{h:Translate Remove}" Style="{StaticResource GhostButton}"
                                    TextColor="{StaticResource Danger}"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.RemoveItemCommand}"
                                    CommandParameter="{Binding .}"
                                    HorizontalOptions="EndAndExpand"/>
                        </HorizontalStackLayout>
                    </Grid>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ==================== HEADER + CATEGORIES ==================== -->
        <VerticalStackLayout Grid.Row="0" Spacing="0"
                             BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">

            <!-- Back + title -->
            <Grid Padding="8,12" HeightRequest="64" ColumnDefinitions="Auto,*" ColumnSpacing="0">
                <Border Padding="10,8" StrokeShape="RoundRectangle 8" StrokeThickness="0"
                        BackgroundColor="Transparent" VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="4">
                        <Label Text="←" FontSize="18"
                               TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                               VerticalOptions="Center"/>
                        <Label Text="{h:Translate Back}" FontSize="14"
                               TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding CloseCommand}"/>
                    </Border.GestureRecognizers>
                </Border>
                <Label Grid.Column="1" VerticalOptions="Center" Margin="4,0,16,0">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{h:Translate AddNewMenu}"
                                  FontFamily="OpenSansSemibold" FontSize="17"
                                  TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                            <Span Text=" · " FontSize="15" TextColor="{StaticResource Gray400}"/>
                            <Span Text="{Binding OrderNumber}" FontSize="15"
                                  TextColor="{StaticResource Primary}"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Grid>

            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>

            <!-- Search -->
            <Border Margin="12,10,12,8" Padding="14,0"
                    StrokeShape="RoundRectangle 12" StrokeThickness="1"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                    HeightRequest="46">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <Label Text="🔍" FontSize="15" TextColor="{StaticResource Gray400}" VerticalOptions="Center"/>
                    <Entry Grid.Column="1"
                           Text="{Binding SearchText, Mode=TwoWay}"
                           Placeholder="{h:Translate SearchMenuItems}"
                           BackgroundColor="Transparent"
                           HeightRequest="46"
                           IsTextPredictionEnabled="False"/>
                </Grid>
            </Border>

            <!-- Category pills -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never"
                        Padding="12,0,12,10" HeightRequest="50">
                <HorizontalStackLayout Spacing="8">
                    <Border StrokeShape="RoundRectangle 20" StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray800}}"
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                            Padding="16,0" HeightRequest="36" VerticalOptions="Center">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsAllSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                                <Setter Property="Stroke" Value="{StaticResource Primary}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectAllCategoriesCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="{h:Translate All}" FontFamily="OpenSansSemibold" FontSize="13"
                               VerticalOptions="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsAllSelected}" Value="True">
                                    <Setter Property="TextColor" Value="White"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>

                    <HorizontalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding Categories}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:SelectableCategory">
                                <Border StrokeShape="RoundRectangle 20" StrokeThickness="1"
                                        BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray800}}"
                                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                                        Padding="16,0" HeightRequest="36" VerticalOptions="Center">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource Primary}"/>
                                            <Setter Property="Stroke" Value="{StaticResource Primary}"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.SelectCategoryCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <Label Text="{Binding Name}" FontFamily="OpenSansSemibold" FontSize="13"
                                           VerticalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="TextColor" Value="White"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </HorizontalStackLayout>
            </ScrollView>

            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>
        </VerticalStackLayout>

        <!-- ==================== PRODUCTS GRID / CART VIEW ==================== -->
        <Grid Grid.Row="1">

            <!-- Products grid (shown when cart is not open) -->
            <Grid x:Name="ProductsView" IsVisible="True">
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="{StaticResource Primary}"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>

                <CollectionView x:Name="MenuCollectionView"
                                ItemsSource="{Binding FilteredMenuItems}"
                                ItemTemplate="{StaticResource MenuItemTemplate}"
                                IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                                BackgroundColor="Transparent"
                                Margin="8,8">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2"
                                         HorizontalItemSpacing="8" VerticalItemSpacing="8"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                             Spacing="8" Margin="0,60,0,0">
                            <Label Text="🍽️" FontSize="40" HorizontalOptions="Center"/>
                            <Label Text="{h:Translate NoItemsInCategory}"
                                   FontSize="15" TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>
            </Grid>

            <!-- Cart view (shown when user taps the bottom bar) -->
            <Grid x:Name="CartView" IsVisible="False"
                  RowDefinitions="Auto,*,Auto"
                  BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">

                <!-- Cart header -->
                <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="Auto,*,Auto">
                    <Border Padding="10,8" StrokeShape="RoundRectangle 8" StrokeThickness="0"
                            BackgroundColor="Transparent">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="←" FontSize="16"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                   VerticalOptions="Center"/>
                            <Label Text="{h:Translate Back}" FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackToProducts"/>
                        </Border.GestureRecognizers>
                    </Border>
                    <Label Grid.Column="1" Text="{h:Translate CurrentOrder}"
                           FontFamily="OpenSansSemibold" FontSize="17"
                           HorizontalOptions="Center" VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                    <Label Grid.Column="2"
                           Text="{Binding TotalItems, StringFormat='{0} items'}"
                           FontSize="13" TextColor="{StaticResource Gray500}"
                           VerticalOptions="Center"/>
                </Grid>
                <BoxView Grid.Row="0" HeightRequest="1"
                         Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                         VerticalOptions="End"/>

                <!-- Cart items — BindableLayout avoids UICollectionView zero-frame crash on iOS -->
                <ScrollView Grid.Row="1" Margin="12,8">
                    <VerticalStackLayout Spacing="0">
                        <VerticalStackLayout IsVisible="{Binding HasItems, Converter={StaticResource InvertedBoolConverter}}"
                                             HorizontalOptions="Center" Spacing="8" Margin="0,40,0,0">
                            <Label Text="{h:Translate CartIsEmpty}"
                                   FontSize="15" TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding CartItems}"
                                             BindableLayout.ItemTemplate="{StaticResource CartItemTemplate}"
                                             IsVisible="{Binding HasItems}"/>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- Totals -->
                <Grid Grid.Row="2" Padding="16,12" ColumnDefinitions="*,Auto"
                      BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource Gray700}}">
                    <Label Text="{h:Translate Total}"
                           FontFamily="OpenSansSemibold" FontSize="16"
                           VerticalOptions="Center"
                           TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                    <Label Grid.Column="1"
                           Text="{Binding SubtotalDisplay}"
                           FontFamily="OpenSansSemibold" FontSize="18"
                           TextColor="{StaticResource Primary}" VerticalOptions="Center"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- ==================== BOTTOM BAR ==================== -->
        <!-- Products view: shown when HasItems — tap to open cart -->
        <Border Grid.Row="2"
                Margin="12,10,12,12"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="0"
                BackgroundColor="{StaticResource Primary}"
                IsVisible="{Binding HasItems}"
                x:Name="BottomBar">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnBottomBarTapped"/>
            </Border.GestureRecognizers>
            <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                <Border Padding="8,4" StrokeShape="RoundRectangle 8" StrokeThickness="0"
                        BackgroundColor="#33FFFFFF" VerticalOptions="Center">
                    <Label Text="{Binding TotalItems}"
                           FontFamily="OpenSansSemibold" FontSize="13" TextColor="White"/>
                </Border>
                <Label Grid.Column="1" Text="{h:Translate AddNewMenu}"
                       FontFamily="OpenSansSemibold" FontSize="15"
                       TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                <Label Grid.Column="2" Text="{Binding SubtotalDisplay}"
                       FontFamily="OpenSansSemibold" FontSize="15"
                       TextColor="White" VerticalOptions="Center"/>
            </Grid>
        </Border>

        <!-- Cart view: submit button shown inside cart -->
        <Border Grid.Row="2"
                Margin="12,10,12,12"
                StrokeShape="RoundRectangle 14"
                StrokeThickness="0"
                BackgroundColor="{StaticResource Primary}"
                x:Name="SubmitBar"
                IsVisible="False">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding SubmitCommand}"/>
            </Border.GestureRecognizers>
            <Border.Triggers>
                <DataTrigger TargetType="Border" Binding="{Binding CanSubmit}" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </DataTrigger>
            </Border.Triggers>
            <Label Text="{h:Translate AddNewMenu}"
                   FontFamily="OpenSansSemibold" FontSize="16"
                   TextColor="White" HorizontalOptions="Center" Margin="0,14"/>
        </Border>

        <!-- ==================== CUSTOMIZATION OVERLAY ==================== -->
        <Grid Grid.Row="0" Grid.RowSpan="3"
              IsVisible="{Binding ShowCustomization}"
              BackgroundColor="#80000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CancelCustomizationCommand}"/>
            </Grid.GestureRecognizers>

            <Border VerticalOptions="Center"
                    HorizontalOptions="Fill"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                    MaximumHeightRequest="580"
                    Margin="12"
                    Padding="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer/>
                </Border.GestureRecognizers>

                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <!-- Header -->
                    <Grid Grid.Row="0" Padding="16,12" ColumnDefinitions="*,Auto"
                          BackgroundColor="{StaticResource Primary}">
                        <Label Text="{Binding SelectedMenuItem.MenuItemName}"
                               TextColor="White" FontFamily="OpenSansSemibold" FontSize="16"
                               LineBreakMode="TailTruncation" VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="{Binding SelectedMenuItem.PriceDisplay}"
                               TextColor="White" FontFamily="OpenSansSemibold" FontSize="16"
                               VerticalOptions="Center" Margin="8,0,0,0"/>
                    </Grid>

                    <!-- Quantity Row -->
                    <Grid Grid.Row="1" Padding="16,10" ColumnDefinitions="Auto,*,Auto"
                          BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource Gray800}}">
                        <Label Text="{h:Translate Quantity}"
                               FontFamily="OpenSansSemibold" FontSize="15" VerticalOptions="Center"/>
                        <HorizontalStackLayout Grid.Column="2" Spacing="12">
                            <Button Text="-" Style="{StaticResource QuantityButton}"
                                    Command="{Binding DecreaseCustomizationQuantityCommand}"
                                    WidthRequest="36" HeightRequest="36" FontSize="18"/>
                            <Label Text="{Binding CustomizationQuantity}"
                                   FontFamily="OpenSansSemibold" FontSize="18"
                                   VerticalOptions="Center" HorizontalTextAlignment="Center"
                                   WidthRequest="36"/>
                            <Button Text="+" Style="{StaticResource QuantityButton}"
                                    Command="{Binding IncreaseCustomizationQuantityCommand}"
                                    WidthRequest="36" HeightRequest="36" FontSize="18"/>
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- Addition Groups -->
                    <ScrollView Grid.Row="2">
                        <VerticalStackLayout Spacing="0">
                            <ActivityIndicator IsRunning="{Binding IsLoadingAdditions}"
                                               IsVisible="{Binding IsLoadingAdditions}"
                                               Color="{StaticResource Primary}"
                                               HorizontalOptions="Center"
                                               HeightRequest="80"/>

                            <VerticalStackLayout IsVisible="{Binding IsLoadingAdditions, Converter={StaticResource InvertedBoolConverter}}"
                                                 BindableLayout.ItemsSource="{Binding SelectableAdditionGroups}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SelectableAdditionGroup">
                                        <VerticalStackLayout Spacing="8" Padding="14,10">
                                            <!-- Group Header -->
                                            <HorizontalStackLayout Spacing="8">
                                                <Label Text="{Binding Name}" FontFamily="OpenSansSemibold" FontSize="17"/>
                                                <Label Text="{Binding SelectionHint}" Style="{StaticResource Caption}"
                                                       FontSize="14" VerticalOptions="Center"/>
                                                <Label Text="*" TextColor="{StaticResource Danger}" FontSize="16"
                                                       IsVisible="{Binding IsRequired}" VerticalOptions="Center"/>
                                            </HorizontalStackLayout>

                                            <!-- Single Select (Radio) -->
                                            <VerticalStackLayout Spacing="4" IsVisible="{Binding IsSingleSelect}"
                                                                 BindableLayout.ItemsSource="{Binding Additions}">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:SelectableAddition">
                                                        <Border Padding="12,10" Margin="0,0,0,4"
                                                                StrokeShape="RoundRectangle 8" StrokeThickness="1"
                                                                Stroke="{Binding StrokeColor}"
                                                                BackgroundColor="{Binding BackgroundColor}">
                                                            <Border.GestureRecognizers>
                                                                <TapGestureRecognizer
                                                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleAdditionCommand}"
                                                                    CommandParameter="{Binding .}"/>
                                                            </Border.GestureRecognizers>
                                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                                <Ellipse WidthRequest="20" HeightRequest="20"
                                                                         Fill="{Binding CheckboxBackgroundColor}"
                                                                         Stroke="{Binding StrokeColor}"
                                                                         StrokeThickness="2" VerticalOptions="Center"/>
                                                                <Label Grid.Column="0" Text="✓" FontSize="11"
                                                                       TextColor="White" HorizontalOptions="Center"
                                                                       VerticalOptions="Center"
                                                                       IsVisible="{Binding IsSelected}"
                                                                       InputTransparent="True"/>
                                                                <Label Grid.Column="1" Text="{Binding Name}"
                                                                       FontSize="15" VerticalOptions="Center"/>
                                                                <Label Grid.Column="2" Text="{Binding UnitPricePlusDisplay}"
                                                                       FontSize="13" TextColor="{StaticResource Primary}"
                                                                       VerticalOptions="Center" IsVisible="{Binding HasPrice}"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>

                                            <!-- Multi Select (Checkbox) -->
                                            <VerticalStackLayout Spacing="4" IsVisible="{Binding IsMultiSelect}"
                                                                 BindableLayout.ItemsSource="{Binding Additions}">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:SelectableAddition">
                                                        <Border Padding="12,10" Margin="0,0,0,4"
                                                                StrokeShape="RoundRectangle 8" StrokeThickness="1"
                                                                Stroke="{Binding StrokeColor}"
                                                                BackgroundColor="{Binding BackgroundColor}"
                                                                Opacity="{Binding ItemOpacity}">
                                                            <Border.GestureRecognizers>
                                                                <TapGestureRecognizer
                                                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleAdditionCommand}"
                                                                    CommandParameter="{Binding .}"/>
                                                            </Border.GestureRecognizers>
                                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                                <RoundRectangle WidthRequest="20" HeightRequest="20"
                                                                                CornerRadius="4"
                                                                                Fill="{Binding CheckboxBackgroundColor}"
                                                                                Stroke="{Binding StrokeColor}"
                                                                                StrokeThickness="2" VerticalOptions="Center"/>
                                                                <Label Grid.Column="0" Text="✓" FontSize="11"
                                                                       TextColor="White" HorizontalOptions="Center"
                                                                       VerticalOptions="Center"
                                                                       IsVisible="{Binding IsSelected}"
                                                                       InputTransparent="True"/>
                                                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                                    <VerticalStackLayout.GestureRecognizers>
                                                                        <TapGestureRecognizer
                                                                            Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.ToggleAdditionCommand}"
                                                                            CommandParameter="{Binding .}"/>
                                                                    </VerticalStackLayout.GestureRecognizers>
                                                                    <HorizontalStackLayout Spacing="4">
                                                                        <Label Text="{Binding Quantity, StringFormat='{0}x '}"
                                                                               FontSize="15" FontFamily="OpenSansSemibold"
                                                                               TextColor="{StaticResource Primary}"
                                                                               IsVisible="{Binding IsSelected}"/>
                                                                        <Label Text="{Binding Name}" FontSize="15"/>
                                                                    </HorizontalStackLayout>
                                                                    <Label Text="{Binding UnitPriceDisplay, StringFormat='{0} each'}"
                                                                           FontSize="12" TextColor="{StaticResource Gray500}"
                                                                           IsVisible="{Binding HasPrice}"/>
                                                                </VerticalStackLayout>
                                                                <HorizontalStackLayout Grid.Column="2" Spacing="8"
                                                                                       IsVisible="{Binding IsSelected}"
                                                                                       VerticalOptions="Center">
                                                                    <Border WidthRequest="32" HeightRequest="32"
                                                                            StrokeShape="RoundRectangle 16"
                                                                            StrokeThickness="0"
                                                                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}">
                                                                        <Border.GestureRecognizers>
                                                                            <TapGestureRecognizer
                                                                                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.DecreaseAdditionQuantityCommand}"
                                                                                CommandParameter="{Binding .}"/>
                                                                        </Border.GestureRecognizers>
                                                                        <Label Text="-" FontSize="16" FontFamily="OpenSansSemibold"
                                                                               TextColor="{StaticResource Gray700}"
                                                                               HorizontalOptions="Center" VerticalOptions="Center"
                                                                               InputTransparent="True"/>
                                                                    </Border>
                                                                    <Label Text="{Binding Quantity}" FontSize="15"
                                                                           FontFamily="OpenSansSemibold" WidthRequest="24"
                                                                           HorizontalTextAlignment="Center" VerticalOptions="Center"/>
                                                                    <Border WidthRequest="32" HeightRequest="32"
                                                                            StrokeShape="RoundRectangle 16"
                                                                            StrokeThickness="0"
                                                                            BackgroundColor="{StaticResource Primary}">
                                                                        <Border.GestureRecognizers>
                                                                            <TapGestureRecognizer
                                                                                Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.IncreaseAdditionQuantityCommand}"
                                                                                CommandParameter="{Binding .}"/>
                                                                        </Border.GestureRecognizers>
                                                                        <Label Text="+" FontSize="16" FontFamily="OpenSansSemibold"
                                                                               TextColor="White"
                                                                               HorizontalOptions="Center" VerticalOptions="Center"
                                                                               InputTransparent="True"/>
                                                                    </Border>
                                                                    <Label Text="{Binding TotalPriceDisplay}" FontSize="14"
                                                                           FontFamily="OpenSansSemibold"
                                                                           TextColor="{StaticResource Primary}"
                                                                           WidthRequest="50" HorizontalTextAlignment="End"
                                                                           VerticalOptions="Center"
                                                                           IsVisible="{Binding HasPrice}"/>
                                                                </HorizontalStackLayout>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </ScrollView>

                    <!-- Footer -->
                    <Grid Grid.Row="3" RowDefinitions="Auto,Auto,Auto" Padding="14,10" RowSpacing="8"
                          BackgroundColor="{AppThemeBinding Light={StaticResource Gray50}, Dark={StaticResource Gray700}}">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <VerticalStackLayout>
                                <Label Text="{h:Translate ItemTotal}" Style="{StaticResource Caption}"/>
                                <Label Style="{StaticResource Caption}">
                                    <Label.Text>
                                        <MultiBinding StringFormat="{}{0} x {1}">
                                            <Binding Path="CustomizationItemPriceDisplay"/>
                                            <Binding Path="CustomizationQuantity"/>
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="{Binding CustomizationTotalPriceDisplay}"
                                   FontFamily="OpenSansSemibold" FontSize="20"
                                   TextColor="{StaticResource Primary}" VerticalOptions="Center"/>
                        </Grid>
                        <Label Grid.Row="1" Text="{Binding ValidationMessage}"
                               TextColor="{StaticResource Danger}" FontSize="13"
                               FontFamily="OpenSansSemibold" HorizontalOptions="Center"
                               IsVisible="{Binding HasValidationError}"/>
                        <Grid Grid.Row="2" ColumnDefinitions="*,2*" ColumnSpacing="12">
                            <Button Grid.Column="0" Text="{h:Translate Cancel}"
                                    Style="{StaticResource GhostButton}"
                                    Command="{Binding CancelCustomizationCommand}"/>
                            <Button Grid.Column="1" Text="{h:Translate AddNewMenu}"
                                    Style="{StaticResource PrimaryButton}"
                                    Command="{Binding ConfirmCustomizationCommand}"/>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
