<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Trenios.Mobile.ViewModels"
             xmlns:models="clr-namespace:Trenios.Mobile.Models.Api"
             xmlns:h="clr-namespace:Trenios.Mobile.Helpers"
             x:Class="Trenios.Mobile.Pages.ActivityBoardPage"
             x:DataType="vm:ActivityBoardViewModel"
             x:Name="ThisPage"
             Title="{h:Translate Activities}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- ==================== PAGE HEADER ==================== -->
        <VerticalStackLayout Grid.Row="0" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
            <Grid Padding="16,12" HeightRequest="64" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <Image Source="trenios_logo_red.png"
                       HeightRequest="36"
                       HorizontalOptions="Start"
                       VerticalOptions="Center"
                       Aspect="AspectFit"/>
                <Border Grid.Column="1"
                        x:Name="LanguageBorder"
                        Padding="12,6"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="1.5"
                        Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                        VerticalOptions="Center">
                    <Label x:Name="CurrentLanguageLabel"
                           Text="EN"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLanguageTapped"/>
                    </Border.GestureRecognizers>
                </Border>
                <Border Grid.Column="2"
                        Padding="12,8"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0"
                        BackgroundColor="{StaticResource Primary}"
                        VerticalOptions="Center">
                    <Label Text="&#x2794;"
                           FontSize="16"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>
            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>

            <!-- Restaurant · Branch row -->
            <Grid Padding="16,10" HeightRequest="52" ColumnDefinitions="Auto,*" BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                <Border WidthRequest="34" HeightRequest="34"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0"
                        BackgroundColor="{StaticResource Primary}"
                        VerticalOptions="Center"
                        IsVisible="{Binding HasRestaurantLogo, Converter={StaticResource InvertedBoolConverter}}">
                    <Label Text="{Binding RestaurantName, Converter={StaticResource FirstLetterConverter}}"
                           TextColor="White"
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
                <Image Source="{Binding RestaurantLogoUrl}"
                       WidthRequest="34" HeightRequest="34"
                       Aspect="AspectFill"
                       VerticalOptions="Center"
                       IsVisible="{Binding HasRestaurantLogo}">
                    <Image.Clip>
                        <RoundRectangleGeometry Rect="0,0,34,34" CornerRadius="8"/>
                    </Image.Clip>
                </Image>
                <Label Grid.Column="1" VerticalOptions="Center" Margin="10,0,0,0">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{Binding RestaurantName}"
                                  FontFamily="OpenSansSemibold"
                                  FontSize="14"
                                  TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                            <Span Text=" · " FontSize="14" TextColor="{StaticResource Gray400}"/>
                            <Span Text="{Binding BranchName}"
                                  FontSize="14"
                                  TextColor="{StaticResource Gray500}"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Grid>
            <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>
        </VerticalStackLayout>

        <!-- ==================== MAIN CONTENT ==================== -->
        <Grid Grid.Row="1">

            <!-- Loading indicator -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>

            <!-- Board content -->
            <RefreshView Command="{Binding RefreshCommand}"
                         IsRefreshing="{Binding IsRefreshing}"
                         IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">
                <ScrollView>
                    <VerticalStackLayout Padding="16" Spacing="20">

                        <!-- Empty state -->
                        <VerticalStackLayout IsVisible="{Binding HasGroups, Converter={StaticResource InvertedBoolConverter}}"
                                             HorizontalOptions="Center"
                                             VerticalOptions="Center"
                                             Spacing="8"
                                             Margin="0,60,0,0">
                            <Label Text="🎯"
                                   FontSize="48"
                                   HorizontalOptions="Center"/>
                            <Label Text="{h:Translate NoActivitiesFound}"
                                   FontSize="16"
                                   TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <!-- Groups (Bilardo, Bowling, etc.) -->
                        <VerticalStackLayout x:Name="GroupsContainer" Spacing="20"
                                             BindableLayout.ItemsSource="{Binding BoardGroups}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:ActivityBoardGroupDto">
                                    <Border StrokeShape="RoundRectangle 12"
                                            StrokeThickness="1"
                                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}">
                                        <VerticalStackLayout>
                                            <!-- Group header -->
                                            <Label Text="{Binding ActivityTypeName}"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="15"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray200}}"
                                                   Padding="16,12"/>
                                            <BoxView HeightRequest="1"
                                                     Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"/>

                                            <!-- Activities list -->
                                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Activities}"
                                                                 Spacing="0">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="models:ActivityBoardItemDto">
                                                        <VerticalStackLayout>
                                                        <BoxView HeightRequest="1"
                                                                 Color="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}"/>
                                                        <Grid ColumnDefinitions="*,Auto" Padding="16,12" ColumnSpacing="12"
                                                              BackgroundColor="Transparent">
                                                            <!-- Left: name, status, elapsed -->
                                                            <VerticalStackLayout Spacing="4">
                                                                <Label Text="{Binding Name}"
                                                                       FontFamily="OpenSansSemibold"
                                                                       FontSize="15"
                                                                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"/>
                                                                <Label Text="{Binding UnitPriceDisplay}"
                                                                       FontSize="13"
                                                                       TextColor="{StaticResource Gray500}"/>

                                                                <!-- Status badge -->
                                                                <Border Padding="8,4"
                                                                        StrokeShape="RoundRectangle 6"
                                                                        StrokeThickness="0"
                                                                        BackgroundColor="{Binding StatusBackgroundColor}"
                                                                        HorizontalOptions="Start">
                                                                    <Label Text="{Binding StatusDisplay}"
                                                                           FontFamily="OpenSansSemibold"
                                                                           FontSize="11"
                                                                           TextColor="{Binding StatusColor}"/>
                                                                </Border>

                                                                <!-- Elapsed time + order number when active -->
                                                                <StackLayout Orientation="Horizontal" Spacing="8"
                                                                             IsVisible="{Binding IsOccupied}">
                                                                    <Label Text="{Binding ActiveSession.ElapsedDisplay}"
                                                                           FontSize="13"
                                                                           FontFamily="OpenSansSemibold"
                                                                           TextColor="{StaticResource Primary}"/>
                                                                    <Label Text="·" FontSize="13" TextColor="{StaticResource Gray400}"/>
                                                                    <Border Padding="0" StrokeThickness="0" BackgroundColor="Transparent">
                                                                        <Label Text="{Binding ActiveSession.OrderNumber}"
                                                                               FontSize="13"
                                                                               FontFamily="OpenSansSemibold"
                                                                               TextColor="{StaticResource Primary}"
                                                                               TextDecorations="Underline"/>
                                                                        <Border.GestureRecognizers>
                                                                            <TapGestureRecognizer
                                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActivityBoardViewModel}}, Path=GoToOrderCommand}"
                                                                                CommandParameter="{Binding}"/>
                                                                        </Border.GestureRecognizers>
                                                                    </Border>
                                                                </StackLayout>
                                                            </VerticalStackLayout>

                                                            <!-- Right: action buttons -->
                                                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">

                                                                <!-- Start button (shown when free) -->
                                                                <Border IsVisible="{Binding IsOccupied, Converter={StaticResource InvertedBoolConverter}}"
                                                                        Padding="12,8"
                                                                        StrokeShape="RoundRectangle 8"
                                                                        StrokeThickness="0"
                                                                        BackgroundColor="{StaticResource Primary}">
                                                                    <Label Text="{h:Translate Start}"
                                                                           FontFamily="OpenSansSemibold"
                                                                           FontSize="13"
                                                                           TextColor="White"
                                                                           HorizontalOptions="Center"/>
                                                                    <Border.GestureRecognizers>
                                                                        <TapGestureRecognizer
                                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActivityBoardViewModel}}, Path=StartSessionCommand}"
                                                                            CommandParameter="{Binding}"/>
                                                                    </Border.GestureRecognizers>
                                                                </Border>

                                                                <!-- Stop button hidden -->
                                                                <Border IsVisible="False"
                                                                        Padding="12,8"
                                                                        StrokeShape="RoundRectangle 8"
                                                                        StrokeThickness="0"
                                                                        BackgroundColor="{StaticResource Primary}">
                                                                    <Label Text="{h:Translate Stop}"
                                                                           FontFamily="OpenSansSemibold"
                                                                           FontSize="13"
                                                                           TextColor="White"
                                                                           HorizontalOptions="Center"/>
                                                                    <Border.GestureRecognizers>
                                                                        <TapGestureRecognizer
                                                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ActivityBoardViewModel}}, Path=StopSessionCommand}"
                                                                            CommandParameter="{Binding}"/>
                                                                    </Border.GestureRecognizers>
                                                                </Border>

                                                            </VerticalStackLayout>
                                                        </Grid>
                                                        </VerticalStackLayout>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>
            </RefreshView>
        </Grid>

    </Grid>

</ContentPage>
