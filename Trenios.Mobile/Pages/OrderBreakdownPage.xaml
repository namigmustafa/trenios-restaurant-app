<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Trenios.Mobile.ViewModels"
             xmlns:models="clr-namespace:Trenios.Mobile.Models.Api"
             xmlns:h="clr-namespace:Trenios.Mobile.Helpers"
             x:Class="Trenios.Mobile.Pages.OrderBreakdownPage"
             x:DataType="vm:OrderBreakdownViewModel"
             Shell.NavBarIsVisible="False">

    <ScrollView BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
        <VerticalStackLayout Spacing="0" Padding="0">

            <!-- ==================== PAGE HEADER ==================== -->
            <VerticalStackLayout BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}" Padding="0,0,0,0">
                <Grid Padding="16,12" HeightRequest="64" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                    <Image Source="trenios_logo_red.png"
                           HeightRequest="36"
                           HorizontalOptions="Start"
                           VerticalOptions="Center"
                           Aspect="AspectFit" />
                    <Border Grid.Column="1"
                            Padding="12,6"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="1.5"
                            Stroke="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                            VerticalOptions="Center">
                        <Label x:Name="LanguageLabel"
                               Text="EN"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLanguageTapped" />
                        </Border.GestureRecognizers>
                    </Border>
                    <Border Grid.Column="2"
                            Padding="12,8"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="0"
                            BackgroundColor="{StaticResource Primary}"
                            VerticalOptions="Center">
                        <Label Text="&#x2794;"
                               FontSize="16"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLogoutTapped" />
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>
                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}" />

                <!-- Back row -->
                <Grid BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}" Padding="8,6" ColumnDefinitions="Auto,*">
                    <Border Padding="10,8"
                            StrokeShape="RoundRectangle 8"
                            StrokeThickness="0"
                            BackgroundColor="Transparent">
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="←"
                                   FontSize="16"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                   VerticalOptions="Center" />
                            <Label Text="{h:Translate Back}"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding BackCommand}" />
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>
                <BoxView HeightRequest="1" Color="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}" />
            </VerticalStackLayout>

            <!-- ==================== LOADING INDICATOR ==================== -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Center"
                               Margin="0,20,0,0" />

            <!-- ==================== CONTENT ==================== -->
            <VerticalStackLayout Spacing="12"
                                 Padding="16,8,16,24"
                                 IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}">

                <!-- ── TOTAL REVENUE card ── -->
                <Border Padding="20"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}">
                    <VerticalStackLayout Spacing="10">

                        <Label Text="{h:Translate TotalRevenue}"
                               FontSize="11"
                               TextColor="{StaticResource Gray500}"
                               CharacterSpacing="1.5" />

                        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                            <Label Text="{Binding TotalRevenueDisplay}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="36"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                   VerticalOptions="Center" />

                            <!-- Orders badge -->
                            <Border Grid.Column="1"
                                    Padding="10,6"
                                    BackgroundColor="{StaticResource Primary}"
                                    StrokeShape="RoundRectangle 20"
                                    StrokeThickness="0"
                                    VerticalOptions="Center">
                                <Label Text="{Binding TotalOrdersBadge}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="13"
                                       TextColor="White" />
                            </Border>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- ── ORDER TYPE BREAKDOWN card ── -->
                <Border Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}">
                    <VerticalStackLayout Spacing="0">

                        <Label Text="{h:Translate ByOrderType}"
                               FontSize="11"
                               TextColor="{StaticResource Gray500}"
                               CharacterSpacing="1.5"
                               Margin="0,0,0,12" />

                        <!-- Order type rows via BindableLayout -->
                        <VerticalStackLayout Spacing="16"
                                             BindableLayout.ItemsSource="{Binding OrderTypes}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:OrderTypeItem">
                                    <VerticalStackLayout Spacing="6">

                                        <!-- Type name + percent on left, revenue on right -->
                                        <Grid ColumnDefinitions="*,Auto">
                                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                                <Label Text="{Binding TypeName}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="14"
                                                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                                       VerticalOptions="Center" />
                                                <Border Padding="6,3"
                                                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}"
                                                        StrokeShape="RoundRectangle 6"
                                                        StrokeThickness="0">
                                                    <Label Text="{Binding PercentDisplay}"
                                                           FontSize="12"
                                                           TextColor="{StaticResource Gray600}" />
                                                </Border>
                                            </HorizontalStackLayout>
                                            <Label Grid.Column="1"
                                                   Text="{Binding RevenueDisplay}"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="15"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                                   VerticalOptions="Center" />
                                        </Grid>

                                        <!-- Red progress bar -->
                                        <ProgressBar Progress="{Binding PercentProgress}"
                                                     ProgressColor="{StaticResource Primary}"
                                                     HeightRequest="6" />

                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- ── ORDER COUNTS section ── -->
                <Border Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}">
                    <VerticalStackLayout Spacing="0">

                        <Label Text="{h:Translate OrderCounts}"
                               FontSize="11"
                               TextColor="{StaticResource Gray500}"
                               CharacterSpacing="1.5"
                               Margin="0,0,0,12" />

                        <!-- Per-type count tiles via BindableLayout on FlexLayout -->
                        <FlexLayout Wrap="Wrap"
                                    JustifyContent="Start"
                                    AlignItems="Start"
                                    BindableLayout.ItemsSource="{Binding OrderTypes}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:OrderTypeItem">
                                    <Border Padding="14,12"
                                            Margin="0,0,10,10"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}"
                                            StrokeShape="RoundRectangle 12"
                                            StrokeThickness="0"
                                            MinimumWidthRequest="100">
                                        <VerticalStackLayout Spacing="4">
                                            <Label Text="{Binding Orders}"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="28"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                                            <Label FontSize="12"
                                                   TextColor="{StaticResource Gray500}">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding TypeName}" />
                                                        <Span Text=" " />
                                                        <Span Text="{h:Translate Count}" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Label Text="{Binding OrdersChangeDisplay}"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="12"
                                                   TextColor="{Binding OrdersChangeColor}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </FlexLayout>

                        <!-- Cancelled orders tile -->
                        <Border Padding="14,12"
                                Margin="0,0,10,10"
                                BackgroundColor="{AppThemeBinding Light=#FFF5F5, Dark=#4A1515}"
                                StrokeShape="RoundRectangle 12"
                                StrokeThickness="0"
                                MinimumWidthRequest="100"
                                HorizontalOptions="Start">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="{Binding CancelledOrders}"
                                       FontFamily="OpenSansSemibold"
                                       FontSize="28"
                                       TextColor="#E74C3C" />
                                <Label Text="{h:Translate Cancelled}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray500}" />
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </Border>

                <!-- ── PERIOD BREAKDOWN section ── -->
                <Border Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                        IsVisible="{Binding HasTimePeriodData}">
                    <VerticalStackLayout Spacing="0">

                        <Label Text="{h:Translate PeriodBreakdown}"
                               FontSize="11"
                               TextColor="{StaticResource Gray500}"
                               CharacterSpacing="1.5"
                               Margin="0,0,0,12" />

                        <VerticalStackLayout Spacing="0"
                                             BindableLayout.ItemsSource="{Binding TimePeriods}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:SalesPeriodItem">
                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                          ColumnSpacing="14"
                                          Padding="0,10"
                                          VerticalOptions="Center">

                                        <!-- Period icon circle -->
                                        <Border Padding="10"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}"
                                                StrokeShape="RoundRectangle 24"
                                                StrokeThickness="0"
                                                WidthRequest="44"
                                                HeightRequest="44"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding PeriodIcon}"
                                                   FontSize="18"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center" />
                                        </Border>

                                        <!-- Period name + time range -->
                                        <VerticalStackLayout Grid.Column="1"
                                                             Spacing="2"
                                                             VerticalOptions="Center">
                                            <Label Text="{Binding PeriodNameDisplay}"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="14"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}" />
                                            <Label Text="{Binding TimeRangeDisplay}"
                                                   FontSize="12"
                                                   TextColor="{StaticResource Gray500}" />
                                        </VerticalStackLayout>

                                        <!-- Revenue + percent -->
                                        <VerticalStackLayout Grid.Column="2"
                                                             Spacing="2"
                                                             HorizontalOptions="End"
                                                             VerticalOptions="Center">
                                            <Label Text="{Binding RevenueDisplay}"
                                                   FontFamily="OpenSansSemibold"
                                                   FontSize="15"
                                                   TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                                   HorizontalOptions="End" />
                                            <Label Text="{Binding PercentDisplay}"
                                                   FontSize="12"
                                                   TextColor="{StaticResource Gray500}"
                                                   HorizontalOptions="End" />
                                        </VerticalStackLayout>

                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- ── HOURLY SALES section ── -->
                <Border Padding="16"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray800}}"
                        StrokeShape="RoundRectangle 14"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}"
                        IsVisible="{Binding HasHourlyData}">
                    <VerticalStackLayout Spacing="0">

                        <Label Text="{h:Translate HourlySales}"
                               FontSize="11"
                               TextColor="{StaticResource Gray500}"
                               CharacterSpacing="1.5"
                               Margin="0,0,0,12" />

                        <!-- Hour rows -->
                        <VerticalStackLayout Spacing="0"
                                             BindableLayout.ItemsSource="{Binding VisibleHours}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:SalesHourItem">
                                    <VerticalStackLayout Spacing="6" Padding="0,8,0,8">

                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                                            <!-- Hour label badge -->
                                            <Border Padding="8,4"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray700}}"
                                                    StrokeShape="RoundRectangle 6"
                                                    StrokeThickness="0"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding HourLabel}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="13"
                                                       TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}"
                                                       VerticalOptions="Center" />
                                            </Border>

                                            <!-- Orders count -->
                                            <Label Grid.Column="1"
                                                   Text="{Binding OrdersDisplay}"
                                                   FontSize="13"
                                                   TextColor="{StaticResource Gray500}"
                                                   VerticalOptions="Center" />

                                            <!-- Revenue + percent -->
                                            <VerticalStackLayout Grid.Column="2"
                                                                 Spacing="1"
                                                                 HorizontalOptions="End"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding RevenueDisplay}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="14"
                                                       TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                                       HorizontalOptions="End" />
                                                <Label Text="{Binding PercentDisplay}"
                                                       FontSize="11"
                                                       TextColor="{StaticResource Gray500}"
                                                       HorizontalOptions="End" />
                                            </VerticalStackLayout>
                                        </Grid>

                                        <!-- Percent progress bar -->
                                        <ProgressBar Progress="{Binding PercentProgress}"
                                                     ProgressColor="{StaticResource Primary}"
                                                     HeightRequest="4" />

                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- Show More button -->
                        <Button Text="{h:Translate ShowMore}"
                                Command="{Binding ShowMoreHoursCommand}"
                                IsVisible="{Binding CanShowMoreHours}"
                                BackgroundColor="Transparent"
                                TextColor="{StaticResource Primary}"
                                FontFamily="OpenSansSemibold"
                                FontSize="14"
                                Padding="0,12,0,4"
                                BorderWidth="0" />

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
