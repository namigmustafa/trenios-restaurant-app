<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Trenios.Mobile.ViewModels"
             xmlns:api="clr-namespace:Trenios.Mobile.Models.Api"
             xmlns:h="clr-namespace:Trenios.Mobile.Helpers"
             x:Class="Trenios.Mobile.Pages.BranchSelectionPage"
             x:DataType="vm:BranchSelectionViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Gray100}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                BackgroundColor="White"
                HeightRequest="{OnIdiom Phone=72, Tablet=96}"
                Padding="16,0">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">

                <!-- Logo -->
                <Image Source="trenios_logo_red.png"
                       HeightRequest="{OnIdiom Phone=100, Tablet=140}"
                       WidthRequest="{OnIdiom Phone=100, Tablet=140}"
                       Aspect="AspectFit"
                       HorizontalOptions="Start"
                       VerticalOptions="Center"/>

                <!-- Language button -->
                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="1.5"
                        Stroke="{StaticResource Gray200}"
                        BackgroundColor="Transparent"
                        Padding="14,8"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLanguageTapped"/>
                    </Border.GestureRecognizers>
                    <Label x:Name="CurrentLanguageLabelHeader"
                           Text="EN"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{StaticResource Gray700}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"/>
                </Border>

                <!-- Logout button -->
                <Border Grid.Column="2"
                        StrokeShape="RoundRectangle 10"
                        StrokeThickness="0"
                        BackgroundColor="{StaticResource Primary}"
                        HeightRequest="40"
                        WidthRequest="40"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="&#x2794;"
                           FontSize="18"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

            </Grid>
        </Border>

        <!-- Separator -->
        <BoxView Grid.Row="1" HeightRequest="1" BackgroundColor="{StaticResource Gray200}"/>

        <!-- Content -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout HorizontalOptions="Center"
                                 MaximumWidthRequest="600"
                                 Padding="20,16,20,24"
                                 Spacing="0">

                <!-- Restaurant info -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14" Margin="0,0,0,20">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="0"
                            HeightRequest="56"
                            WidthRequest="56"
                            BackgroundColor="{StaticResource Gray200}"
                            VerticalOptions="Center">
                        <Image Source="{Binding RestaurantImageUrl, Converter={StaticResource ImageFallbackConverter}}"
                               Aspect="AspectFill"
                               HeightRequest="56"
                               WidthRequest="56"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                        <Label Text="{Binding RestaurantName}"
                               FontFamily="OpenSansSemibold"
                               FontSize="22"
                               TextColor="{StaticResource Gray900}"/>
                        <Label Text="{h:Translate SelectBranch}"
                               FontSize="13"
                               TextColor="{StaticResource Secondary}"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- Back button (SuperAdmin / RestaurantOwner) -->
                <Button Text="{h:Translate SelectRestaurant}"
                        Command="{Binding BackCommand}"
                        IsVisible="{Binding CanGoBack}"
                        BackgroundColor="{StaticResource Gray200}"
                        TextColor="{StaticResource Gray700}"
                        BorderColor="Transparent"
                        BorderWidth="0"
                        CornerRadius="10"
                        HeightRequest="40"
                        FontSize="13"
                        HorizontalOptions="Start"
                        Padding="16,0"
                        Margin="0,0,0,16"/>

                <!-- Loading -->
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   HorizontalOptions="Center"
                                   Margin="0,40,0,0"/>

                <!-- Error banner -->
                <Border IsVisible="{Binding HasError}"
                        StrokeShape="RoundRectangle 12"
                        StrokeThickness="1"
                        Stroke="#FECACA"
                        BackgroundColor="#FEF2F2"
                        Padding="14,12"
                        Margin="0,0,0,16">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="&#x26A0;"
                               TextColor="{StaticResource Primary}"
                               FontSize="16"
                               VerticalOptions="Center"/>
                        <Label Text="{Binding ErrorMessage}"
                               TextColor="#B91C1C"
                               FontFamily="OpenSansSemibold"
                               FontSize="13"
                               VerticalOptions="Center"
                               HorizontalOptions="Fill"/>
                        <Button Text="{h:Translate Retry}"
                                Command="{Binding RefreshCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                HeightRequest="32"
                                CornerRadius="8"
                                FontSize="12"
                                Padding="10,0"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Branch list -->
                <CollectionView ItemsSource="{Binding Branches}"
                                IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="api:BranchDto">
                            <Border StrokeShape="RoundRectangle 16"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource Gray200}"
                                    BackgroundColor="White"
                                    Padding="16">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BranchSelectionViewModel}}, Path=SelectBranchCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                    <!-- Branch icon (red square with first letter) -->
                                    <Border Grid.Column="0"
                                            StrokeShape="RoundRectangle 14"
                                            StrokeThickness="0"
                                            HeightRequest="64"
                                            WidthRequest="64"
                                            BackgroundColor="{StaticResource Primary}"
                                            VerticalOptions="Center">
                                        <Label Text="{Binding Name[0]}"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="22"
                                               TextColor="White"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>
                                    <!-- Branch name + address -->
                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="5"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="16"
                                               TextColor="{StaticResource Gray900}"/>
                                        <HorizontalStackLayout Spacing="4"
                                                               IsVisible="{Binding Address, Converter={StaticResource IsNotNullOrEmptyConverter}}">
                                            <Label Text="&#x2315;"
                                                   FontSize="13"
                                                   TextColor="{StaticResource Gray400}"
                                                   VerticalOptions="Center"/>
                                            <Label Text="{Binding TruncatedAddress}"
                                                   FontSize="13"
                                                   TextColor="{StaticResource Gray500}"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                    <!-- Arrow -->
                                    <Label Grid.Column="2"
                                           Text="›"
                                           FontSize="26"
                                           TextColor="{StaticResource Gray400}"
                                           VerticalOptions="Center"
                                           HorizontalOptions="End"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center"
                                             HorizontalOptions="Center"
                                             Spacing="12"
                                             Margin="0,60,0,0">
                            <Label Text="{h:Translate NoBranchesFound}"
                                   FontSize="16"
                                   TextColor="{StaticResource Gray400}"
                                   HorizontalOptions="Center"/>
                            <Button Text="{h:Translate Retry}"
                                    Command="{Binding RefreshCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    WidthRequest="120"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Full screen loading overlay -->
        <Grid Grid.RowSpan="3"
              IsVisible="{Binding IsNavigating}"
              BackgroundColor="#80000000">
            <ActivityIndicator IsRunning="True"
                               Color="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               HeightRequest="48"
                               WidthRequest="48"/>
        </Grid>

        <!-- Language popup -->
        <Grid x:Name="LanguagePopup"
              Grid.RowSpan="3"
              IsVisible="False"
              BackgroundColor="#80000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseLanguagePopup"/>
            </Grid.GestureRecognizers>
            <Border VerticalOptions="Center"
                    HorizontalOptions="Center"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="0"
                    BackgroundColor="White"
                    Padding="0"
                    WidthRequest="300">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer/>
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="0">
                    <Label Text="{h:Translate Language}"
                           FontFamily="OpenSansSemibold"
                           FontSize="20"
                           Padding="20,16"
                           BackgroundColor="{StaticResource Primary}"
                           TextColor="White"/>
                    <VerticalStackLayout Padding="8">
                        <Button Text="English" Style="{StaticResource GhostButton}" HorizontalOptions="Fill" Clicked="OnLanguageSelected" AutomationId="en"/>
                        <Button Text="Azərbaycan" Style="{StaticResource GhostButton}" HorizontalOptions="Fill" Clicked="OnLanguageSelected" AutomationId="az"/>
                        <Button Text="Русский" Style="{StaticResource GhostButton}" HorizontalOptions="Fill" Clicked="OnLanguageSelected" AutomationId="ru"/>
                        <Button Text="Türkçe" Style="{StaticResource GhostButton}" HorizontalOptions="Fill" Clicked="OnLanguageSelected" AutomationId="tr"/>
                        <Button Text="Latviešu" Style="{StaticResource GhostButton}" HorizontalOptions="Fill" Clicked="OnLanguageSelected" AutomationId="lv"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>

</ContentPage>
