<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Trenios.Mobile.ViewModels"
             xmlns:models="clr-namespace:Trenios.Mobile.Models.Api"
             xmlns:h="clr-namespace:Trenios.Mobile.Helpers"
             x:Class="Trenios.Mobile.Pages.KitchenDisplayPage"
             x:DataType="viewmodels:KitchenDisplayViewModel"
             Title="{h:Translate KitchenDisplay}"
             BackgroundColor="#ecf0f1">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0"
              BackgroundColor="White"
              Padding="16,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Text="{h:Translate Back}"
                    Command="{Binding BackCommand}"
                    BackgroundColor="#e67e22"
                    TextColor="White"
                    FontSize="14"
                    HeightRequest="40"
                    CornerRadius="6"
                    Padding="16,0"/>

            <Label Grid.Column="1"
                   Text="{h:Translate KitchenDisplay}"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#2c3e50"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>

            <!-- Connection Status -->
            <Frame Grid.Column="2"
                   BackgroundColor="{Binding ConnectionStatusColor}"
                   CornerRadius="6"
                   Padding="10,6"
                   HasShadow="False"
                   VerticalOptions="Center"
                   Margin="0,0,10,0"
                   BorderColor="#bdc3c7">
                <Label Text="{Binding ConnectionStatusText}"
                       TextColor="White"
                       FontSize="12"
                       FontAttributes="Bold"/>
            </Frame>

            <Button Grid.Column="3"
                    Text="{h:Translate Refresh}"
                    Command="{Binding RefreshCommand}"
                    BackgroundColor="#e67e22"
                    TextColor="White"
                    FontSize="14"
                    HeightRequest="40"
                    CornerRadius="6"
                    Padding="16,0"/>
        </Grid>

        <!-- Orders Grid -->
        <Grid Grid.Row="1" BackgroundColor="#ecf0f1" Padding="14">
            <CollectionView ItemsSource="{Binding ActiveOrders}"
                            SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical"
                                     Span="3"
                                     HorizontalItemSpacing="14"
                                     VerticalItemSpacing="14"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:OrderResponse">
                        <Frame BackgroundColor="White"
                               CornerRadius="8"
                               Padding="18"
                               HasShadow="True"
                               BorderColor="{Binding UrgencyColor}">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:KitchenDisplayViewModel}}, Path=SelectOrderCommand}"
                                                      CommandParameter="{Binding .}"/>
                            </Frame.GestureRecognizers>
                            <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

                                <!-- Order Number & Timer -->
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                                    <Label Grid.Column="0"
                                           Text="{Binding OrderNumber}"
                                           TextColor="#2c3e50"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center"
                                           LineBreakMode="NoWrap"
                                           Margin="0,0,6,0"/>
                                    <Frame Grid.Column="1"
                                           BackgroundColor="{Binding UrgencyColor}"
                                           CornerRadius="4"
                                           Padding="6,3"
                                           HasShadow="False"
                                           VerticalOptions="Center"
                                           BorderColor="{Binding UrgencyColor}">
                                        <Label Text="{Binding AgeDisplay}"
                                               TextColor="White"
                                               FontSize="11"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               LineBreakMode="NoWrap"/>
                                    </Frame>
                                </Grid>

                                <!-- Separator Line -->
                                <BoxView Grid.Row="1"
                                         Color="#dee2e6"
                                         HeightRequest="1"
                                         Margin="0,0,0,12"/>

                                <!-- Items List -->
                                <VerticalStackLayout Grid.Row="2" Spacing="10">
                                    <BindableLayout.ItemsSource>
                                        <Binding Path="Items"/>
                                    </BindableLayout.ItemsSource>
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:OrderItemResponse">
                                            <VerticalStackLayout Spacing="4">
                                                <Grid ColumnDefinitions="Auto,*">
                                                    <Frame Grid.Column="0"
                                                           BackgroundColor="#e67e22"
                                                           CornerRadius="4"
                                                           Padding="8,4"
                                                           HasShadow="False"
                                                           VerticalOptions="Center"
                                                           Margin="0,0,10,0"
                                                           BorderColor="#d35400">
                                                        <Label Text="{Binding QuantityDisplay}"
                                                               TextColor="White"
                                                               FontSize="18"
                                                               FontAttributes="Bold"
                                                               HorizontalTextAlignment="Center"/>
                                                    </Frame>
                                                    <Label Grid.Column="1"
                                                           Text="{Binding MenuItemName}"
                                                           TextColor="#2c3e50"
                                                           FontSize="18"
                                                           FontAttributes="Bold"
                                                           VerticalOptions="Center"
                                                           LineBreakMode="WordWrap"/>
                                                </Grid>
                                                <Label Text="{Binding AdditionsSummary}"
                                                       TextColor="#7f8c8d"
                                                       FontSize="14"
                                                       IsVisible="{Binding HasAdditions}"
                                                       Margin="0,0,0,0"
                                                       LineBreakMode="WordWrap"/>
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                                <!-- Separator Line Before Status -->
                                <BoxView Grid.Row="3"
                                         Color="#dee2e6"
                                         HeightRequest="1"
                                         Margin="0,12,0,0"/>

                                <!-- Status & Time (Bottom) -->
                                <HorizontalStackLayout Grid.Row="4" Spacing="10" Margin="0,10,0,0">
                                    <Frame BackgroundColor="{Binding StatusColor}"
                                           CornerRadius="4"
                                           Padding="8,4"
                                           HasShadow="False"
                                           BorderColor="{Binding StatusColor}">
                                        <Label Text="{Binding StatusDisplay}"
                                               TextColor="White"
                                               FontSize="12"
                                               FontAttributes="Bold"/>
                                    </Frame>
                                    <Label Text="{Binding PlacedAtDisplay}"
                                           TextColor="#7f8c8d"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="40">
                        <Label Text="✓"
                               TextColor="#27ae60"
                               FontSize="64"
                               HorizontalOptions="Center"
                               FontAttributes="Bold"/>
                        <Label Text="{h:Translate NoActiveOrders}"
                               TextColor="#2c3e50"
                               FontSize="22"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               Margin="0,16,0,0"/>
                        <Label Text="{h:Translate NewOrdersAppear}"
                               TextColor="#7f8c8d"
                               FontSize="15"
                               HorizontalOptions="Center"
                               Margin="0,8,0,0"/>
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>

            <!-- Loading Overlay -->
            <Frame BackgroundColor="#CC000000"
                   IsVisible="{Binding IsLoading}"
                   CornerRadius="0"
                   HasShadow="False">
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   Color="White"
                                   HeightRequest="40"
                                   WidthRequest="40"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
            </Frame>
        </Grid>

        <!-- Order Details Popup -->
        <Grid Grid.RowSpan="2"
              IsVisible="{Binding HasSelectedOrder}"
              BackgroundColor="#DD000000"
              Padding="{OnPlatform Android='0,20,0,0', Default=0}">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ClosePopupCommand}"/>
            </Grid.GestureRecognizers>

            <Frame VerticalOptions="Center"
                   HorizontalOptions="Fill"
                   BackgroundColor="White"
                   CornerRadius="10"
                   Padding="0"
                   HasShadow="True"
                   MaximumWidthRequest="850"
                   MaximumHeightRequest="650"
                   Margin="40">
                <Frame.GestureRecognizers>
                    <TapGestureRecognizer/>
                </Frame.GestureRecognizers>

                <Grid RowDefinitions="Auto,*,Auto">

                    <!-- Header -->
                    <Grid Grid.Row="0"
                          BackgroundColor="White"
                          Padding="24,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <VerticalStackLayout>
                            <Label Text="{Binding SelectedOrder.OrderNumber}"
                                   TextColor="#2c3e50"
                                   FontSize="28"
                                   FontAttributes="Bold"/>
                            <HorizontalStackLayout Spacing="10" Margin="0,8,0,0">
                                <Frame BackgroundColor="{Binding SelectedOrder.StatusColor}"
                                       CornerRadius="4"
                                       Padding="8,4"
                                       HasShadow="False"
                                       BorderColor="{Binding SelectedOrder.StatusColor}">
                                    <Label Text="{Binding SelectedOrder.StatusDisplay}"
                                           TextColor="White"
                                           FontSize="12"
                                           FontAttributes="Bold"/>
                                </Frame>
                                <Label Text="{Binding SelectedOrder.OrderTypeDisplay}"
                                       TextColor="#7f8c8d"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"/>
                                <Label Text="•"
                                       TextColor="#bdc3c7"
                                       FontSize="14"
                                       VerticalOptions="Center"/>
                                <Label Text="{Binding SelectedOrder.PlacedAtFullDisplay}"
                                       TextColor="#7f8c8d"
                                       FontSize="14"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                        <Frame Grid.Column="1"
                               BackgroundColor="{Binding SelectedOrder.UrgencyColor}"
                               CornerRadius="8"
                               Padding="14,8"
                               HasShadow="False"
                               VerticalOptions="Center"
                               Margin="0,0,14,0"
                               BorderColor="{Binding SelectedOrder.UrgencyColor}">
                            <Label Text="{Binding SelectedOrder.AgeDisplay}"
                                   TextColor="White"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"/>
                        </Frame>
                        <Button Grid.Column="2"
                                Text="✕"
                                Command="{Binding ClosePopupCommand}"
                                BackgroundColor="#e74c3c"
                                TextColor="White"
                                FontSize="20"
                                WidthRequest="44"
                                HeightRequest="44"
                                CornerRadius="22"
                                VerticalOptions="Center"/>
                    </Grid>

                    <!-- Items List -->
                    <ScrollView Grid.Row="1" Padding="24,16">
                        <VerticalStackLayout Spacing="14"
                                             BindableLayout.ItemsSource="{Binding SelectedOrder.Items}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:OrderItemResponse">
                                    <Frame BackgroundColor="#f8f9fa"
                                           CornerRadius="8"
                                           Padding="18"
                                           HasShadow="False"
                                           BorderColor="#dee2e6">
                                        <VerticalStackLayout Spacing="12">
                                            <Grid ColumnDefinitions="Auto,*">
                                                <Frame Grid.Column="0"
                                                       BackgroundColor="#e67e22"
                                                       CornerRadius="6"
                                                       Padding="12,8"
                                                       HasShadow="False"
                                                       VerticalOptions="Center"
                                                       Margin="0,0,14,0"
                                                       BorderColor="#d35400">
                                                    <Label Text="{Binding QuantityDisplay}"
                                                           TextColor="White"
                                                           FontSize="22"
                                                           FontAttributes="Bold"
                                                           HorizontalTextAlignment="Center"/>
                                                </Frame>
                                                <Label Grid.Column="1"
                                                       Text="{Binding MenuItemName}"
                                                       TextColor="#2c3e50"
                                                       FontSize="22"
                                                       FontAttributes="Bold"
                                                       VerticalOptions="Center"
                                                       LineBreakMode="WordWrap"/>
                                            </Grid>

                                            <!-- Additions -->
                                            <VerticalStackLayout Spacing="8"
                                                                IsVisible="{Binding HasAdditions}"
                                                                Margin="0,4,0,0">
                                                <BindableLayout.ItemsSource>
                                                    <Binding Path="Additions"/>
                                                </BindableLayout.ItemsSource>
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="models:OrderItemAdditionResponse">
                                                        <HorizontalStackLayout Spacing="8">
                                                            <Label Text="+"
                                                                   TextColor="#e67e22"
                                                                   FontSize="16"
                                                                   FontAttributes="Bold"/>
                                                            <Label TextColor="#2c3e50" FontSize="16">
                                                                <Label.FormattedText>
                                                                    <FormattedString>
                                                                        <Span Text="{Binding AdditionName}" FontAttributes="Bold"/>
                                                                        <Span Text=" ×" FontAttributes="Bold"/>
                                                                        <Span Text="{Binding Quantity}" FontAttributes="Bold"/>
                                                                    </FormattedString>
                                                                </Label.FormattedText>
                                                            </Label>
                                                        </HorizontalStackLayout>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </Frame>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </ScrollView>

                    <!-- Action Buttons -->
                    <Grid Grid.Row="2"
                          ColumnDefinitions="*,*"
                          ColumnSpacing="14"
                          Padding="24,20"
                          BackgroundColor="White">
                        <Button Grid.Column="0"
                                Text="{h:Translate StartPreparing}"
                                Command="{Binding StartPreparingCommand}"
                                BackgroundColor="#f39c12"
                                TextColor="White"
                                FontSize="16"
                                FontAttributes="Bold"
                                HeightRequest="54"
                                CornerRadius="8"/>

                        <Button Grid.Column="1"
                                Text="{h:Translate MarkCompleted}"
                                Command="{Binding MarkCompletedCommand}"
                                BackgroundColor="#27ae60"
                                TextColor="White"
                                FontSize="16"
                                FontAttributes="Bold"
                                HeightRequest="54"
                                CornerRadius="8"/>
                    </Grid>
                </Grid>
            </Frame>
        </Grid>

    </Grid>
</ContentPage>
