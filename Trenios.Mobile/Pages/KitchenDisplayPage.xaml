<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Trenios.Mobile.ViewModels"
             xmlns:models="clr-namespace:Trenios.Mobile.Models.Api"
             xmlns:h="clr-namespace:Trenios.Mobile.Helpers"
             x:Class="Trenios.Mobile.Pages.KitchenDisplayPage"
             x:DataType="viewmodels:KitchenDisplayViewModel"
             Title="{h:Translate KitchenDisplay}"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- ==================== PAGE HEADER ==================== -->
        <VerticalStackLayout Grid.Row="0" BackgroundColor="White">
            <Grid Padding="16,12" HeightRequest="64" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                <Image Source="trenios_logo_red.png"
                       HeightRequest="36"
                       HorizontalOptions="Start"
                       VerticalOptions="Center"
                       Aspect="AspectFit"/>

                <!-- Connection dot -->
                <Ellipse Grid.Column="1"
                         WidthRequest="10" HeightRequest="10"
                         Fill="{Binding ConnectionStatusColor}"
                         VerticalOptions="Center"/>

                <Border Grid.Column="2"
                        x:Name="LanguageBorder"
                        Padding="12,6"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="1.5"
                        Stroke="{StaticResource Gray300}"
                        BackgroundColor="White"
                        VerticalOptions="Center">
                    <Label x:Name="CurrentLanguageLabel"
                           Text="EN"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{StaticResource Gray700}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLanguageTapped"/>
                    </Border.GestureRecognizers>
                </Border>
                <Border Grid.Column="3"
                        Padding="12,8"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0"
                        BackgroundColor="{StaticResource Primary}"
                        VerticalOptions="Center">
                    <Label Text="&#x2794;"
                           FontSize="16"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                    </Border.GestureRecognizers>
                </Border>
            </Grid>
            <BoxView HeightRequest="1" Color="{StaticResource Gray200}"/>

            <!-- Restaurant · Branch row -->
            <Grid Padding="16,10" HeightRequest="52" ColumnDefinitions="Auto,*" BackgroundColor="White">
                <Border WidthRequest="34" HeightRequest="34"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0"
                        BackgroundColor="{StaticResource Primary}"
                        VerticalOptions="Center"
                        IsVisible="{Binding HasRestaurantLogo, Converter={StaticResource InvertedBoolConverter}}">
                    <Label Text="{Binding RestaurantName, Converter={StaticResource FirstLetterConverter}}"
                           TextColor="White"
                           FontFamily="OpenSansSemibold"
                           FontSize="15"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>
                <Image Source="{Binding RestaurantLogoUrl}"
                       WidthRequest="34" HeightRequest="34"
                       Aspect="AspectFill"
                       VerticalOptions="Center"
                       IsVisible="{Binding HasRestaurantLogo}">
                    <Image.Clip>
                        <RoundRectangleGeometry Rect="0,0,34,34" CornerRadius="8"/>
                    </Image.Clip>
                </Image>
                <VerticalStackLayout Grid.Column="1" Spacing="1" Margin="10,0,0,0" VerticalOptions="Center">
                    <Label Text="{Binding RestaurantName}"
                           FontFamily="OpenSansSemibold"
                           FontSize="14"
                           TextColor="{StaticResource Gray900}"
                           LineBreakMode="TailTruncation"/>
                    <Label Text="{Binding BranchName}"
                           FontSize="12"
                           TextColor="{StaticResource Gray500}"
                           LineBreakMode="TailTruncation"/>
                </VerticalStackLayout>
            </Grid>
            <BoxView HeightRequest="1" Color="{StaticResource Gray200}"/>
        </VerticalStackLayout>

        <!-- ==================== ORDERS GRID ==================== -->
        <Grid Grid.Row="1" BackgroundColor="{StaticResource Gray100}" Padding="12">
            <RefreshView Command="{Binding RefreshCommand}"
                         IsRefreshing="{Binding IsRefreshing}">
                <CollectionView ItemsSource="{Binding ActiveOrders}"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical"
                                         Span="{OnIdiom Phone=1, Default=3}"
                                         HorizontalItemSpacing="12"
                                         VerticalItemSpacing="12"/>
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:OrderResponse">
                            <Border StrokeShape="RoundRectangle 12"
                                    StrokeThickness="0"
                                    BackgroundColor="White"
                                    Padding="0"
                                    Margin="2">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:KitchenDisplayViewModel}}, Path=SelectOrderCommand}"
                                                          CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Opacity="0.06" Radius="8" Offset="0,2"/>
                                </Border.Shadow>

                                <Grid RowDefinitions="Auto,*">

                                    <!-- Red header: order number + age only -->
                                    <Grid Grid.Row="0"
                                          Padding="14,12"
                                          BackgroundColor="{StaticResource Primary}"
                                          ColumnDefinitions="*,Auto"
                                          ColumnSpacing="8">
                                        <Label Text="{Binding OrderNumber}"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="17"
                                               TextColor="White"
                                               VerticalOptions="Center"
                                               LineBreakMode="NoWrap"/>
                                        <HorizontalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                            <Label Text="⏱"
                                                   FontSize="11"
                                                   TextColor="White"
                                                   VerticalOptions="Center"/>
                                            <Label Text="{Binding AgeDisplay}"
                                                   FontSize="12"
                                                   FontFamily="OpenSansSemibold"
                                                   TextColor="White"
                                                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Grid>

                                    <!-- White body -->
                                    <VerticalStackLayout Grid.Row="1" Padding="14,12" Spacing="0">

                                        <!-- Order type + status row -->
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                                <Label Text="{Binding OrderTypeIcon}" FontSize="14" VerticalOptions="Center"/>
                                                <Label Text="{Binding OrderTypeDisplay}"
                                                       FontSize="13"
                                                       TextColor="{StaticResource Gray600}"
                                                       VerticalOptions="Center"/>
                                                <Label Text="{Binding TableDisplay}"
                                                       FontSize="13"
                                                       TextColor="{StaticResource Primary}"
                                                       FontFamily="OpenSansSemibold"
                                                       IsVisible="{Binding HasTable}"
                                                       VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                            <Border Grid.Column="1"
                                                    Padding="8,4"
                                                    StrokeShape="RoundRectangle 6"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{Binding StatusColor}"
                                                    VerticalOptions="Center">
                                                <Label Text="{Binding StatusDisplay}"
                                                       FontSize="11"
                                                       FontFamily="OpenSansSemibold"
                                                       TextColor="White"/>
                                            </Border>
                                        </Grid>

                                        <!-- Items -->
                                        <VerticalStackLayout Spacing="10"
                                                             BindableLayout.ItemsSource="{Binding Items}">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="models:OrderItemResponse">
                                                    <VerticalStackLayout Spacing="3">
                                                        <Label FontSize="15" FontFamily="OpenSansSemibold"
                                                               TextColor="{StaticResource Gray900}"
                                                               LineBreakMode="WordWrap">
                                                            <Label.FormattedText>
                                                                <FormattedString>
                                                                    <Span Text="{Binding Quantity}" FontAttributes="Bold"/>
                                                                    <Span Text="x " FontAttributes="Bold"/>
                                                                    <Span Text="{Binding MenuItemName}" FontAttributes="Bold"/>
                                                                </FormattedString>
                                                            </Label.FormattedText>
                                                        </Label>
                                                        <VerticalStackLayout Spacing="2"
                                                                             IsVisible="{Binding HasAdditions}"
                                                                             BindableLayout.ItemsSource="{Binding Additions}">
                                                            <BindableLayout.ItemTemplate>
                                                                <DataTemplate x:DataType="models:OrderItemAdditionResponse">
                                                                    <Label Text="{Binding DisplayText}"
                                                                           FontSize="13"
                                                                           TextColor="{StaticResource Primary}"
                                                                           LineBreakMode="WordWrap"
                                                                           Margin="8,0,0,0"/>
                                                                </DataTemplate>
                                                            </BindableLayout.ItemTemplate>
                                                        </VerticalStackLayout>
                                                    </VerticalStackLayout>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </VerticalStackLayout>

                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>

                    <CollectionView.EmptyView>
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Padding="40">
                            <Label Text="✓"
                                   TextColor="#27ae60"
                                   FontSize="64"
                                   HorizontalOptions="Center"
                                   FontAttributes="Bold"/>
                            <Label Text="{h:Translate NoActiveOrders}"
                                   TextColor="{StaticResource Gray900}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="22"
                                   HorizontalOptions="Center"
                                   Margin="0,16,0,0"/>
                            <Label Text="{h:Translate NewOrdersAppear}"
                                   TextColor="{StaticResource Gray500}"
                                   FontSize="15"
                                   HorizontalOptions="Center"
                                   Margin="0,8,0,0"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                </CollectionView>
            </RefreshView>

            <!-- Loading Overlay — only on initial load, not during pull-to-refresh -->
            <Border BackgroundColor="#CC000000"
                    IsVisible="{Binding IsLoadingOverlay}"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 0">
                <ActivityIndicator IsRunning="{Binding IsLoadingOverlay}"
                                   Color="White"
                                   HeightRequest="40"
                                   WidthRequest="40"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
            </Border>
        </Grid>

        <!-- ==================== ORDER DETAILS POPUP (full screen) ==================== -->
        <Grid Grid.RowSpan="2"
              IsVisible="{Binding HasSelectedOrder}"
              BackgroundColor="#DD000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ClosePopupCommand}"/>
            </Grid.GestureRecognizers>

            <Border VerticalOptions="Fill"
                    HorizontalOptions="Fill"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 0"
                    StrokeThickness="0"
                    Padding="0">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer/>
                </Border.GestureRecognizers>

                <Grid RowDefinitions="Auto,*,Auto">

                    <!-- Popup header: red -->
                    <Grid Grid.Row="0"
                          BackgroundColor="{StaticResource Primary}"
                          Padding="16,14"
                          ColumnDefinitions="*,Auto,Auto"
                          ColumnSpacing="10">

                        <VerticalStackLayout VerticalOptions="Center">
                            <Label Text="{Binding SelectedOrder.OrderNumber}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="22"
                                   TextColor="White"/>
                            <HorizontalStackLayout Spacing="8" Margin="0,6,0,0">
                                <Border Padding="8,4"
                                        StrokeShape="RoundRectangle 6"
                                        StrokeThickness="0"
                                        BackgroundColor="{Binding SelectedOrder.StatusColor}">
                                    <Label Text="{Binding SelectedOrder.StatusDisplay}"
                                           FontSize="12"
                                           FontFamily="OpenSansSemibold"
                                           TextColor="White"/>
                                </Border>
                                <Label Text="{Binding SelectedOrder.OrderTypeDisplay}"
                                       FontSize="14"
                                       TextColor="White"
                                       Opacity="0.85"
                                       VerticalOptions="Center"/>
                                <Label Text="{Binding SelectedOrder.TableDisplay}"
                                       FontSize="14"
                                       TextColor="White"
                                       FontFamily="OpenSansSemibold"
                                       IsVisible="{Binding SelectedOrder.HasTable}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <!-- Age -->
                        <Border Grid.Column="1"
                                Padding="10,6"
                                StrokeShape="RoundRectangle 8"
                                StrokeThickness="0"
                                BackgroundColor="#33FFFFFF"
                                VerticalOptions="Center">
                            <HorizontalStackLayout Spacing="4">
                                <Label Text="⏱" FontSize="14" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding SelectedOrder.AgeDisplay}"
                                       FontSize="15"
                                       FontFamily="OpenSansSemibold"
                                       TextColor="White"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Close -->
                        <Button Grid.Column="2"
                                Text="✕"
                                Command="{Binding ClosePopupCommand}"
                                BackgroundColor="#33FFFFFF"
                                TextColor="White"
                                FontSize="16"
                                WidthRequest="40"
                                HeightRequest="40"
                                CornerRadius="20"
                                VerticalOptions="Center"/>
                    </Grid>

                    <!-- Items -->
                    <ScrollView Grid.Row="1" Padding="16,14">
                        <VerticalStackLayout Spacing="12"
                                             BindableLayout.ItemsSource="{Binding SelectedOrder.Items}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:OrderItemResponse">
                                    <Border BackgroundColor="{StaticResource Gray50}"
                                            StrokeShape="RoundRectangle 10"
                                            StrokeThickness="1"
                                            Stroke="{StaticResource Gray200}"
                                            Padding="16">
                                        <VerticalStackLayout Spacing="8">
                                            <Label FontSize="18"
                                                   FontFamily="OpenSansSemibold"
                                                   TextColor="{StaticResource Gray900}"
                                                   LineBreakMode="WordWrap">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding Quantity}" FontAttributes="Bold"/>
                                                        <Span Text="x " FontAttributes="Bold"/>
                                                        <Span Text="{Binding MenuItemName}" FontAttributes="Bold"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <VerticalStackLayout Spacing="4"
                                                                 IsVisible="{Binding HasAdditions}"
                                                                 Margin="8,0,0,0"
                                                                 BindableLayout.ItemsSource="{Binding Additions}">
                                                <BindableLayout.ItemTemplate>
                                                    <DataTemplate x:DataType="models:OrderItemAdditionResponse">
                                                        <Label Text="{Binding DisplayText}"
                                                               FontSize="15"
                                                               TextColor="{StaticResource Primary}"
                                                               LineBreakMode="WordWrap"/>
                                                    </DataTemplate>
                                                </BindableLayout.ItemTemplate>
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </ScrollView>

                    <!-- Action button -->
                    <Grid Grid.Row="2"
                          Padding="16,14"
                          BackgroundColor="White"
                          IsVisible="{Binding SelectedOrder.CanStartPreparing}">
                        <Button Text="{h:Translate StartPreparing}"
                                Command="{Binding StartPreparingCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                FontFamily="OpenSansSemibold"
                                FontSize="16"
                                HeightRequest="52"
                                CornerRadius="10"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</ContentPage>
