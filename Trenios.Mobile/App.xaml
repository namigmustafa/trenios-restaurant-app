<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Trenios.Mobile"
             xmlns:converters="clr-namespace:Trenios.Mobile.Converters"
             x:Class="Trenios.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <converters:IsNotNullConverter x:Key="IsNotNullConverter"/>
            <converters:IsNotNullConverter x:Key="IsNotNullOrEmptyConverter"/>
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
            <converters:BoolToColorConverter x:Key="BoolToColorConverter"/>
            <converters:BoolToBackgroundConverter x:Key="BoolToBackgroundConverter"/>
            <converters:BoolToTextColorConverter x:Key="BoolToTextColorConverter"/>
            <converters:FirstLetterConverter x:Key="FirstLetterConverter"/>
            <converters:QuantityToBoolConverter x:Key="QuantityToBoolConverter"/>
            <converters:BoolToStrokeConverter x:Key="BoolToStrokeConverter"/>
            <converters:BoolToCircleBackgroundConverter x:Key="BoolToCircleBackgroundConverter"/>
            <converters:CountToHeightConverter x:Key="CountToHeightConverter"/>
            <converters:CountToHeightMultiConverter x:Key="CountToHeightMultiConverter"/>
            <converters:BoolToGridLengthConverter x:Key="BoolToGridLengthConverter"/>
            <converters:BoolToColumnSpanConverter x:Key="BoolToColumnSpanConverter"/>
            <converters:BoolToMarginConverter x:Key="BoolToMarginConverter"/>
            <converters:BoolToWidthConverter x:Key="BoolToWidthConverter"/>
            <converters:ImageFallbackConverter x:Key="ImageFallbackConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
