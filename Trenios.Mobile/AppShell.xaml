<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Trenios.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:Trenios.Mobile.Pages"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False">

    <!-- Pre-login pages (no tabs) -->
    <ShellContent
        Title="Login"
        Route="LoginPage"
        ContentTemplate="{DataTemplate pages:LoginPage}" />

    <ShellContent
        Title="Restaurant Selection"
        Route="RestaurantSelection"
        ContentTemplate="{DataTemplate pages:RestaurantSelectionPage}" />

    <ShellContent
        Title="Branch Selection"
        Route="BranchSelection"
        ContentTemplate="{DataTemplate pages:BranchSelectionPage}" />

    <!-- Main app tabs -->
    <TabBar Route="MainTabs">

        <Tab Title="Create Order">
            <Tab.Icon>
                <FontImageSource Glyph="🛒" Size="22" />
            </Tab.Icon>
            <ShellContent x:Name="CreateOrderShellContent" Route="CreateOrderPage" />
        </Tab>

        <Tab Title="Orders">
            <Tab.Icon>
                <FontImageSource Glyph="📋" Size="22" />
            </Tab.Icon>
            <ShellContent
                Route="OrdersPage"
                ContentTemplate="{DataTemplate pages:OrdersPage}" />
        </Tab>

        <Tab Title="Tables">
            <Tab.Icon>
                <FontImageSource Glyph="🪑" Size="22" />
            </Tab.Icon>
            <ShellContent
                Route="TablesPage"
                ContentTemplate="{DataTemplate pages:TablesPage}" />
        </Tab>

        <Tab Title="Kitchen">
            <Tab.Icon>
                <FontImageSource Glyph="👨‍🍳" Size="22" />
            </Tab.Icon>
            <ShellContent
                Route="KitchenPage"
                ContentTemplate="{DataTemplate pages:KitchenDisplayPage}" />
        </Tab>

    </TabBar>

</Shell>
